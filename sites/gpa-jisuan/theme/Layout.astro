  opacity: 0.5;
  max-width: 500px;
  line-height: 1.5;
}

/* =============================================
   Chatbot Widget
   ============================================= */
.widget-bubble {
  position: fixed;
  bottom: 28px;
  right: 28px;
  z-index: 9000;
}
.widget-btn {
  width: 60px; height: 60px;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 4px 20px rgba(39,52,139,0.4);
  transition: transform var(--transition), box-shadow var(--transition);
  position: relative;
  border: none;
}
.widget-btn:hover {
  transform: scale(1.08) translateY(-2px);
  box-shadow: 0 8px 28px rgba(39,52,139,0.5);
}
.widget-btn svg { color: #fff; width: 26px; height: 26px; }
.widget-online-dot {
  position: absolute;
  top: 2px; left: 2px;
  width: 14px; height: 14px;
  background: #22A06B;
  border-radius: 50%;
  border: 2px solid #fff;
  animation: widget-pulse 2.5s infinite;
}
@keyframes widget-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(34,160,107,0.6); }
  50% { box-shadow: 0 0 0 5px rgba(34,160,107,0); }
}
.widget-panel {
  position: absolute;
  bottom: 72px; right: 0;
  width: 320px;
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  box-shadow: 0 12px 48px rgba(39,52,139,0.22);
  overflow: hidden;
  display: none;
  flex-direction: column;
  border: 1.5px solid var(--border);
}
.widget-panel.open { display: flex; }
.widget-panel-header {
  background: linear-gradient(135deg, var(--primary-dark), var(--primary));
