        <p class="disclaimer">本工具结果仅供参考，各院校 GPA 换算标准不同，建议以院校官方规定或授权认证机构（如 WES）结果为准。</p>
      </div>
    </div>
  </footer>

  <!-- Back to top -->
  <button class="back-top" id="backTop" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="返回顶部">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
  </button>

  <!-- ============ CHATBOT WIDGET ============ -->
  <div class="widget-bubble" id="widgetBubble" role="complementary" aria-label="AI留学助手">
    <div class="widget-panel" id="widgetPanel" role="dialog" aria-modal="true" aria-label="留学顾问助手">
      <div class="widget-panel-header">
        <div class="widget-avatar" aria-hidden="true">📚</div>
        <div>
          <h4>Lina · 留学助手</h4>
          <p>在线 · 通常即时回复</p>
        </div>
        <button class="widget-close" onclick="toggleWidget()" aria-label="关闭对话框">✕</button>
      </div>
      <div class="widget-messages" id="widgetMessages" aria-live="polite" aria-label="对话消息">
        <div class="msg bot">唔知自己 GPA 换算成 4 分制几多？用上面换算器即刻知 📐 有其他留学问题也可以问我～</div>
      </div>
      <div class="widget-quick-replies">
        <button class="qr-btn" onclick="sendQuick('我的GPA够申请澳洲G8吗？')" aria-label="快捷问题：申请G8">申请 G8</button>
        <button class="qr-btn" onclick="sendQuick('WES认证怎么换算？')" aria-label="快捷问题：WES认证">WES 认证</button>
        <button class="qr-btn" onclick="sendQuick('GPA低了怎么办？')" aria-label="快捷问题：GPA低">GPA 低怎么办</button>
      </div>
      <div class="widget-input-row">
        <input class="widget-input" id="widgetInput" type="text" placeholder="输入问题…" aria-label="输入消息" onkeydown="if(event.key==='Enter')sendMsg()">
        <button class="widget-send" onclick="sendMsg()" aria-label="发送">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 2L11 13M22 2L15 22l-4-9-9-4 20-7z"/></svg>
        </button>
      </div>
    </div>
    <button class="widget-btn" onclick="toggleWidget()" aria-label="打开留学顾问助手" aria-expanded="false" id="widgetBtn">
      <div class="widget-online-dot" aria-hidden="true"></div>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-label="聊天气泡">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
    </button>
  </div>

  <!-- ============ COMMON JAVASCRIPT ============ -->
  <script>
    'use strict';

    /* ---- Nav scroll effect ---- */
    const nav = document.getElementById('nav');
    const backTop = document.getElementById('backTop');
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY > 60;
      nav.className = 'nav ' + (scrolled ? 'solid' : 'transparent');
      backTop.classList.toggle('visible', window.scrollY > 400);
    }, { passive: true });

    /* ---- Hamburger ---- */
    const hamburger = document.getElementById('hamburger');
    const mobileMenu = document.getElementById('mobileMenu');
    function closeMobile() {
      mobileMenu.classList.remove('open');
      hamburger.setAttribute('aria-expanded', 'false');
    }
    hamburger.addEventListener('click', () => {
      const open = mobileMenu.classList.toggle('open');
      hamburger.setAttribute('aria-expanded', String(open));
    });

    /* ---- Scroll reveal ---- */
    const revealObs = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObs.unobserve(e.target); } });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    /* ---- Smooth anchor scroll (offset for sticky nav) ---- */
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const href = a.getAttribute('href');
        if (href === '#') return;
        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();
          const top = target.getBoundingClientRect().top + window.scrollY - 80;
          window.scrollTo({ top, behavior: 'smooth' });
          closeMobile();
        }
      });
    });

    /* ---- Chatbot Widget ---- */
    let widgetOpen = false;
    function toggleWidget() {
      widgetOpen = !widgetOpen;
      const panel = document.getElementById('widgetPanel');
      const btn = document.getElementById('widgetBtn');
      panel.classList.toggle('open', widgetOpen);
      btn.setAttribute('aria-expanded', String(widgetOpen));
      if (widgetOpen) document.getElementById('widgetInput').focus();
    }

    const botResponses = {
      'gpa': '你好！GPA 换算可以直接用上方的换算器 📐 输入各科成绩和学分，即时获得 4.0 制和英式等第结果。如需专业留学评估，可以预约 UNILINK 顾问哦～',
      '澳洲': '澳洲 G8 大学研究生一般要求 GPA 2.8–3.5，具体看专业。你的 GPA 是多少？我帮你对照一下。',
      '英国': '英国大学以英式等第为主：First（≥70%）、2:1（60-69%）、2:2（50-59%）。大多数 Russell Group 院校要求 2:1 以上。',
      'wes': 'WES 认证是北美最常见的学历认证方式，一般需要 2–8 周出结果。你目前有在准备材料吗？',
      'default': '这是个好问题！我建议可以预约 UNILINK 留学顾问做详细评估，他们持英国文化协会双认证，专注中国学生留学申请。是否需要我帮你安排？'
    };

    function getBotReply(text) {
      const t = text.toLowerCase();
      if (t.includes('gpa') || t.includes('成绩') || t.includes('换算')) return botResponses['gpa'];
      if (t.includes('澳洲') || t.includes('澳大利亚') || t.includes('g8') || t.includes('墨尔本') || t.includes('悉尼')) return botResponses['澳洲'];
      if (t.includes('英国') || t.includes('英式') || t.includes('first') || t.includes('2:1')) return botResponses['英国'];
      if (t.includes('wes') || t.includes('认证')) return botResponses['wes'];
      return botResponses['default'];
    }

    function appendMsg(text, type) {
      const msgs = document.getElementById('widgetMessages');
      const div = document.createElement('div');
      div.className = 'msg ' + type;
      div.textContent = text;
      msgs.appendChild(div);
      msgs.scrollTop = msgs.scrollHeight;
    }

    function sendMsg() {
      const input = document.getElementById('widgetInput');
      const text = input.value.trim();
      if (!text) return;
      appendMsg(text, 'user');
      input.value = '';
      setTimeout(() => appendMsg(getBotReply(text), 'bot'), 600);
    }

    function sendQuick(text) {
      appendMsg(text, 'user');
      setTimeout(() => appendMsg(getBotReply(text), 'bot'), 600);
    }
  </script>

</body>
</html>
