562|<script is:inline>
'use strict';

/* ── Hero search ── */
function doSearch() {
  const v = document.getElementById('hero-search-input').value.trim();
  if (!v) return;
  document.getElementById('calculators').scrollIntoView({ behavior: 'smooth' });
}
document.getElementById('hero-search-input').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') doSearch();
});
function scrollToId(id) {
  document.querySelector(id).scrollIntoView({ behavior: 'smooth' });
}

/* ── Calc card filter ── */
function filterCalcs(cat, btn) {
  document.querySelectorAll('.calc-tab').forEach(t => {
    t.classList.remove('active');
    t.setAttribute('aria-selected', 'false');
  });
  btn.classList.add('active');
  btn.setAttribute('aria-selected', 'true');

  document.querySelectorAll('.calc-card').forEach(card => {
    const show = cat === 'all' || card.dataset.cat === cat;
    card.style.display = show ? 'block' : 'none';
    card.style.opacity = show ? '1' : '0';
  });
}

/* ── Demo calculator widget ── */
let cwMode = 'annuity';
function setCwTab(mode, btn) {
  cwMode = mode;
  document.querySelectorAll('.cw-tab').forEach(t => {
    t.classList.remove('active');
    t.setAttribute('aria-selected', 'false');
  });
  btn.classList.add('active');
  btn.setAttribute('aria-selected', 'true');
  document.getElementById('cw-result').classList.remove('show');
}

function calcLoan() {
  const P = parseFloat(document.getElementById('cw-principal').value);
  const annualRate = parseFloat(document.getElementById('cw-rate').value);
  const n = parseInt(document.getElementById('cw-months').value);

  if (!P || !annualRate || !n || P <= 0 || annualRate <= 0 || n <= 0) {
    alert('请填写有效的贷款金额、年利率和还款月数。');
    return;
  }

  const r = annualRate / 100 / 12;
  let monthly, totalPay, totalInterest;

  if (cwMode === 'annuity') {
    // 等额本息: M = P × r × (1+r)^n / ((1+r)^n - 1)
    monthly = P * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
    totalPay = monthly * n;
    totalInterest = totalPay - P;
  } else if (cwMode === 'principal') {
    // 等额本金 — show first month
    const principalPerMonth = P / n;
    const firstMonthInterest = P * r;
    monthly = principalPerMonth + firstMonthInterest;
    totalPay = P + P * r * (n + 1) / 2;
    totalInterest = totalPay - P;
  } else {
    // 利息总额 (same as annuity monthly)
    monthly = P * r * Math.pow(1 + r, n) / (Math.pow(1 + r, n) - 1);
    totalPay = monthly * n;
    totalInterest = totalPay - P;
  }

  const fmt = (v) => v.toLocaleString('zh-CN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  const suffix = cwMode === 'principal' ? '（首月）' : '';

  document.getElementById('cw-monthly').textContent = '¥' + fmt(monthly) + suffix;
  document.getElementById('cw-breakdown').innerHTML = `
    <div class="cw-result-row"><span>贷款本金</span><span>¥${fmt(P)}</span></div>
    <div class="cw-result-row"><span>还款总额</span><span>¥${fmt(totalPay)}</span></div>
    <div class="cw-result-row"><span>总利息支出</span><span style="color:var(--c-red)">¥${fmt(totalInterest)}</span></div>
    <div class="cw-result-row"><span>还款月数</span><span>${n} 个月 (${(n/12).toFixed(1)} 年)</span></div>
  `;
  document.getElementById('cw-result').classList.add('show');
}

/* ── FAQ accordion ── */
function toggleFaq(btn) {
  const item = btn.closest('.faq-item');
  const isOpen = item.classList.contains('open');
  // Close all
  document.querySelectorAll('.faq-item.open').forEach(i => {
    i.classList.remove('open');
    i.querySelector('.faq-q').setAttribute('aria-expanded', 'false');
  });
  if (!isOpen) {
    item.classList.add('open');
    btn.setAttribute('aria-expanded', 'true');
  }
}
</script>
