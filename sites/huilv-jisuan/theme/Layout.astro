<script>
// ===== STATIC REFERENCE RATES (示意参考，不代表实际牌价) =====
const REF_RATES_TO_CNY = {
  CNY: 1,
  USD: 7.258,
  GBP: 9.184,
  AUD: 4.547,
  EUR: 7.893,
  HKD: 0.931,
  CAD: 5.312,
  JPY: 0.04726,
  NZD: 4.183,
  SGD: 5.412
};

const CURRENCY_SYMBOLS = {
  CNY: '¥', USD: '$', GBP: '£', AUD: 'A$',
  EUR: '€', HKD: 'HK$', CAD: 'CA$', JPY: '¥',
  NZD: 'NZ$', SGD: 'S$'
};

const CURRENCY_FLAGS = {
  CNY: '🇨🇳', USD: '🇺🇸', GBP: '🇬🇧', AUD: '🇦🇺',
  EUR: '🇪🇺', HKD: '🇭🇰', CAD: '🇨🇦', JPY: '🇯🇵',
  NZD: '🇳🇿', SGD: '🇸🇬'
};

function getRate(from, to) {
  const fromCNY = REF_RATES_TO_CNY[from] || 1;
  const toCNY = REF_RATES_TO_CNY[to] || 1;
  return toCNY / fromCNY;
}

// ===== CALCULATOR =====
function calcConvert() {
  const amountEl = document.getElementById('calc-amount');
  const fromEl = document.getElementById('from-currency');
  const toEl = document.getElementById('to-currency');
  if (!amountEl || !fromEl || !toEl) return;
  const amount = parseFloat(amountEl.value) || 0;
  const from = fromEl.value;
  const to = toEl.value;
  const rate = getRate(from, to);
  const result = amount * rate;

  const resultEl = document.getElementById('result-amount');
  const rateEl = document.getElementById('result-rate');
  const currencyEl = document.getElementById('result-currency');
  const badgeEl = document.getElementById('from-badge');

  if (badgeEl) badgeEl.textContent = from;
  if (currencyEl) currencyEl.textContent = to;

  if (resultEl) {
    // Number roll animation
    const start = parseFloat(resultEl.textContent.replace(/,/g, '')) || 0;
    const end = result;
    const duration = 400;
    const startTime = performance.now();

    function animate(now) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = start + (end - start) * eased;
      resultEl.textContent = current.toLocaleString('zh-CN', {
        minimumFractionDigits: 2, maximumFractionDigits: to === 'JPY' ? 0 : 2
      });
      if (progress < 1) requestAnimationFrame(animate);
    }
    requestAnimationFrame(animate);
  }

  if (rateEl) {
    rateEl.textContent = `参考汇率 1 ${from} ≈ ${rate.toFixed(4)} ${to}（${CURRENCY_FLAGS[from]}→${CURRENCY_FLAGS[to]}）`;
  }

  // Update cost comparison
  buildCostGrid(amount, from, to, rate);
}

// Attach calculator listeners
(function() {
  const amountEl = document.getElementById('calc-amount');
  const fromEl = document.getElementById('from-currency');
  const toEl = document.getElementById('to-currency');
  const swapEl = document.getElementById('swap-btn');
  if (amountEl) amountEl.addEventListener('input', calcConvert);
  if (fromEl) fromEl.addEventListener('change', calcConvert);
  if (toEl) toEl.addEventListener('change', calcConvert);
  if (swapEl) {
    swapEl.addEventListener('click', function() {
      const fEl = document.getElementById('from-currency');
      const tEl = document.getElementById('to-currency');
      if (!fEl || !tEl) return;
      const tmp = fEl.value;
      fEl.value = tEl.value;
      tEl.value = tmp;
      calcConvert();
    });
  }
})();

// ===== RATE TICKER =====
function buildTicker() {
  const tickerEl = document.getElementById('rate-ticker');
  if (!tickerEl) return;
  const pairs = [
    ['USD', 'CNY'], ['AUD', 'CNY'], ['GBP', 'CNY'],
    ['EUR', 'CNY'], ['HKD', 'CNY'], ['CAD', 'CNY'],
    ['JPY', 'CNY'], ['NZD', 'CNY'], ['SGD', 'CNY'],
    ['CNY', 'AUD'], ['CNY', 'USD'], ['CNY', 'GBP']
  ];
  const changes = ['+0.12%','+0.08%','-0.15%','+0.21%','-0.09%','+0.04%',
                   '-0.18%','+0.11%','+0.06%','-0.08%','+0.15%','-0.11%'];

  let html = '';
  const allPairs = [...pairs, ...pairs]; // double for seamless loop
  allPairs.forEach(([a, b], i) => {
    const rate = getRate(a, b);
    const change = changes[i % changes.length];
    const isPos = change.startsWith('+');
    html += `<div class="ticker-item">
      <span class="ticker-pair">${CURRENCY_FLAGS[a]} ${a}/${b}</span>
      <span class="ticker-rate">${rate < 0.1 ? rate.toFixed(5) : rate.toFixed(4)}</span>
      <span class="ticker-change ${isPos ? 'pos' : 'neg'}">${change}</span>
    </div>`;
  });
  tickerEl.innerHTML = html;
}

// ===== COST GRID =====
function buildCostGrid(amount, from, to, rate) {
  const grid = document.getElementById('cost-grid');
  if (!grid) return;
  const converted = amount * rate;
  const symbol = CURRENCY_SYMBOLS[to] || '';

  const channels = [
    {
      name: '国有银行电汇（留学优惠）',
      sub: '工行/建行/中行，凭录取通知书',
      spreadPct: 1.0,
      fixedFee: 150,
      minFee: 50,
      recommended: false,
    },
    {
      name: 'Wise（国际汇款平台）',
      sub: '真实中间汇率 + 固定手续费',
      spreadPct: 0.35,
      fixedFee: 0,
      minFee: 0,
      recommended: true,
    },
    {
      name: '机场/商场找换所',
      sub: '现钞换汇，无需预约',
      spreadPct: 4.0,
      fixedFee: 0,
      minFee: 0,
      recommended: false,
    }
  ];

  grid.innerHTML = channels.map(ch => {
    const spreadLoss = amount * (ch.spreadPct / 100);
    const totalFee = spreadLoss + ch.fixedFee;
    const youGet = converted - (totalFee * rate);
    const recHtml = ch.recommended ? `<span class="cost-badge-rec">推荐</span><br>` : '';
    return `<div class="cost-card ${ch.recommended ? 'recommended' : ''} reveal">
      ${recHtml}
      <div class="cost-channel">${ch.name}</div>
      <div class="cost-channel-sub">${ch.sub}</div>
      <div class="cost-detail-row">
        <span class="cost-detail-label">汇率点差</span>
        <span class="cost-detail-val ${ch.spreadPct <= 0.5 ? 'good' : ch.spreadPct >= 3 ? 'bad' : ''}">${ch.spreadPct}%</span>
      </div>
      <div class="cost-detail-row">
        <span class="cost-detail-label">固定手续费</span>
        <span class="cost-detail-val">${ch.fixedFee > 0 ? '¥' + ch.fixedFee.toFixed(0) : '无'}</span>
      </div>
      <div class="cost-detail-row">
        <span class="cost-detail-label">综合成本估算</span>
        <span class="cost-detail-val ${ch.spreadPct <= 0.5 ? 'good' : ch.spreadPct >= 3 ? 'bad' : ''}">
          ~¥${(totalFee).toLocaleString('zh-CN', {minimumFractionDigits: 0, maximumFractionDigits: 0})}
        </span>
      </div>
      <div class="cost-total">
        <div class="cost-total-label">参考到手金额</div>
        <div class="cost-total-amount">${symbol}${Math.max(0, youGet).toLocaleString('zh-CN', {minimumFractionDigits: 2, maximumFractionDigits: 2})}</div>
      </div>
    </div>`;
  }).join('');

  // Re-observe new cards
  document.querySelectorAll('.cost-card.reveal:not(.visible)').forEach(el => {
    if (typeof observer !== 'undefined') observer.observe(el);
  });
}

// ===== FAQ =====
const faqs = [
  { q: '这个汇率换算器的数据准确吗？', a: '本工具提供的是参考中间汇率示意，数据仅供估算参考，不代表任何银行或金融机构的实际报价。实际换汇时，请务必以银行柜台、网银或相关换汇平台的实时牌价为准。' },
  { q: '人民币每年购汇有额度限制吗？', a: '根据中国外汇管理局规定，境内个人每自然年内购汇累计不超过等值 5 万美元（约合 36 万元人民币）。超过此额度需提供用途证明材料，如录取通知书、留学费用证明等。建议出行前提前与开户行确认相关手续。' },
  { q: 'Wise 在中国大陆能用吗？', a: 'Wise 目前支持从中国大陆汇款，但需要通过其合规合作渠道完成，具体可用性和操作方式可能因时间而异。建议访问 Wise 官网查阅最新的中国大陆用户操作指引，并完成实名认证流程。' },
  { q: '银行电汇和买汇的区别是什么？', a: '银行电汇（Telegraphic Transfer）是将人民币通过 SWIFT 网络汇出到境外账户；买汇则是在国内将人民币兑换成外币现钞。两者适用的汇率不同（电汇价通常优于现钞价），手续费结构也不同，大额留学汇款通常更适合走电汇渠道。' },
  { q: '换汇点差是如何产生的？', a: '金融机构以中间价为基准，以低于中间价买入外币（买入价），以高于中间价卖出外币（卖出价），两者之差即为点差（spread），是换汇机构的主要盈利来源之一。点差越小，换汇成本越低。' },
  { q: '留学换汇有什么优惠汇率可以申请？', a: '部分国有银行（如工商银行、中国银行、建设银行）针对出国留学汇款提供专属优惠汇率，需提供录取通知书、护照、学费缴费通知等材料。大额汇款可提前与银行国际汇款部门预约，询问当日优惠汇率及手续费减免情况。' },
];

(function initFAQ() {
  const faqList = document.getElementById('faq-list');
  if (!faqList) return;
  faqList.innerHTML = faqs.map((faq, i) => `
  <div class="faq-item" data-index="${i}" role="listitem">
    <button class="faq-q" aria-expanded="false" aria-controls="faq-a-${i}" id="faq-q-${i}">
      ${faq.q}
      <span class="faq-q-icon" aria-hidden="true">+</span>
    </button>
    <div class="faq-a" id="faq-a-${i}" role="region" aria-labelledby="faq-q-${i}">
      <div class="faq-a-inner">${faq.a}</div>
    </div>
  </div>
`).join('');

  faqList.addEventListener('click', e => {
    const btn = e.target.closest('.faq-q');
    if (!btn) return;
    const item = btn.closest('.faq-item');
    const isOpen = item.classList.contains('open');
    // Close all
    document.querySelectorAll('.faq-item.open').forEach(el => {
      el.classList.remove('open');
      el.querySelector('.faq-q').setAttribute('aria-expanded', 'false');
    });
    if (!isOpen) {
      item.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    }
  });
})();

// ===== NAV SCROLL =====
(function initNav() {
  const nav = document.getElementById('main-nav');
  if (!nav) return;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      nav.classList.add('scrolled');
    } else {
      nav.classList.remove('scrolled');
    }
  }, { passive: true });
})();

// ===== HAMBURGER =====
(function initHamburger() {
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');
  if (!hamburger || !mobileMenu) return;
  hamburger.addEventListener('click', () => {
    const isOpen = mobileMenu.classList.contains('open');
    mobileMenu.classList.toggle('open');
    hamburger.classList.toggle('active');
    hamburger.setAttribute('aria-expanded', (!isOpen).toString());
    document.body.style.overflow = isOpen ? '' : 'hidden';
  });
})();

function closeMobileMenu() {
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburger = document.getElementById('hamburger');
  if (mobileMenu) mobileMenu.classList.remove('open');
  if (hamburger) {
    hamburger.classList.remove('active');
    hamburger.setAttribute('aria-expanded', 'false');
  }
  document.body.style.overflow = '';
}

// ===== SCROLL REVEAL =====
const observer = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      observer.unobserve(entry.target);
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

// ===== SPREAD BARS ANIMATION =====
const barObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      const widths = [35, 60, 80, 100];
      widths.forEach((w, i) => {
        const bar = document.getElementById(`bar-${i}`);
        if (bar) {
          setTimeout(() => { bar.style.width = w + '%'; }, i * 120);
        }
      });
      barObserver.disconnect();
    }
  });
}, { threshold: 0.3 });

// ===== BACK TO TOP =====
(function initBackTop() {
  const backTop = document.getElementById('back-top');
  if (!backTop) return;
  window.addEventListener('scroll', () => {
    if (window.scrollY > 400) backTop.classList.add('visible');
    else backTop.classList.remove('visible');
  }, { passive: true });
  backTop.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
})();

// ===== WIDGET =====
(function initWidget() {
  const widgetBtn = document.getElementById('widget-btn');
  const widgetPanel = document.getElementById('widget-panel');
  const widgetClose = document.getElementById('widget-close');
  const widgetInput = document.getElementById('widget-input');
  const widgetMessages = document.getElementById('widget-messages');
  const widgetSendBtn = document.getElementById('widget-send-btn');
  if (!widgetBtn || !widgetPanel) return;

  function toggleWidget() {
    const isOpen = widgetPanel.classList.contains('open');
    widgetPanel.classList.toggle('open');
    widgetBtn.setAttribute('aria-expanded', (!isOpen).toString());
    if (!isOpen && widgetInput) { setTimeout(() => widgetInput.focus(), 200); }
  }

  widgetBtn.addEventListener('click', toggleWidget);
  widgetBtn.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggleWidget(); } });
  if (widgetClose) widgetClose.addEventListener('click', () => { widgetPanel.classList.remove('open'); widgetBtn.setAttribute('aria-expanded', 'false'); });

  const WIDGET_REPLIES = {
    '人民币': '人民币换外币，建议先在上方试算器输入金额，查看不同渠道的参考到手金额对比。一般而言，Wise 等在线平台点差较低，适合中小额跨境汇款。',
    '澳元': '人民币换澳元是留学最常见需求！参考汇率约 1 CNY ≈ 0.22 AUD，渠道对比建议看页面上方的费用对比卡。留学大额汇款也可咨询工行、建行的留学专项汇款服务。',
    '英镑': '人民币换英镑，参考汇率约 1 CNY ≈ 0.109 GBP。英国留学换汇可使用 Wise 或 HSBC 等英国本地有账户更方便日常消费。',
    'wise': 'Wise 以中间汇率计费，手续费透明，适合中小额换汇。需完成实名认证（护照+手机号）。请在 Wise 官网查询最新支持的汇款通道。',
    '银行': '银行电汇适合大额留学汇款，凭录取通知书可申请优惠汇率。工行、建行、中行等国有大行均有留学汇款服务，建议提前预约并询问当日优惠汇率。',
    '省钱': '省换汇成本核心三招：① 选点差低的渠道（Wise等）② 避开节假日和重大数据日换汇 ③ 大额汇款凭证申请留学优惠汇率。可用上方试算器比较各渠道实际到手金额。',
    '攻略': '换汇省钱攻略：① 比渠道点差，不只看手续费 ② 工作日银行交易时段报价更优 ③ 大额分批换，摊平汇率风险 ④ 银行留学优惠汇率记得提前申请。详细攻略见页面"留学换汇攻略"板块。',
  };

  const DEFAULT_REPLY = '这个问题我需要再查查！你可以在上方试算器直接输入金额换算，或者查看页面"渠道费用对比"和"换汇攻略"板块。如有复杂换汇规划需求，建议直接咨询开户银行。';

  function addMessage(text, type) {
    if (!widgetMessages) return;
    const msg = document.createElement('div');
    msg.className = `widget-msg ${type}`;
    msg.innerHTML = `<div class="widget-bubble">${text}</div>`;
    widgetMessages.appendChild(msg);
    widgetMessages.scrollTop = widgetMessages.scrollHeight;
  }

  window.widgetQuick = function(text) {
    addMessage(text, 'user');
    setTimeout(() => {
      const lower = text.toLowerCase();
      const reply = Object.entries(WIDGET_REPLIES).find(([k]) => lower.includes(k.toLowerCase()));
      addMessage(reply ? reply[1] : DEFAULT_REPLY, 'bot');
    }, 600);
  };

  function sendWidgetMsg() {
    if (!widgetInput) return;
    const text = widgetInput.value.trim();
    if (!text) return;
    addMessage(text, 'user');
    widgetInput.value = '';
    setTimeout(() => {
      const lower = text.toLowerCase();
      const reply = Object.entries(WIDGET_REPLIES).find(([k]) => lower.includes(k.toLowerCase()));
      addMessage(reply ? reply[1] : DEFAULT_REPLY, 'bot');
    }, 700);
  }

  if (widgetSendBtn) widgetSendBtn.addEventListener('click', sendWidgetMsg);
  if (widgetInput) widgetInput.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); sendWidgetMsg(); } });
})();

// ===== INIT =====
document.addEventListener('DOMContentLoaded', () => {
  buildTicker();
  calcConvert();

  // Scroll reveal
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // Spread bar observer
  const barWrap = document.querySelector('.spread-bar-wrap');
  if (barWrap) barObserver.observe(barWrap);

  // Smooth anchor scroll
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const target = document.querySelector(a.getAttribute('href'));
      if (target) {
        e.preventDefault();
        const offset = 80;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });
});
</script>
</body>
</html>
