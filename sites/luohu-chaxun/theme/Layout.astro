---
// 海归落户分数查询 · Bespoke Layout
import { siteConfig } from '../../../src/lib/site';

const { title, description, ogImage } = Astro.props;
const brand = siteConfig.brand || '海归落户分数查询';
const pageTitle = title || brand;
const pageDesc = description || '海归学历落户积分计算工具';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
{ogImage && <meta property="og:image" content={ogImage} />}
<style is:global>
/* =============================================
       CSS VARIABLES — TOOL TERMINAL THEME
       Primary: City Night Blue  #1A2E4A
       Accent:  Calculation Green #19C37D
       ============================================= */
    :root {
      --primary:        #1A2E4A;
      --primary-dark:   #111E30;
      --primary-light:  #243D5E;
      --accent:         #19C37D;
      --accent-dark:    #13A368;
      --accent-light:   #3DD49A;
      --accent-glow:    rgba(25,195,125,0.18);
      --neutral-50:     #F7F9FC;
      --neutral-100:    #EEF2F7;
      --neutral-200:    #D8E2EE;
      --neutral-300:    #B0C2D8;
      --neutral-400:    #7A94B0;
      --neutral-600:    #3D5A78;
      --neutral-700:    #253D56;
      --neutral-800:    #162233;
      --neutral-900:    #0E1820;
      --text-primary:   #0E1E2E;
      --text-secondary: #3D5A78;
      --text-muted:     #7A94B0;
      --bg-base:        #F7F9FC;
      --bg-section:     #EEF2F7;
      --radius-sm:      6px;
      --radius-md:      12px;
      --radius-lg:      20px;
      --radius-xl:      28px;
      --shadow-sm:      0 2px 8px rgba(26,46,74,0.08);
      --shadow-md:      0 6px 24px rgba(26,46,74,0.12);
      --shadow-lg:      0 16px 48px rgba(26,46,74,0.18);
      --font-stack:     -apple-system, BlinkMacSystemFont, "PingFang SC",
                        "Microsoft YaHei", "Noto Sans SC",
                        "Source Han Sans SC", "Helvetica Neue", Arial, sans-serif;
      --transition:     150ms cubic-bezier(.4,0,.2,1);
      --transition-md:  250ms cubic-bezier(.4,0,.2,1);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-stack);
      color: var(--text-primary);
      background: var(--bg-base);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: .01ms !important; transition-duration: .01ms !important; }
    }

    /* =============================================
       UTILITY
       ============================================= */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .container--narrow { max-width: 760px; margin: 0 auto; padding: 0 24px; }

    .section-label {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 11px; font-weight: 700; letter-spacing: .12em;
      text-transform: uppercase; color: var(--accent);
      background: var(--accent-glow); padding: 4px 12px;
      border-radius: 100px; margin-bottom: 16px;
    }
    .section-label::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent); flex-shrink: 0;
    }

    .section-title {
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 700; color: var(--text-primary);
      line-height: 1.3; margin-bottom: 12px;
    }
    .section-sub {
      font-size: 1rem; color: var(--text-secondary); max-width: 540px;
    }
    .section-header { margin-bottom: 48px; }

    /* SCROLL REVEAL */
    .reveal {
      opacity: 0; transform: translateY(28px);
      transition: opacity .55s ease, transform .55s ease;
    }
    .reveal.visible { opacity: 1; transform: none; }

    /* =============================================
       NAVIGATION
       ============================================= */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
      padding: 20px 0;
      background: transparent;
      transition: background var(--transition-md), padding var(--transition-md),
                  box-shadow var(--transition-md);
    }
    .nav.scrolled {
      background: rgba(17,30,48,.96);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      padding: 12px 0;
      box-shadow: 0 2px 20px rgba(0,0,0,.3);
    }
    .nav__inner {
      display: flex; align-items: center; justify-content: space-between;
      gap: 24px;
    }
    .nav__brand {
      display: flex; align-items: center; gap: 10px;
      text-decoration: none; flex-shrink: 0;
    }
    .nav__logo {
      width: 36px; height: 36px; border-radius: 10px;
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; font-weight: 900; color: #fff;
      box-shadow: 0 0 12px var(--accent-glow);
    }
    .nav__name { font-size: .95rem; font-weight: 700; color: #fff; }
    .nav__name span { color: var(--accent); }
    .nav__links {
      display: flex; align-items: center; gap: 8px;
      list-style: none;
    }
    .nav__links a {
      display: block; padding: 6px 14px; border-radius: var(--radius-sm);
      font-size: .9rem; font-weight: 500; color: rgba(255,255,255,.82);
      text-decoration: none;
      transition: color var(--transition), background var(--transition);
    }
    .nav__links a:hover { color: #fff; background: rgba(255,255,255,.1); }
    .nav__links a.active { color: var(--accent); }
    .nav__cta {
      display: flex; align-items: center; gap: 8px;
    }
    .btn-cta-nav {
      padding: 8px 20px; border-radius: var(--radius-sm);
      background: var(--accent); color: #fff;
      font-size: .875rem; font-weight: 700;
      text-decoration: none; border: none; cursor: pointer;
      transition: background var(--transition), transform var(--transition),
                  box-shadow var(--transition);
    }
    .btn-cta-nav:hover {
      background: var(--accent-dark); transform: translateY(-1px);
      box-shadow: 0 4px 16px rgba(25,195,125,.4);
    }
    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      background: none; border: none; cursor: pointer; padding: 6px;
    }
    .hamburger span {
      display: block; width: 22px; height: 2px;
      background: #fff; border-radius: 2px;
      transition: transform var(--transition-md), opacity var(--transition-md);
    }
    .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .hamburger.open span:nth-child(2) { opacity: 0; }
    .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

    /* Mobile nav */
    .nav__mobile {
      display: none; flex-direction: column; gap: 4px;
      position: absolute; top: 100%; left: 0; right: 0;
      background: rgba(17,30,48,.98);
      backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
      padding: 16px 24px 20px;
      border-top: 1px solid rgba(255,255,255,.08);
    }
    .nav__mobile.open { display: flex; }
    .nav__mobile a {
      display: block; padding: 10px 12px; border-radius: var(--radius-sm);
      color: rgba(255,255,255,.85); text-decoration: none;
      font-size: .95rem; font-weight: 500;
      transition: background var(--transition), color var(--transition);
    }
    .nav__mobile a:hover { background: rgba(255,255,255,.08); color: #fff; }
    .nav__mobile .btn-cta-nav { margin-top: 8px; text-align: center; padding: 12px; }

    /* =============================================
       HERO
       ============================================= */
    .hero {
      position: relative; min-height: 100vh;
      display: flex; flex-direction: column; align-items: center;
      justify-content: flex-start; padding-top: 120px;
      overflow: hidden;
    }
    .hero__bg {
      position: absolute; inset: 0; z-index: 0;
      background-image: url('https://images.pexels.com/photos/37011820/pexels-photo-37011820.jpeg?auto=compress&cs=tinysrgb&w=1920');
      background-size: cover; background-position: center top;
      transform: scale(1.04);
      transition: transform 8s ease-out;
    }
    .hero__bg.loaded { transform: scale(1); }
    .hero__overlay {
      position: absolute; inset: 0; z-index: 1;
      background: linear-gradient(
        180deg,
        rgba(14,24,40,.65) 0%,
        rgba(17,30,48,.55) 40%,
        rgba(14,24,40,.82) 100%
      );
    }
    .hero__grid-lines {
      position: absolute; inset: 0; z-index: 2; pointer-events: none;
      background-image:
        linear-gradient(rgba(25,195,125,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(25,195,125,.04) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .hero__content {
      position: relative; z-index: 3;
      text-align: center; max-width: 720px;
      padding: 0 24px;
    }
    .hero__badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(25,195,125,.15);
      border: 1px solid rgba(25,195,125,.3);
      border-radius: 100px; padding: 6px 16px;
      font-size: .8rem; font-weight: 600; color: var(--accent-light);
      letter-spacing: .06em; margin-bottom: 24px;
      backdrop-filter: blur(8px);
    }
    .hero__badge-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { box-shadow: 0 0 0 0 rgba(25,195,125,.5); }
      50% { box-shadow: 0 0 0 6px rgba(25,195,125,0); }
    }
    .hero__title {
      font-size: clamp(2rem, 5.5vw, 3.4rem);
      font-weight: 900; color: #fff; line-height: 1.18;
      letter-spacing: -.02em; margin-bottom: 18px;
    }
    .hero__title em {
      font-style: normal; color: var(--accent);
      text-shadow: 0 0 24px rgba(25,195,125,.4);
    }
    .hero__sub {
      font-size: clamp(.95rem, 2vw, 1.15rem);
      color: rgba(255,255,255,.78);
      margin-bottom: 36px; line-height: 1.6;
    }
    .hero__actions {
      display: flex; align-items: center; justify-content: center;
      gap: 16px; flex-wrap: wrap; margin-bottom: 52px;
    }
    .btn-primary {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 14px 32px; border-radius: var(--radius-md);
      background: var(--accent); color: #fff;
      font-size: 1rem; font-weight: 700;
      text-decoration: none; border: none; cursor: pointer;
      transition: background var(--transition), transform var(--transition),
                  box-shadow var(--transition);
      box-shadow: 0 4px 24px rgba(25,195,125,.35);
    }
    .btn-primary:hover {
      background: var(--accent-dark); transform: translateY(-2px);
      box-shadow: 0 8px 32px rgba(25,195,125,.5);
    }
    .btn-secondary {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 14px 28px; border-radius: var(--radius-md);
      background: rgba(255,255,255,.1);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255,255,255,.22);
      color: #fff; font-size: 1rem; font-weight: 600;
      text-decoration: none; cursor: pointer;
      transition: background var(--transition), transform var(--transition);
    }
    .btn-secondary:hover {
      background: rgba(255,255,255,.18); transform: translateY(-2px);
    }
    .hero__stats {
      display: flex; align-items: center; justify-content: center; gap: 36px;
      flex-wrap: wrap;
    }
    .hero__stat { text-align: center; }
    .hero__stat-num {
      font-size: 1.6rem; font-weight: 900; color: #fff;
      line-height: 1; margin-bottom: 4px;
    }
    .hero__stat-num span { color: var(--accent); }
    .hero__stat-label { font-size: .78rem; color: rgba(255,255,255,.55); letter-spacing: .04em; }
    .hero__divider { width: 1px; height: 36px; background: rgba(255,255,255,.18); }

    /* =============================================
       CALCULATOR SECTION
       ============================================= */
    .calc-section {
      background: var(--bg-base); padding: 0 0 80px;
      position: relative; z-index: 10;
    }
    .calc-card {
      background: #fff; border-radius: var(--radius-xl);
      box-shadow: 0 24px 80px rgba(26,46,74,.16);
      border: 1px solid var(--neutral-200);
      overflow: hidden;
      margin: -64px auto 0; max-width: 980px;
    }
    .calc-header {
      background: var(--primary);
      padding: 28px 36px; display: flex; align-items: center; gap: 16px;
    }
    .calc-header-icon {
      width: 44px; height: 44px; border-radius: var(--radius-sm);
      background: rgba(25,195,125,.2);
      border: 1px solid rgba(25,195,125,.4);
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    .calc-header-text h2 {
      font-size: 1.2rem; font-weight: 800; color: #fff; margin-bottom: 2px;
    }
    .calc-header-text p { font-size: .82rem; color: rgba(255,255,255,.6); }
    .calc-header-badge {
      margin-left: auto; background: var(--accent-glow);
      border: 1px solid rgba(25,195,125,.3); border-radius: 100px;
      padding: 4px 12px; font-size: .75rem; font-weight: 700;
      color: var(--accent-light); display: flex; align-items: center; gap: 6px;
    }
    .calc-header-badge::before {
      content: ''; width: 6px; height: 6px; border-radius: 50%;
      background: var(--accent); animation: pulse-dot 2s ease-in-out infinite;
    }

    .calc-body { padding: 36px; }
    .calc-city-tabs {
      display: flex; gap: 8px; margin-bottom: 32px; flex-wrap: wrap;
    }
    .city-tab {
      padding: 8px 20px; border-radius: 100px;
      border: 1.5px solid var(--neutral-200);
      background: #fff; color: var(--text-secondary);
      font-size: .875rem; font-weight: 600; cursor: pointer;
      transition: all var(--transition);
    }
    .city-tab:hover { border-color: var(--accent); color: var(--accent); }
    .city-tab.active {
      background: var(--accent); border-color: var(--accent);
      color: #fff;
      box-shadow: 0 4px 16px rgba(25,195,125,.3);
    }

    .calc-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .calc-field { display: flex; flex-direction: column; gap: 8px; }
    .calc-field label {
      font-size: .82rem; font-weight: 600; color: var(--text-secondary);
      letter-spacing: .03em;
    }
    .calc-field label span { color: var(--accent); margin-left: 2px; }
    .calc-select, .calc-input {
      width: 100%; padding: 12px 16px; border-radius: var(--radius-md);
      border: 1.5px solid var(--neutral-200);
      background: var(--neutral-50);
      color: var(--text-primary);
      font-family: var(--font-stack); font-size: .925rem;
      transition: border-color var(--transition), box-shadow var(--transition);
      appearance: none; -webkit-appearance: none;
      cursor: pointer;
    }
    .calc-select:focus, .calc-input:focus {
      outline: none; border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(25,195,125,.12);
      background: #fff;
    }
    .calc-select-wrap { position: relative; }
    .calc-select-wrap::after {
      content: '▾'; position: absolute; right: 14px; top: 50%;
      transform: translateY(-50%); color: var(--neutral-400);
      pointer-events: none; font-size: .8rem;
    }
    .calc-full { grid-column: 1 / -1; }

    .calc-run-btn {
      width: 100%; margin-top: 24px;
      padding: 16px; border-radius: var(--radius-md);
      background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
      color: #fff; font-size: 1rem; font-weight: 800;
      border: none; cursor: pointer;
      display: flex; align-items: center; justify-content: center; gap: 10px;
      transition: transform var(--transition), box-shadow var(--transition);
      box-shadow: 0 6px 24px rgba(25,195,125,.35);
      letter-spacing: .02em;
    }
    .calc-run-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 32px rgba(25,195,125,.5);
    }
    .calc-run-btn:active { transform: translateY(0); }
    .calc-run-btn .btn-icon { font-size: 1.1rem; }

    /* RESULT PANEL */
    .calc-result {
      display: none; margin-top: 28px;
      border-radius: var(--radius-lg);
      overflow: hidden;
      border: 1.5px solid rgba(25,195,125,.25);
    }
    .calc-result.visible { display: block; animation: slide-in .3s ease; }
    @keyframes slide-in { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }

    .result-header {
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
      padding: 20px 24px; display: flex; align-items: center; gap: 16px;
    }
    .result-score-ring {
      position: relative; width: 72px; height: 72px; flex-shrink: 0;
    }
    .result-score-ring svg { width: 72px; height: 72px; transform: rotate(-90deg); }
    .result-score-ring circle { fill: none; stroke-width: 5; stroke-linecap: round; }
    .ring-bg { stroke: rgba(255,255,255,.1); }
    .ring-fg { stroke: var(--accent); stroke-dasharray: 180; stroke-dashoffset: 60;
               filter: drop-shadow(0 0 4px var(--accent)); }
    .ring-label {
      position: absolute; inset: 0;
      display: flex; align-items: center; justify-content: center;
      flex-direction: column;
    }
    .ring-num { font-size: 1.3rem; font-weight: 900; color: #fff; line-height: 1; }
    .ring-unit { font-size: .62rem; color: rgba(255,255,255,.5); }
    .result-meta h3 { font-size: 1.1rem; font-weight: 800; color: #fff; margin-bottom: 4px; }
    .result-meta p { font-size: .82rem; color: rgba(255,255,255,.65); }
    .result-verdict {
      display: inline-block; margin-top: 6px;
      padding: 2px 10px; border-radius: 100px; font-size: .75rem; font-weight: 700;
    }
    .verdict-close { background: rgba(25,195,125,.2); color: var(--accent-light); }
    .verdict-need { background: rgba(255,165,0,.15); color: #FFA500; }

    .result-breakdown {
      background: var(--neutral-50); padding: 20px 24px;
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
    }
    .breakdown-item {
      background: #fff; border-radius: var(--radius-sm);
      padding: 12px 14px; border: 1px solid var(--neutral-200);
    }
    .breakdown-item .bi-label {
      font-size: .72rem; color: var(--text-muted); font-weight: 600;
      letter-spacing: .04em; margin-bottom: 4px;
    }
    .breakdown-item .bi-score {
      font-size: 1.25rem; font-weight: 800; color: var(--primary);
    }
    .breakdown-item .bi-score span { font-size: .75rem; font-weight: 400; color: var(--text-muted); }
    .result-disclaimer {
      padding: 12px 24px;
      background: var(--neutral-100); border-top: 1px solid var(--neutral-200);
      font-size: .75rem; color: var(--text-muted);
      display: flex; align-items: flex-start; gap: 6px;
    }
    .result-disclaimer::before { content: '⚠'; font-size: .75rem; flex-shrink: 0; margin-top: 1px; }

    /* LOADING SKELETON */
    .calc-skeleton {
      display: none; margin-top: 28px;
    }
    .calc-skeleton.visible { display: block; }
    .skel-row {
      height: 20px; border-radius: var(--radius-sm);
      background: linear-gradient(90deg, var(--neutral-100) 25%, var(--neutral-200) 50%, var(--neutral-100) 75%);
      background-size: 200% 100%;
      animation: shimmer 1.4s ease infinite;
      margin-bottom: 10px;
    }
    .skel-row:last-child { width: 60%; }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* =============================================
       CITY POLICY CARDS
       ============================================= */
    .city-section { padding: 80px 0; background: #fff; }
    .city-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }
    .city-card {
      border-radius: var(--radius-lg); overflow: hidden;
      border: 1.5px solid var(--neutral-200);
      transition: transform var(--transition-md), box-shadow var(--transition-md),
                  border-color var(--transition-md);
      cursor: pointer; background: #fff;
    }
    .city-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-lg);
      border-color: var(--accent);
    }
    .city-card__top {
      padding: 24px 22px 18px;
      background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    }
    .city-card--gz .city-card__top { background: linear-gradient(135deg, #1B3A5C 0%, #0D2438 100%); }
    .city-card--sz .city-card__top { background: linear-gradient(135deg, #0D3B2E 0%, #061F18 100%); }
    .city-card--bj .city-card__top { background: linear-gradient(135deg, #2A1A3E 0%, #160F24 100%); }
    .city-card__emoji { font-size: 2rem; margin-bottom: 10px; display: block; }
    .city-card__name { font-size: 1.3rem; font-weight: 800; color: #fff; margin-bottom: 4px; }
    .city-card__route {
      font-size: .78rem; color: rgba(255,255,255,.55);
      letter-spacing: .04em;
    }
    .city-card__body { padding: 20px 22px; }
    .city-card__threshold {
      display: flex; align-items: baseline; gap: 4px; margin-bottom: 14px;
    }
    .threshold-num { font-size: 2rem; font-weight: 900; color: var(--accent); line-height: 1; }
    .threshold-unit { font-size: .8rem; color: var(--text-muted); font-weight: 600; }
    .city-card__label { font-size: .75rem; color: var(--text-muted); margin-bottom: 16px; }
    .city-tag-list { display: flex; flex-wrap: wrap; gap: 6px; }
    .city-tag {
      padding: 3px 10px; border-radius: 100px;
      background: var(--neutral-100); color: var(--text-secondary);
      font-size: .73rem; font-weight: 600;
      border: 1px solid var(--neutral-200);
    }
    .city-tag.highlight {
      background: var(--accent-glow); color: var(--accent-dark);
      border-color: rgba(25,195,125,.25);
    }

    /* =============================================
       HAIGUI CHANNEL SECTION
       ============================================= */
    .channel-section { padding: 80px 0; background: var(--bg-section); }
    .channel-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 36px;
      align-items: center;
    }
    .channel-visual {
