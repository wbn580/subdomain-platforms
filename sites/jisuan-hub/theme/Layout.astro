---
import { siteConfig } from '../../../src/lib/site';

const { title, description } = Astro.props;
const brand = siteConfig.brand || 'jisuan.help';
const pageTitle = title || brand;
const pageDesc = description || 'jisuan.help — 专为留学生、新移民打造的计算器工具平台。留学费用、GPA换算、汇率换汇、贷款月供、落户积分，全部免费在线计算，无需注册。';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
<link rel="preconnect" href="https://images.pexels.com" />
<style is:global>
/* ════════════════════════════════════════════
   DESIGN TOKENS — jisuan.help
   Primary: 深空灰 #1B1F24  Accent: 电光蓝 #3B82F6
   ════════════════════════════════════════════ */
:root {
  --c-bg:         #0F1317;
  --c-surface:    #1B1F24;
  --c-surface-2:  #22272E;
  --c-surface-3:  #2C3139;
  --c-border:     rgba(255,255,255,.08);
  --c-text:       #E8ECF0;
  --c-text-2:     #9BA6B2;
  --c-text-3:     #6B7684;
  --c-accent:     #3B82F6;
  --c-accent-h:   #2563EB;
  --c-accent-glow:rgba(59,130,246,.18);
  --c-green:      #22C55E;
  --c-amber:      #F59E0B;
  --c-red:        #EF4444;

  --font-sans: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei",
               "Noto Sans SC", "Source Han Sans SC", "Helvetica Neue", Arial, sans-serif;

  --r-sm:  6px;
  --r-md:  12px;
  --r-lg:  18px;
  --r-xl:  24px;

  --shadow-sm:  0 1px 3px rgba(0,0,0,.35);
  --shadow-md:  0 4px 16px rgba(0,0,0,.45);
  --shadow-lg:  0 8px 32px rgba(0,0,0,.55);
  --shadow-blue:0 0 0 3px rgba(59,130,246,.30);

  --nav-h: 64px;
  --max-w: 1200px;
  --section-py: 80px;
}

/* ─── Reset ─── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  font-family: var(--font-sans);
  background: var(--c-bg);
  color: var(--c-text);
  line-height: 1.6;
  overflow-x: hidden;
}
a { color: inherit; text-decoration: none; }
img { display: block; max-width: 100%; }
button { font-family: var(--font-sans); cursor: pointer; border: none; background: none; }
ul { list-style: none; }

/* ─── Utility ─── */
.container { max-width: var(--max-w); margin: 0 auto; padding: 0 24px; }
.section { padding: var(--section-py) 0; }
.tag-chip {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 4px 10px; border-radius: 20px;
  font-size: 12px; font-weight: 600; letter-spacing: .3px;
  background: var(--c-accent-glow); color: var(--c-accent);
  border: 1px solid rgba(59,130,246,.25);
}
.section-eyebrow {
  display: inline-flex; align-items: center; gap: 6px;
  font-size: 12px; font-weight: 700; letter-spacing: 1.5px;
  text-transform: uppercase; color: var(--c-accent); margin-bottom: 12px;
}
.section-eyebrow::before {
  content: ''; width: 20px; height: 2px;
  background: var(--c-accent); border-radius: 2px;
}
.section-title {
  font-size: clamp(1.6rem, 3vw, 2.2rem);
  font-weight: 700; line-height: 1.25;
  color: var(--c-text); margin-bottom: 16px;
}
.section-sub {
  font-size: 1rem; color: var(--c-text-2); max-width: 560px;
}

/* Scroll-reveal */
.sr { opacity: 0; transform: translateY(28px); transition: opacity .55s ease, transform .55s ease; }
.sr.visible { opacity: 1; transform: translateY(0); }
.sr-delay-1 { transition-delay: .08s; }
.sr-delay-2 { transition-delay: .16s; }
.sr-delay-3 { transition-delay: .24s; }
.sr-delay-4 { transition-delay: .32s; }
.sr-delay-5 { transition-delay: .40s; }
.sr-delay-6 { transition-delay: .48s; }
@media (prefers-reduced-motion: reduce) {
  .sr { opacity: 1; transform: none; transition: none; }
}

/* ════════════════════════════════════════════
   NAVIGATION
   ════════════════════════════════════════════ */
#nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 900;
  height: var(--nav-h);
  background: transparent;
  transition: background .3s ease, backdrop-filter .3s ease, border-color .3s ease;
  border-bottom: 1px solid transparent;
}
#nav.scrolled {
  background: rgba(15,19,23,.92);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom-color: var(--c-border);
}
.nav-inner {
  height: var(--nav-h);
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  display: flex; align-items: center; gap: 10px;
}
.nav-logo-icon {
  width: 36px; height: 36px;
  background: var(--c-accent);
  border-radius: var(--r-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; font-weight: 900; color: #fff;
  letter-spacing: -1px;
  box-shadow: 0 0 16px rgba(59,130,246,.4);
}
.nav-logo-text {
  font-size: 1rem; font-weight: 700; color: var(--c-text);
  display: flex; flex-direction: column; line-height: 1.1;
}
.nav-logo-text span { font-size: 10px; font-weight: 400; color: var(--c-text-3); }
.nav-links {
  display: flex; align-items: center; gap: 28px;
  font-size: 14px; color: var(--c-text-2);
}
.nav-links a { transition: color .2s; }
.nav-links a:hover { color: var(--c-text); }
.nav-links a.active { color: var(--c-accent); }
.nav-cta {
  padding: 8px 18px; border-radius: var(--r-sm);
  background: var(--c-accent); color: #fff;
  font-size: 13px; font-weight: 600;
  transition: background .2s, transform .15s;
}
.nav-cta:hover { background: var(--c-accent-h); transform: translateY(-1px); }

/* Hamburger */
.nav-burger {
  display: none; flex-direction: column; gap: 5px;
  width: 24px; cursor: pointer;
}
.nav-burger span {
  width: 100%; height: 2px; border-radius: 2px;
  background: var(--c-text-2);
  transition: transform .3s ease, opacity .3s ease;
}
#nav.menu-open .nav-burger span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
#nav.menu-open .nav-burger span:nth-child(2) { opacity: 0; }
#nav.menu-open .nav-burger span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile menu */
.nav-mobile {
  display: none;
  position: fixed; top: var(--nav-h); left: 0; right: 0;
  background: rgba(15,19,23,.97);
  backdrop-filter: blur(16px);
  padding: 20px 24px 28px;
  border-bottom: 1px solid var(--c-border);
  flex-direction: column; gap: 16px;
  z-index: 899;
}
.nav-mobile.open { display: flex; }
.nav-mobile a {
  font-size: 15px; font-weight: 500; color: var(--c-text-2);
  padding: 10px 0;
  border-bottom: 1px solid var(--c-border);
  transition: color .2s;
}
.nav-mobile a:hover { color: var(--c-accent); }
.nav-mobile a:last-child { border-bottom: none; }

/* ════════════════════════════════════════════
   HERO
   ════════════════════════════════════════════ */
#hero {
  position: relative;
  min-height: 100vh;
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  overflow: hidden;
  text-align: center;
  padding-top: var(--nav-h);
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
}
.hero-bg-img {
  width: 100%; height: 100%; object-fit: cover;
  filter: brightness(.35) saturate(1.1);
}
/* Layered gradients for text legibility */
.hero-bg::after {
  content: '';
  position: absolute; inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 80%, rgba(59,130,246,.18) 0%, transparent 70%),
    linear-gradient(to bottom,
      rgba(15,19,23,.15) 0%,
      rgba(15,19,23,.3) 40%,
      rgba(15,19,23,.75) 80%,
      rgba(15,19,23,1) 100%
    );
}
/* Tech grid overlay */
.hero-grid {
  position: absolute; inset: 0; z-index: 1; pointer-events: none;
  background-image:
    linear-gradient(rgba(59,130,246,.06) 1px, transparent 1px),
    linear-gradient(90deg, rgba(59,130,246,.06) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black 30%, transparent 80%);
  -webkit-mask-image: radial-gradient(ellipse 80% 100% at 50% 0%, black 30%, transparent 80%);
}
/* Floating particles */
.hero-particles {
  position: absolute; inset: 0; z-index: 1; pointer-events: none; overflow: hidden;
}
.particle {
  position: absolute; border-radius: 50%;
  background: var(--c-accent); opacity: 0;
  animation: particle-float 6s ease-in-out infinite;
}
.p1 { width:3px;height:3px; left:15%; top:25%; animation-delay:0s;   animation-duration:7s; }
.p2 { width:2px;height:2px; left:35%; top:45%; animation-delay:1.2s; animation-duration:9s; }
.p3 { width:4px;height:4px; left:65%; top:30%; animation-delay:2.5s; animation-duration:8s; }
.p4 { width:2px;height:2px; left:80%; top:55%; animation-delay:0.8s; animation-duration:6s; }
.p5 { width:3px;height:3px; left:50%; top:20%; animation-delay:3.0s; animation-duration:10s; }
.p6 { width:2px;height:2px; left:90%; top:35%; animation-delay:1.8s; animation-duration:7s; }
@keyframes particle-float {
  0%,100% { opacity:0; transform:translateY(0) scale(1); }
  30% { opacity:.6; }
  70% { opacity:.3; }
  50% { transform:translateY(-40px) scale(1.3); }
}
@media (prefers-reduced-motion: reduce) {
  .particle { animation: none; opacity:.15; }
}

.hero-content {
  position: relative; z-index: 2;
  max-width: 780px; padding: 0 24px;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px; border-radius: 20px; margin-bottom: 28px;
  border: 1px solid rgba(59,130,246,.35);
  background: rgba(59,130,246,.1);
  font-size: 12px; font-weight: 600; color: var(--c-accent);
  letter-spacing: .5px;
  backdrop-filter: blur(8px);
}
.hero-badge-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--c-green);
  box-shadow: 0 0 6px var(--c-green);
  animation: pulse-dot 2s infinite;
}
@keyframes pulse-dot {
  0%,100% { opacity:1; transform:scale(1); }
  50% { opacity:.6; transform:scale(.8); }
}
.hero-title {
  font-size: clamp(2.4rem, 6vw, 4rem);
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: -1.5px;
  margin-bottom: 20px;
  color: var(--c-text);
}
.hero-title .brand {
  background: linear-gradient(135deg, #60A5FA, #3B82F6, #818CF8);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-tagline {
  font-size: clamp(1rem, 2.2vw, 1.2rem);
  color: var(--c-text-2); margin-bottom: 36px;
  line-height: 1.7; max-width: 560px; margin-left: auto; margin-right: auto;
}
/* Search bar */
.hero-search {
  display: flex; align-items: stretch;
  max-width: 560px; margin: 0 auto 40px;
  background: rgba(255,255,255,.07);
  border: 1px solid rgba(255,255,255,.12);
  border-radius: var(--r-lg);
  backdrop-filter: blur(12px);
  overflow: hidden;
  transition: border-color .2s, box-shadow .2s;
}
.hero-search:focus-within {
  border-color: var(--c-accent);
  box-shadow: var(--shadow-blue);
}
.hero-search-icon {
  display: flex; align-items: center; justify-content: center;
  padding: 0 16px; color: var(--c-text-3); flex-shrink: 0;
}
.hero-search input {
  flex: 1; background: transparent; border: none; outline: none;
  padding: 14px 0; font-size: 15px; color: var(--c-text);
  font-family: var(--font-sans);
}
.hero-search input::placeholder { color: var(--c-text-3); }
.hero-search-btn {
  padding: 10px 20px; margin: 6px;
  background: var(--c-accent); color: #fff;
  border-radius: var(--r-sm);
  font-size: 14px; font-weight: 600;
  transition: background .2s, transform .15s;
  flex-shrink: 0;
}
.hero-search-btn:hover { background: var(--c-accent-h); transform: scale(1.02); }
/* Quick chips */
.hero-chips {
  display: flex; flex-wrap: wrap; gap: 8px;
  justify-content: center;
}
.hero-chip {
  padding: 6px 14px; border-radius: 20px;
  background: rgba(255,255,255,.07); border: 1px solid rgba(255,255,255,.1);
  font-size: 13px; color: var(--c-text-2);
  cursor: pointer;
  transition: background .2s, color .2s, border-color .2s, transform .15s;
}
.hero-chip:hover {
  background: rgba(59,130,246,.15); color: var(--c-accent);
  border-color: rgba(59,130,246,.3);
  transform: translateY(-2px);
}

/* Hero scroll indicator */
.hero-scroll {
  position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);
  z-index: 2; display: flex; flex-direction: column; align-items: center; gap: 8px;
  color: var(--c-text-3); font-size: 11px; letter-spacing: 1px;
  animation: bounce-scroll 2s infinite;
}
.hero-scroll-arrow { font-size: 18px; color: var(--c-text-3); }
@keyframes bounce-scroll {
  0%,100% { transform:translateX(-50%) translateY(0); }
  50% { transform:translateX(-50%) translateY(6px); }
}

/* Stats bar in hero bottom */
.hero-stats {
  position: relative; z-index: 2;
  display: flex; gap: 0;
  background: rgba(27,31,36,.75);
  backdrop-filter: blur(12px);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  overflow: hidden;
  max-width: 700px; width: 100%; margin-top: 56px;
}
.hero-stat {
  flex: 1; padding: 18px 20px; text-align: center;
  border-right: 1px solid var(--c-border);
}
.hero-stat:last-child { border-right: none; }
.hero-stat-num {
  font-size: 1.5rem; font-weight: 800;
  color: var(--c-accent); line-height: 1;
  margin-bottom: 4px;
}
.hero-stat-label { font-size: 11px; color: var(--c-text-3); letter-spacing: .3px; }

/* ════════════════════════════════════════════
   CALCULATOR GRID (main feature)
   ════════════════════════════════════════════ */
#calculators { background: var(--c-bg); }
.calc-header { text-align: center; margin-bottom: 48px; }
.calc-tabs {
  display: flex; flex-wrap: wrap; gap: 8px;
  justify-content: center; margin-bottom: 36px;
}
.calc-tab {
  padding: 8px 20px; border-radius: var(--r-sm);
  font-size: 13px; font-weight: 600;
  border: 1px solid var(--c-border);
  color: var(--c-text-2); background: var(--c-surface);
  cursor: pointer;
  transition: all .2s;
}
.calc-tab:hover { border-color: var(--c-accent); color: var(--c-accent); }
.calc-tab.active {
  background: var(--c-accent); border-color: var(--c-accent);
  color: #fff;
}
.calc-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
}
.calc-card {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  padding: 24px;
  cursor: pointer;
  position: relative; overflow: hidden;
  transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
  text-decoration: none; color: inherit;
  display: block;
}
.calc-card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 2px;
  background: var(--c-accent); opacity: 0;
  transition: opacity .2s;
}
.calc-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg), 0 0 0 1px rgba(59,130,246,.2);
  border-color: rgba(59,130,246,.3);
}
.calc-card:hover::before { opacity: 1; }
.calc-card.featured {
  border-color: rgba(59,130,246,.35);
  background: linear-gradient(135deg, rgba(59,130,246,.06), var(--c-surface));
}
.calc-card.featured::before { opacity: 1; }
.calc-icon {
  width: 48px; height: 48px; border-radius: var(--r-md);
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; margin-bottom: 16px;
  background: rgba(59,130,246,.1);
  border: 1px solid rgba(59,130,246,.18);
}
.calc-card-title {
  font-size: 16px; font-weight: 700; margin-bottom: 8px;
  color: var(--c-text);
}
.calc-card-desc {
  font-size: 13px; color: var(--c-text-2); line-height: 1.55; margin-bottom: 16px;
}
.calc-card-meta {
  display: flex; align-items: center; justify-content: space-between;
}
.calc-card-tag { font-size: 11px; font-weight: 600; }
.calc-card-tag.liuxue { color: #22C55E; }
.calc-card-tag.finance { color: var(--c-amber); }
.calc-card-tag.life { color: #A78BFA; }
.calc-card-tag.tax { color: #F472B6; }
.calc-card-tag.visa { color: #34D399; }
.calc-card-arrow {
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--c-surface-3);
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; color: var(--c-text-3);
  transition: background .2s, color .2s, transform .2s;
}
.calc-card:hover .calc-card-arrow {
  background: var(--c-accent); color: #fff; transform: translateX(3px);
}
.calc-badge-new {
  position: absolute; top: 16px; right: 16px;
  padding: 3px 8px; border-radius: 10px;
  background: var(--c-accent); color: #fff;
  font-size: 10px; font-weight: 700; letter-spacing: .5px;
}
.calc-badge-hot {
  position: absolute; top: 16px; right: 16px;
  padding: 3px 8px; border-radius: 10px;
  background: rgba(239,68,68,.15); color: var(--c-red);
  border: 1px solid rgba(239,68,68,.25);
  font-size: 10px; font-weight: 700;
}

/* ════════════════════════════════════════════
   FEATURED / POPULAR
   ════════════════════════════════════════════ */
#featured { background: var(--c-surface); }
.featured-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
.featured-main {
  background: linear-gradient(135deg, #1E2A3A, #162235);
  border: 1px solid rgba(59,130,246,.25);
  border-radius: var(--r-xl);
  padding: 36px;
  display: flex; flex-direction: column; justify-content: space-between;
  min-height: 300px;
  position: relative; overflow: hidden;
}
.featured-main::after {
  content: '💱';
  position: absolute; right: -10px; bottom: -20px;
  font-size: 120px; opacity: .06;
  transform: rotate(-15deg);
  pointer-events: none;
}
.featured-main-title {
  font-size: 1.5rem; font-weight: 800; color: var(--c-text);
  margin-bottom: 10px;
}
.featured-main-desc { font-size: 14px; color: var(--c-text-2); line-height: 1.6; }
.featured-main-cta {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 12px 22px; margin-top: 24px;
  background: var(--c-accent); color: #fff;
  border-radius: var(--r-sm); font-size: 14px; font-weight: 600;
  width: fit-content;
  transition: background .2s, transform .15s;
}
.featured-main-cta:hover { background: var(--c-accent-h); transform: translateY(-2px); }
.featured-list {
  display: flex; flex-direction: column; gap: 12px;
}
.featured-item {
  display: flex; align-items: center; gap: 16px;
  background: var(--c-surface-2); border: 1px solid var(--c-border);
  border-radius: var(--r-md); padding: 16px 20px;
  cursor: pointer;
  transition: all .2s; text-decoration: none; color: inherit;
}
.featured-item:hover {
  border-color: rgba(59,130,246,.3);
  background: var(--c-surface-3);
  transform: translateX(4px);
}
.featured-item-icon {
  width: 42px; height: 42px; border-radius: var(--r-sm); flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 20px;
}
.fi-blue  { background: rgba(59,130,246,.12); }
.fi-green { background: rgba(34,197,94,.12); }
.fi-amber { background: rgba(245,158,11,.12); }
.fi-purple{ background: rgba(167,139,250,.12); }
.featured-item-body { flex: 1; }
.featured-item-title { font-size: 14px; font-weight: 700; margin-bottom: 2px; }
.featured-item-meta { font-size: 12px; color: var(--c-text-3); }
.featured-item-stat {
  font-size: 12px; font-weight: 600;
  color: var(--c-accent); flex-shrink: 0;
  text-align: right;
}

/* ════════════════════════════════════════════
   WHY US
   ════════════════════════════════════════════ */
#why { background: var(--c-bg); }
.why-grid {
  display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px;
}
.why-card {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-lg);
  padding: 28px 24px;
  text-align: center;
  transition: transform .2s, box-shadow .2s;
}
.why-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}
.why-icon {
  width: 56px; height: 56px; border-radius: var(--r-md);
  background: var(--c-accent-glow);
  border: 1px solid rgba(59,130,246,.2);
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; margin: 0 auto 18px;
}
.why-title { font-size: 15px; font-weight: 700; margin-bottom: 8px; }
.why-desc { font-size: 13px; color: var(--c-text-2); line-height: 1.6; }

/* ════════════════════════════════════════════
   INLINE DEMO CALCULATOR
   ════════════════════════════════════════════ */
#demo { background: var(--c-surface); }
.demo-wrapper {
  display: grid; grid-template-columns: 1fr 1fr; gap: 48px;
  align-items: center;
}
.demo-copy {}
.demo-copy .section-sub { margin-bottom: 24px; }
.demo-features {
  display: flex; flex-direction: column; gap: 12px;
}
.demo-feat {
  display: flex; align-items: flex-start; gap: 12px;
  font-size: 14px; color: var(--c-text-2);
}
.demo-feat-icon {
  width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0;
  background: rgba(34,197,94,.15); color: var(--c-green);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; margin-top: 1px;
}
/* Calculator widget */
.calc-widget {
  background: var(--c-surface-2);
  border: 1px solid var(--c-border);
  border-radius: var(--r-xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}
.calc-widget-header {
  padding: 16px 20px;
  border-bottom: 1px solid var(--c-border);
  display: flex; align-items: center; gap: 10px;
}
.calc-widget-dots {
  display: flex; gap: 6px;
}
.calc-widget-dot {
  width: 10px; height: 10px; border-radius: 50%;
}
.dot-r { background: #FF5F57; }
.dot-y { background: #FEBC2E; }
.dot-g { background: #28C840; }
.calc-widget-title {
  font-size: 13px; font-weight: 600; color: var(--c-text-2);
  margin-left: 6px;
}
.calc-widget-body { padding: 24px; }
.cw-tabs {
  display: flex; gap: 4px; margin-bottom: 20px;
  background: var(--c-surface); border-radius: var(--r-sm); padding: 4px;
}
.cw-tab {
  flex: 1; padding: 7px 0; border-radius: calc(var(--r-sm) - 2px);
  text-align: center; font-size: 12px; font-weight: 600; color: var(--c-text-3);
  cursor: pointer; transition: all .2s;
}
.cw-tab.active { background: var(--c-accent); color: #fff; }
.cw-field { margin-bottom: 14px; }
.cw-label {
  display: block; font-size: 11px; font-weight: 600;
  color: var(--c-text-3); letter-spacing: .5px; margin-bottom: 6px;
  text-transform: uppercase;
}
.cw-input {
  width: 100%;
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-sm);
  padding: 10px 14px;
  font-size: 15px; font-weight: 600; color: var(--c-text);
  font-family: var(--font-sans);
  transition: border-color .2s, box-shadow .2s;
  outline: none;
}
.cw-input:focus { border-color: var(--c-accent); box-shadow: var(--shadow-blue); }
.cw-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.cw-calc-btn {
  width: 100%; padding: 13px;
  background: var(--c-accent); color: #fff;
  border-radius: var(--r-sm); font-size: 15px; font-weight: 700;
  transition: background .2s, transform .15s;
  margin-top: 4px;
}
.cw-calc-btn:hover { background: var(--c-accent-h); transform: translateY(-1px); }
.cw-result {
  display: none;
  margin-top: 16px;
  background: var(--c-surface);
  border: 1px solid rgba(59,130,246,.25);
  border-radius: var(--r-md);
  padding: 16px;
}
.cw-result.show { display: block; }
.cw-result-label { font-size: 11px; color: var(--c-text-3); letter-spacing: .5px; margin-bottom: 6px; }
.cw-result-amount {
  font-size: 1.6rem; font-weight: 800; color: var(--c-accent);
}
.cw-result-breakdown {
  margin-top: 12px; display: flex; flex-direction: column; gap: 6px;
}
.cw-result-row {
  display: flex; justify-content: space-between;
  font-size: 12px; color: var(--c-text-2);
  padding: 4px 0; border-bottom: 1px solid var(--c-border);
}
.cw-result-row:last-child { border-bottom: none; }
.cw-disclaimer { font-size: 10px; color: var(--c-text-3); margin-top: 10px; text-align: center; }

/* ════════════════════════════════════════════
   FAQ
   ════════════════════════════════════════════ */
#faq { background: var(--c-bg); }
.faq-list {
  max-width: 760px; margin: 0 auto;
  display: flex; flex-direction: column; gap: 10px;
}
.faq-item {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-md);
  overflow: hidden;
  transition: border-color .2s;
}
.faq-item:hover { border-color: rgba(59,130,246,.25); }
.faq-q {
  width: 100%; padding: 18px 22px;
  display: flex; align-items: center; justify-content: space-between; gap: 16px;
  font-size: 15px; font-weight: 600; color: var(--c-text);
  cursor: pointer; background: transparent;
  text-align: left;
}
.faq-chevron {
  font-size: 16px; color: var(--c-text-3); flex-shrink: 0;
  transition: transform .3s; user-select: none;
}
.faq-item.open .faq-chevron { transform: rotate(180deg); }
.faq-a {
  max-height: 0; overflow: hidden;
  transition: max-height .3s ease, padding .3s ease;
  font-size: 14px; color: var(--c-text-2); line-height: 1.7;
  padding: 0 22px;
}
.faq-item.open .faq-a {
  max-height: 300px;
  padding: 0 22px 18px;
}

/* ════════════════════════════════════════════
   TEAM / ABOUT
   ════════════════════════════════════════════ */
#team { background: var(--c-surface); }
.team-inner {
  display: grid; grid-template-columns: 1fr 1fr; gap: 56px;
  align-items: center;
}
.team-copy .section-sub { margin-bottom: 28px; }
.team-stats-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
}
.team-stat-box {
  background: var(--c-surface-2);
  border: 1px solid var(--c-border);
  border-radius: var(--r-md);
  padding: 20px; text-align: center;
}
.team-stat-num {
  font-size: 1.8rem; font-weight: 800; color: var(--c-accent);
  margin-bottom: 4px;
}
.team-stat-label { font-size: 12px; color: var(--c-text-3); }
.team-update-card {
  background: var(--c-surface-2);
  border: 1px solid var(--c-border);
  border-radius: var(--r-xl);
  padding: 28px;
}
.team-update-title {
  font-size: 13px; font-weight: 700; color: var(--c-text-3);
  letter-spacing: .8px; text-transform: uppercase; margin-bottom: 16px;
}
.update-item {
  display: flex; gap: 14px; padding: 12px 0;
  border-bottom: 1px solid var(--c-border);
}
.update-item:last-child { border-bottom: none; padding-bottom: 0; }
.update-dot {
  width: 8px; height: 8px; border-radius: 50%; margin-top: 6px; flex-shrink: 0;
}
.update-dot.green  { background: var(--c-green); box-shadow: 0 0 6px var(--c-green); }
.update-dot.blue   { background: var(--c-accent); }
.update-dot.amber  { background: var(--c-amber); }
.update-body { flex: 1; }
.update-tool { font-size: 13px; font-weight: 600; margin-bottom: 2px; }
.update-date { font-size: 11px; color: var(--c-text-3); }

/* ════════════════════════════════════════════
   CTA BANNER
   ════════════════════════════════════════════ */
#cta-banner {
  background: linear-gradient(135deg, #1a2c4e, #0f2038);
  border-top: 1px solid rgba(59,130,246,.2);
  border-bottom: 1px solid rgba(59,130,246,.2);
  position: relative; overflow: hidden;
}
#cta-banner::before {
  content: '';
  position: absolute; top: -60px; right: -60px;
  width: 300px; height: 300px; border-radius: 50%;
  background: radial-gradient(circle, rgba(59,130,246,.2), transparent 70%);
  pointer-events: none;
}
.cta-inner {
  display: flex; align-items: center; justify-content: space-between; gap: 32px;
  padding: 56px 0;
}
.cta-copy .section-title { margin-bottom: 8px; }
.cta-copy .section-sub { color: rgba(232,236,240,.65); }
.cta-btns { display: flex; gap: 14px; flex-shrink: 0; }
.btn-primary {
  padding: 14px 28px; border-radius: var(--r-sm);
  background: var(--c-accent); color: #fff;
  font-size: 15px; font-weight: 700;
  transition: background .2s, transform .15s, box-shadow .2s;
  white-space: nowrap;
}
.btn-primary:hover {
  background: var(--c-accent-h); transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(59,130,246,.4);
}
.btn-outline {
  padding: 14px 28px; border-radius: var(--r-sm);
  background: transparent; color: var(--c-text);
  border: 1px solid rgba(255,255,255,.2);
  font-size: 15px; font-weight: 600;
  transition: border-color .2s, color .2s, transform .15s;
  white-space: nowrap;
}
.btn-outline:hover { border-color: var(--c-accent); color: var(--c-accent); transform: translateY(-2px); }

/* ════════════════════════════════════════════
   FOOTER
   ════════════════════════════════════════════ */
footer {
  background: var(--c-surface);
  border-top: 1px solid var(--c-border);
  padding: 60px 0 32px;
}
.footer-grid {
  display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px;
  padding-bottom: 40px; border-bottom: 1px solid var(--c-border);
  margin-bottom: 28px;
}
.footer-brand-name {
  font-size: 1.1rem; font-weight: 800; color: var(--c-text); margin-bottom: 10px;
  display: flex; align-items: center; gap: 8px;
}
.footer-brand-icon {
  width: 28px; height: 28px; background: var(--c-accent);
  border-radius: 6px; display: flex; align-items: center; justify-content: center;
  font-size: 14px; font-weight: 900; color: #fff;
}
.footer-brand-desc {
  font-size: 13px; color: var(--c-text-3); line-height: 1.65; max-width: 280px;
  margin-bottom: 18px;
}
.footer-col-title {
  font-size: 11px; font-weight: 700;
  letter-spacing: 1px; text-transform: uppercase;
  color: var(--c-text-3); margin-bottom: 14px;
}
.footer-links { display: flex; flex-direction: column; gap: 9px; }
.footer-links a {
  font-size: 13px; color: var(--c-text-2);
  transition: color .2s;
}
.footer-links a:hover { color: var(--c-accent); }
.footer-bottom {
  display: flex; align-items: center; justify-content: space-between;
  flex-wrap: wrap; gap: 12px;
}
.footer-copy { font-size: 12px; color: var(--c-text-3); }
.footer-legal { display: flex; gap: 16px; }
.footer-legal a { font-size: 12px; color: var(--c-text-3); transition: color .2s; }
.footer-legal a:hover { color: var(--c-accent); }

/* ════════════════════════════════════════════
   CHATBOT WIDGET
   ════════════════════════════════════════════ */
#chat-widget {
  position: fixed; bottom: 24px; right: 24px; z-index: 1000;
}
#chat-bubble {
  width: 56px; height: 56px; border-radius: 50%;
  background: var(--c-accent);
  box-shadow: 0 4px 20px rgba(59,130,246,.5);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: transform .2s, box-shadow .2s;
  position: relative;
}
#chat-bubble:hover {
  transform: scale(1.08);
  box-shadow: 0 6px 28px rgba(59,130,246,.65);
}
#chat-bubble-icon { font-size: 24px; }
/* Green pulse online dot — top-left 14×14px per standard */
.chat-online-dot {
  position: absolute; top: -2px; left: -2px;
  width: 14px; height: 14px; border-radius: 50%;
  background: var(--c-green);
  border: 2px solid var(--c-bg);
  z-index: 1;
}
.chat-online-dot::after {
  content: '';
  position: absolute; inset: -3px;
  border-radius: 50%;
  background: var(--c-green);
  opacity: .4;
  animation: chat-pulse 2s ease-in-out infinite;
}
@keyframes chat-pulse {
  0%,100% { transform: scale(1); opacity: .4; }
  50% { transform: scale(1.7); opacity: 0; }
}
#chat-panel {
  display: none;
  position: absolute; bottom: 68px; right: 0;
  width: 320px;
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--r-xl);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
  animation: panel-slide-up .25s ease;
}
#chat-panel.open { display: flex; flex-direction: column; }
@keyframes panel-slide-up {
  from { opacity:0; transform:translateY(12px) scale(.97); }
  to   { opacity:1; transform:translateY(0) scale(1); }
}
.chat-panel-header {
  padding: 16px 18px;
  background: linear-gradient(135deg, var(--c-accent), #6366F1);
  display: flex; align-items: center; gap: 10px;
}
.chat-panel-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  background: rgba(255,255,255,.2);
  display: flex; align-items: center; justify-content: center; font-size: 18px;
}
.chat-panel-info { flex: 1; }
.chat-panel-name { font-size: 14px; font-weight: 700; color: #fff; }
.chat-panel-status {
  font-size: 11px; color: rgba(255,255,255,.75);
  display: flex; align-items: center; gap: 4px;
}
.chat-panel-status::before {
  content: ''; width: 6px; height: 6px; border-radius: 50%; background: var(--c-green);
}
.chat-close {
  font-size: 20px; color: rgba(255,255,255,.7); cursor: pointer;
  line-height: 1;
  transition: color .2s;
}
.chat-close:hover { color: #fff; }
.chat-messages {
  padding: 16px; flex: 1; overflow-y: auto;
  display: flex; flex-direction: column; gap: 10px;
  max-height: 260px;
}
.chat-msg-bot {
  background: var(--c-surface-2); border: 1px solid var(--c-border);
  border-radius: 12px 12px 12px 4px;
  padding: 10px 14px; font-size: 13px; color: var(--c-text);
  line-height: 1.55; max-width: 85%;
}
.chat-msg-typing {
  display: flex; align-items: center; gap: 4px; padding: 10px 14px;
  background: var(--c-surface-2); border: 1px solid var(--c-border);
  border-radius: 12px 12px 12px 4px; width: fit-content;
}
.typing-dot {
  width: 6px; height: 6px; border-radius: 50%; background: var(--c-text-3);
  animation: typing 1.2s infinite;
}
.typing-dot:nth-child(2) { animation-delay: .2s; }
.typing-dot:nth-child(3) { animation-delay: .4s; }
@keyframes typing {
  0%,60%,100% { transform:translateY(0); }
  30% { transform:translateY(-5px); }
}
.chat-quick-btns {
  padding: 0 16px 10px;
  display: flex; flex-wrap: wrap; gap: 6px;
}
.chat-qb {
  padding: 6px 12px; border-radius: 14px;
  background: rgba(59,130,246,.1); border: 1px solid rgba(59,130,246,.2);
  font-size: 12px; color: var(--c-accent); cursor: pointer;
  transition: background .2s;
}
.chat-qb:hover { background: rgba(59,130,246,.2); }
.chat-input-row {
  padding: 10px 12px;
  border-top: 1px solid var(--c-border);
  display: flex; gap: 8px;
}
.chat-input {
  flex: 1; background: var(--c-surface-2); border: 1px solid var(--c-border);
  border-radius: 20px; padding: 8px 14px;
  font-size: 13px; color: var(--c-text); font-family: var(--font-sans);
  outline: none; transition: border-color .2s;
}
.chat-input:focus { border-color: var(--c-accent); }
.chat-send {
  width: 34px; height: 34px; border-radius: 50%;
  background: var(--c-accent); color: #fff;
  display: flex; align-items: center; justify-content: center; font-size: 14px;
  transition: background .2s, transform .15s;
}
.chat-send:hover { background: var(--c-accent-h); transform: scale(1.08); }

/* ════════════════════════════════════════════
   BACK TO TOP
   ════════════════════════════════════════════ */
#back-top {
  position: fixed; bottom: 90px; right: 28px;
  width: 40px; height: 40px; border-radius: 50%;
  background: var(--c-surface-2); border: 1px solid var(--c-border);
  color: var(--c-text-2);
  display: flex; align-items: center; justify-content: center; font-size: 16px;
  cursor: pointer; z-index: 800;
  opacity: 0; pointer-events: none;
  transition: opacity .3s, transform .2s;
}
#back-top.show { opacity: 1; pointer-events: auto; }
#back-top:hover { background: var(--c-accent); color: #fff; transform: translateY(-2px); }

/* ════════════════════════════════════════════
   RESPONSIVE
   ════════════════════════════════════════════ */
@media (max-width: 1024px) {
  .why-grid { grid-template-columns: repeat(2, 1fr); }
  .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  .team-inner { grid-template-columns: 1fr; gap: 36px; }
  .featured-grid { grid-template-columns: 1fr; }
  .demo-wrapper { grid-template-columns: 1fr; gap: 36px; }
}
@media (max-width: 768px) {
  :root { --section-py: 56px; }
  .nav-links, .nav-cta { display: none; }
  .nav-burger { display: flex; }
  .hero-title { letter-spacing: -1px; }
  .calc-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
  .why-grid { grid-template-columns: 1fr 1fr; }
  .hero-stats { flex-direction: column; }
  .hero-stat { border-right: none; border-bottom: 1px solid var(--c-border); }
  .hero-stat:last-child { border-bottom: none; }
  .cta-inner { flex-direction: column; text-align: center; }
  .cta-btns { justify-content: center; }
  .footer-grid { grid-template-columns: 1fr; gap: 28px; }
  #chat-panel { width: 290px; }
}
@media (max-width: 480px) {
  .why-grid { grid-template-columns: 1fr; }
  .calc-grid { grid-template-columns: 1fr; }
  .team-stats-grid { grid-template-columns: 1fr 1fr; }
  .hero-search { flex-direction: column; border-radius: var(--r-md); }
  .hero-search input { padding: 12px 16px; }
  .hero-search-btn { margin: 0 8px 8px; border-radius: var(--r-sm); }
  .footer-bottom { flex-direction: column; align-items: flex-start; }
}
</style>
