<script>
  // ── NAV ──
  window.addEventListener('scroll',()=>{
    document.getElementById('mainNav').classList.toggle('scrolled', window.scrollY>60);
  });
  function closeMobile(){
    document.getElementById('mobileMenu').classList.remove('open');
    document.getElementById('hamburger').setAttribute('aria-expanded','false');
  }
  document.getElementById('hamburger').addEventListener('click',function(){
    const open = document.getElementById('mobileMenu').classList.toggle('open');
    this.setAttribute('aria-expanded', open);
  });

  // ── SMOOTH SCROLL for anchor links ──
  document.querySelectorAll('a[href^="#"]').forEach(a=>{
    a.addEventListener('click',e=>{
      const t=document.querySelector(a.getAttribute('href'));
      if(t){ e.preventDefault(); t.scrollIntoView({behavior:'smooth'}); closeMobile(); }
    });
  });

  // ── WIDGET ──
  function toggleWidget(){
    const p=document.getElementById('widgetPanel');
    const b=document.getElementById('widgetBtn');
    const open=p.classList.toggle('open');
    b.setAttribute('aria-expanded',open);
  }
  const BOT_REPLIES = {
    '澳洲':   '澳洲留学硕士 1.5 年预算大约 ¥55–90 万人民币，悉尼和墨尔本生活费最贵。要详细估算可以用上面的计算器选「澳大利亚」试试 😊',
    '英国':   '英国硕士通常 1 年制，总费用约 ¥30–50 万。伦敦比曼彻斯特贵约 40%，G5 名校学费比普通大学高 ¥5–8 万/年。',
    '美国':   '美国留学费用最高，研究生 2 年一般 ¥80–150 万，纽约/波士顿生活费最贵。不少学校有 TA/RA 可减免学费。',
    '加拿大': '加拿大性价比不错，硕士 2 年约 ¥55–85 万，温哥华和多伦多最贵，蒙特利尔便宜很多。',
    '新加坡': '新加坡生活费高但学费相对亲民，NUS/NTU 国际生硕士约 SGD 30,000–50,000/年，总计约 ¥50–75 万。',
    '奖学金': '推荐关注：澳洲 Australia Awards、英国 Chevening、各院校 Early Bird Scholarship。高 GPA 学生可争取 20%–50% 学费减免。',
    '省钱':   '最有效的省钱方法：① 申请奖学金 ② 校内宿舍 ③ 自炊 ④ 早买机票 ⑤ Wise 换汇代替银行汇款，可省 1%–3% 手续费。',
    '保险':   '澳洲 OSHC、英国 IHS 是强制医保，费用已含在计算器里。美国各校计划差异大，建议比较校内外保险再决定。',
  };
  function sendMsg(){
    const inp=document.getElementById('widgetInput');
    const msg=inp.value.trim();
    if(!msg)return;
    const msgs=document.getElementById('widgetMsgs');
    msgs.innerHTML+=`<div class="msg-user">${msg}</div>`;
    inp.value='';
    setTimeout(()=>{
      let reply='感谢你的问题！建议直接用上方计算器输入具体条件，可以得到更准确的估算。如需专业顾问服务，点击「免费咨询」获取个性化方案。';
      for(const [key,rep] of Object.entries(BOT_REPLIES)){
        if(msg.includes(key)){ reply=rep; break; }
      }
      msgs.innerHTML+=`<div class="msg-bot">${reply}</div>`;
      msgs.scrollTop=msgs.scrollHeight;
    }, 600);
    msgs.scrollTop=msgs.scrollHeight;
  }

  // Close widget on outside click
  document.addEventListener('click',e=>{
    const panel=document.getElementById('widgetPanel');
    const btn=document.getElementById('widgetBtn');
    if(panel.classList.contains('open') && !panel.contains(e.target) && !btn.contains(e.target)){
      panel.classList.remove('open');
      btn.setAttribute('aria-expanded','false');
    }
  });

  // ── SCROLL REVEAL ──
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('visible'); io.unobserve(e.target); }});
  },{ threshold:0.12 });
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

  // Country card keyboard support
  document.querySelectorAll('.country-card').forEach(c=>{
    c.addEventListener('keydown',e=>{ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); c.click(); }});
  });
</script>
