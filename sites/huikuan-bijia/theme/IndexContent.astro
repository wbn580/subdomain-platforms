---
// Bespoke homepage content
---


<!-- ===== HERO ===== -->
<section class="hero" aria-labelledby="hero-title">
  <div class="hero-bg" id="heroBg"
    role="img"
    aria-label="留学生使用手机进行跨境汇款"
    style="background-image: url('https://images.pexels.com/photos/6289170/pexels-photo-6289170.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080&fit=crop');">
  </div>
  <div class="hero-overlay" aria-hidden="true"></div>
  <div class="hero-flow" aria-hidden="true">
    <div class="flow-line"></div>
    <div class="flow-line"></div>
    <div class="flow-line"></div>
  </div>
  <div class="hero-content">
    <div class="hero-inner">
      <!-- Left: Headline + CTAs -->
      <div>
        <div class="hero-tag">实时汇率 · 独立比价</div>
        <h1 class="hero-title" id="hero-title">
          汇学费生活费，<br>
          每一分都该<em>物尽其值</em>
        </h1>
        <p class="hero-tagline">
          汇款比价为留学生家庭独立测评 Wise、Remitly、银行电汇、Flywire 学费直缴等主流渠道——真实汇率差、手续费、到账时间，一目了然，每年最多帮你省 ¥2,000+。
        </p>
        <div class="hero-ctas">
          <a href="#calculator" class="btn-primary" aria-label="开始免费试算">
            ⚡ 立即试算
          </a>
          <a href="#compare" class="btn-ghost" aria-label="查看渠道对比">
            查看渠道对比
          </a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <strong>4+</strong>
            主流渠道对比
          </div>
          <div class="hero-stat">
            <strong>¥0</strong>
            使用完全免费
          </div>
          <div class="hero-stat">
            <strong>每日</strong>
            汇率数据更新
          </div>
        </div>
      </div>

      <!-- Right: Quick Calculator Card -->
      <div class="hero-calc" id="calculator" role="region" aria-label="汇款费用快速试算">
        <div class="calc-title">汇款费用快速试算</div>
        <div class="calc-row">
          <label class="calc-label" for="calcAmount">汇款金额（人民币）</label>
          <div class="calc-input-wrap">
            <span class="calc-prefix">¥ CNY</span>
            <input type="number" id="calcAmount" class="calc-input" value="50000"
              min="100" max="1000000" step="1000"
              aria-label="输入汇款金额（人民币）" />
          </div>
        </div>
        <div class="calc-row">
          <label class="calc-label" for="calcTarget">收款货币</label>
          <select id="calcTarget" class="calc-select" aria-label="选择收款货币">
            <option value="AUD" data-rate="0.2065" data-rate-bank="0.1998">澳大利亚元 (AUD)</option>
            <option value="GBP" data-rate="0.1092" data-rate-bank="0.1055">英镑 (GBP)</option>
            <option value="USD" data-rate="0.1378" data-rate-bank="0.1335">美元 (USD)</option>
            <option value="EUR" data-rate="0.1252" data-rate-bank="0.1215">欧元 (EUR)</option>
            <option value="CAD" data-rate="0.1901" data-rate-bank="0.1842">加元 (CAD)</option>
            <option value="NZD" data-rate="0.2248" data-rate-bank="0.2178">新西兰元 (NZD)</option>
            <option value="SGD" data-rate="0.1832" data-rate-bank="0.1776">新加坡元 (SGD)</option>
            <option value="JPY" data-rate="20.65" data-rate-bank="19.98">日元 (JPY)</option>
          </select>
        </div>
        <button class="btn-calc" id="calcBtn" onclick="runCalc()" aria-label="开始比较各渠道">
          <span id="calcBtnText">比较各渠道</span>
          <span id="calcBtnIcon">→</span>
        </button>
        <div class="calc-results" id="calcResults" role="region" aria-live="polite" aria-label="各渠道对比结果">
          <!-- Populated by JS -->
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== STATS STRIP ===== -->
<section class="stats-strip" aria-label="平台数据概览">
  <div class="container">
    <div class="stats-grid">
      <div class="stat-item reveal">
        <div class="stat-number" id="stat1">4+</div>
        <div class="stat-label">已收录汇款渠道</div>
      </div>
      <div class="stat-item reveal reveal-delay-1">
        <div class="stat-number">3%</div>
        <div class="stat-label">综合汇率差最大节省幅度</div>
      </div>
      <div class="stat-item reveal reveal-delay-2">
        <div class="stat-number">24h</div>
        <div class="stat-label">最快到账时效（Wise）</div>
      </div>
      <div class="stat-item reveal reveal-delay-3">
        <div class="stat-number">¥0</div>
        <div class="stat-label">完全独立免费比价</div>
      </div>
    </div>
  </div>
</section>

<!-- ===== CHANNEL COMPARISON ===== -->
<section class="section section-alt" id="compare" aria-labelledby="compare-title">
