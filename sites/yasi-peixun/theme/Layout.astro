<script>
// --- Navbar scroll ---
    const navbar = document.getElementById('navbar');
    function handleScroll() {
      const scrolled = window.scrollY > 48;
      navbar.classList.toggle('scrolled', scrolled);
      document.getElementById('back-top').classList.toggle('visible', window.scrollY > 400);
    }
    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    // --- Hamburger ---
    const hamburger = document.getElementById('hamburger');
    const mobileNav = document.getElementById('mobile-nav');
    hamburger.addEventListener('click', () => {
      const open = hamburger.classList.toggle('active');
      mobileNav.classList.toggle('open', open);
      hamburger.setAttribute('aria-expanded', open);
      mobileNav.style.display = open ? 'flex' : 'none';
    });
    mobileNav.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        hamburger.classList.remove('active');
        mobileNav.classList.remove('open');
        hamburger.setAttribute('aria-expanded', 'false');
      });
    });
    // init mobile nav display
    mobileNav.style.display = 'none';

    // --- Hero bg lazy load + parallax hint ---
    const heroBg = document.getElementById('hero-bg');
    const img = new Image();
    img.onload = () => heroBg.classList.add('loaded');
    img.src = 'https://images.pexels.com/photos/5649522/pexels-photo-5649522.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=1080&w=1920';
    heroBg.style.backgroundImage = `url('${img.src}')`;

    // --- Scroll reveal ---
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          revealObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // --- Skill bar animation ---
    const barObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.querySelectorAll('.skill-score-fill').forEach(bar => {
            const w = bar.dataset.width;
            setTimeout(() => { bar.style.width = w; }, 200);
          });
          barObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.3 });
    document.querySelectorAll('.skills-grid').forEach(el => barObserver.observe(el));

    // --- Score curve animation ---
    const curveObserver = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const line = document.getElementById('curve-line');
          const fill = document.getElementById('curve-fill');
          if (line) {
            line.style.transition = 'stroke-dashoffset 1.8s cubic-bezier(0.4,0,0.2,1)';
            line.style.strokeDashoffset = '0';
          }
          if (fill) {
            fill.style.transition = 'opacity 1.2s ease 0.6s';
            fill.style.opacity = '1';
          }
          document.querySelectorAll('.curve-canvas circle').forEach((c, i) => {
            c.style.transition = `opacity 0.3s ease ${0.4 + i * 0.25}s`;
            c.style.opacity = '1';
          });
          curveObserver.unobserve(e.target);
        }
      });
    }, { threshold: 0.4 });
    document.querySelectorAll('.score-curve-visual').forEach(el => curveObserver.observe(el));

    // --- FAQ ---
    document.querySelectorAll('.faq-q').forEach(q => {
      const activate = () => {
        const item = q.closest('.faq-item');
        const open = item.classList.toggle('open');
        q.setAttribute('aria-expanded', open);
      };
      q.addEventListener('click', activate);
      q.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(); } });
    });

    // --- Filter ---
    function filterRank(btn, type) {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      // visual feedback only (real filter would query data)
      const cards = document.querySelectorAll('.ranking-card');
      cards.forEach(c => {
        c.style.opacity = '0.4';
        c.style.transform = 'scale(0.97)';
        setTimeout(() => {
          c.style.opacity = '1';
          c.style.transform = '';
        }, 350);
      });
    }

    // --- Widget ---
    let widgetOpen = false;
    function toggleWidget() {
      widgetOpen = !widgetOpen;
      const panel = document.getElementById('widget-panel');
      const btn = document.getElementById('widget-btn');
      panel.classList.toggle('open', widgetOpen);
      btn.setAttribute('aria-expanded', widgetOpen);
    }
    function sendChip(chip) {
      const input = document.querySelector('.widget-input input');
      input.value = chip.textContent;
      input.focus();
    }

    // --- Back to top ---
    function scrollToTop() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>

</body>
</html>