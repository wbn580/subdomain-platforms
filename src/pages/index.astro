---
import SiteLayout from "../layouts/SiteLayout.astro";
import { siteConfig } from "../lib/site";

// Bespoke homepage imports
import ZjIndex from '../../sites/zhongjie-paiming/theme/IndexContent.astro';
import XgIndex from '../../sites/xianggang-zhuce/theme/IndexContent.astro';
import OsIndex from '../../sites/oshc-bijia/theme/IndexContent.astro';
import LhIndex from '../../sites/luohu-chaxun/theme/IndexContent.astro';
import HkIndex from '../../sites/huikuan-bijia/theme/IndexContent.astro';
import YsIndex from '../../sites/yasi-peixun/theme/IndexContent.astro';
import LxIndex from '../../sites/liuxue-jisuan/theme/IndexContent.astro';
import JhIndex from '../../sites/jisuan-hub/theme/IndexContent.astro';
import GpIndex from '../../sites/gpa-jisuan/theme/IndexContent.astro';
import HvIndex from '../../sites/huilv-jisuan/theme/IndexContent.astro';
import YgIndex from '../../sites/yuegong-jisuan/theme/IndexContent.astro';

const slug: string = siteConfig.slug || 'zhongjie-paiming';

const bespokeMap: Record<string, any> = {
  'zhongjie-paiming': ZjIndex,
  'xianggang-zhuce': XgIndex,
  'oshc-bijia': OsIndex,
  'luohu-chaxun': LhIndex,
  'huikuan-bijia': HkIndex,
  'yasi-peixun': YsIndex,
  'liuxue-jisuan': LxIndex,
  'jisuan-hub': JhIndex,
  'gpa-jisuan': GpIndex,
  'yuegong-jisuan': YgIndex,
  'huilv-jisuan': HvIndex,
};

const BespokeIndex = bespokeMap[slug];
---

<SiteLayout title={siteConfig.brand} description={siteConfig.tagline}>
  {BespokeIndex && <BespokeIndex />}
</SiteLayout>
