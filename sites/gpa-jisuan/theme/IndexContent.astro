        </div>
      </div>

      <div class="course-grid" id="courseTable" role="table" aria-label="课程成绩输入表">
        <div class="course-row-header" role="row">
          <div class="course-th" role="columnheader">课程名称</div>
          <div class="course-th" role="columnheader">成绩</div>
          <div class="course-th" role="columnheader">学分</div>
          <div class="course-th" role="columnheader" aria-label="删除"></div>
        </div>
        <div id="courseRows" role="rowgroup">
          <div class="course-row" data-row="0" role="row">
            <div role="cell"><input class="course-input" type="text" placeholder="高等数学" aria-label="课程名称" value="高等数学"></div>
            <div role="cell"><input class="course-input score-input" type="number" min="0" max="100" placeholder="85" aria-label="成绩" value="85"></div>
            <div role="cell"><input class="course-input credit-input" type="number" min="0.5" max="20" step="0.5" placeholder="4" aria-label="学分" value="4"></div>
            <div role="cell"><button class="del-btn" onclick="removeRow(0)" aria-label="删除此行">✕</button></div>
          </div>
          <div class="course-row" data-row="1" role="row">
            <div role="cell"><input class="course-input" type="text" placeholder="大学英语" aria-label="课程名称" value="大学英语"></div>
            <div role="cell"><input class="course-input score-input" type="number" min="0" max="100" placeholder="78" aria-label="成绩" value="78"></div>
            <div role="cell"><input class="course-input credit-input" type="number" min="0.5" max="20" step="0.5" placeholder="2" aria-label="学分" value="2"></div>
            <div role="cell"><button class="del-btn" onclick="removeRow(1)" aria-label="删除此行">✕</button></div>
          </div>
          <div class="course-row" data-row="2" role="row">
            <div role="cell"><input class="course-input" type="text" placeholder="线性代数" aria-label="课程名称" value="线性代数"></div>
            <div role="cell"><input class="course-input score-input" type="number" min="0" max="100" placeholder="92" aria-label="成绩" value="92"></div>
            <div role="cell"><input class="course-input credit-input" type="number" min="0.5" max="20" step="0.5" placeholder="3" aria-label="学分" value="3"></div>
