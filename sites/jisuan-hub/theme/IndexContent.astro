---
---
<!-- ═══ HERO ═══ -->
<section id="hero" aria-label="平台介绍">
  <div class="hero-bg">
    <!-- Pexels photo 18545023 — abstract dark technology data visualization 7680×4320 -->
    <img
      class="hero-bg-img"
      src="https://images.pexels.com/photos/18545023/pexels-photo-18545023.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080&fit=crop"
      alt="深色科技数据可视化背景"
      loading="eager"
      fetchpriority="high"
      width="1920" height="1080"
    >
  </div>
  <div class="hero-grid"></div>
  <div class="hero-particles">
    <div class="particle p1"></div>
    <div class="particle p2"></div>
    <div class="particle p3"></div>
    <div class="particle p4"></div>
    <div class="particle p5"></div>
    <div class="particle p6"></div>
  </div>

  <div class="hero-content">
    <div class="hero-badge">
      <span class="hero-badge-dot"></span>
      全部工具免费 · 无需注册 · 随时可用
    </div>

    <h1 class="hero-title">
      留学财务计算<br>
      <span class="brand">一站算清</span>
    </h1>

    <p class="hero-tagline">
      留学费用、GPA换算、汇率兑换、贷款月供、落户积分——<br>
      jisuan.help，各种算什么都在这里。
    </p>

    <div class="hero-search" role="search">
      <div class="hero-search-icon" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
      </div>
      <input
        type="text"
        placeholder="搜索计算器，如「GPA换算」「贷款月供」"
        id="hero-search-input"
        aria-label="搜索计算工具"
      >
      <button class="hero-search-btn" onclick="doSearch()" aria-label="搜索">搜索</button>
    </div>

    <div class="hero-chips" role="list" aria-label="快速导航">
      <button class="hero-chip" onclick="scrollToId('#calculators')" role="listitem">📚 留学费用</button>
      <button class="hero-chip" onclick="scrollToId('#calculators')" role="listitem">🎓 GPA换算</button>
      <button class="hero-chip" onclick="scrollToId('#calculators')" role="listitem">💱 汇率换汇</button>
      <button class="hero-chip" onclick="scrollToId('#calculators')" role="listitem">🏠 贷款月供</button>
      <button class="hero-chip" onclick="scrollToId('#calculators')" role="listitem">🏙️ 落户积分</button>
      <button class="hero-chip" onclick="scrollToId('#calculators')" role="listitem">📊 个税计算</button>
    </div>
  </div>

  <div class="hero-stats" role="group" aria-label="平台数据">
    <div class="hero-stat">
      <div class="hero-stat-num">18+</div>
      <div class="hero-stat-label">在线计算工具</div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-num">15万+</div>
      <div class="hero-stat-label">月活跃用户</div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-num">0</div>
      <div class="hero-stat-label">注册门槛</div>
    </div>
    <div class="hero-stat">
      <div class="hero-stat-num">实时</div>
      <div class="hero-stat-label">汇率数据更新</div>
    </div>
  </div>

  <div class="hero-scroll" aria-hidden="true">
    <div class="hero-scroll-arrow">↓</div>
    <span>向下探索</span>
  </div>
</section>

<!-- ═══ CALCULATOR GRID ═══ -->
<section id="calculators" class="section" aria-labelledby="calc-heading">
  <div class="container">
    <div class="calc-header">
      <div class="section-eyebrow sr" aria-hidden="true">全部工具</div>
      <h2 class="section-title sr sr-delay-1" id="calc-heading">18个专业计算器</h2>
      <p class="section-sub sr sr-delay-2" style="margin:0 auto;">
        覆盖留学、财务、落户、生活全场景，持续更新中。所有计算结果仅供参考，请以官方数据为准。
      </p>
    </div>

    <div class="calc-tabs sr sr-delay-2" role="tablist" aria-label="分类筛选">
      <button class="calc-tab active" role="tab" aria-selected="true" data-filter="all" onclick="filterCalcs('all', this)">全部</button>
      <button class="calc-tab" role="tab" aria-selected="false" data-filter="liuxue" onclick="filterCalcs('liuxue', this)">🎓 留学</button>
      <button class="calc-tab" role="tab" aria-selected="false" data-filter="finance" onclick="filterCalcs('finance', this)">💰 财务</button>
      <button class="calc-tab" role="tab" aria-selected="false" data-filter="life" onclick="filterCalcs('life', this)">🏙️ 生活</button>
      <button class="calc-tab" role="tab" aria-selected="false" data-filter="tax" onclick="filterCalcs('tax', this)">📋 税务</button>
      <button class="calc-tab" role="tab" aria-selected="false" data-filter="visa" onclick="filterCalcs('visa', this)">🛂 签证</button>
    </div>

    <div class="calc-grid" id="calc-grid">

      <!-- Row 1 -->
      <a href="https://liuxue.jisuan.help" class="calc-card featured sr sr-delay-1" data-cat="liuxue" aria-label="留学总费用计算器">
        <div class="calc-badge-hot">🔥 最热</div>
        <div class="calc-icon">🎓</div>
        <h3 class="calc-card-title">留学总费用计算器</h3>
        <p class="calc-card-desc">澳洲/英国/美国/加拿大学费 + 生活费 + 医保 + 机票，一次算清三年总花费。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag liuxue">留学必备</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <a href="https://gpa.jisuan.help" class="calc-card sr sr-delay-2" data-cat="liuxue" aria-label="GPA成绩换算器">
        <div class="calc-badge-new">NEW</div>
        <div class="calc-icon">📊</div>
        <h3 class="calc-card-title">GPA 成绩换算器</h3>
        <p class="calc-card-desc">国内百分制 / 五分制 / 四分制互转，支持澳洲 WAM、英国一等/二等学位对照。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag liuxue">留学必备</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <a href="https://huilv.jisuan.help" class="calc-card sr sr-delay-3" data-cat="finance" aria-label="汇率换汇试算器">
        <div class="calc-icon">💱</div>
        <h3 class="calc-card-title">汇率换汇试算器</h3>
        <p class="calc-card-desc">人民币 / 港币 / 澳元 / 英镑 / 美元多向换算，实时参考汇率，留学汇款前必试。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag finance">财务工具</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <a href="https://yuegong.jisuan.help" class="calc-card sr sr-delay-4" data-cat="finance" aria-label="贷款月供计算器">
        <div class="calc-icon">🏠</div>
        <h3 class="calc-card-title">贷款月供计算器</h3>
        <p class="calc-card-desc">房贷/车贷/个人贷款本息算法，支持等额本息与等额本金两种还款方式。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag finance">财务工具</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <a href="https://huji.jisuan.help" class="calc-card sr sr-delay-5" data-cat="life" aria-label="落户积分计算器">
        <div class="calc-icon">🏙️</div>
        <h3 class="calc-card-title">落户积分计算器</h3>
        <p class="calc-card-desc">上海积分制居住证 / 北京积分落户，输入年龄学历工作年限，一键测算积分。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag life">生活工具</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <a href="https://geshui.jisuan.help" class="calc-card sr sr-delay-6" data-cat="tax" aria-label="个人所得税计算器">
        <div class="calc-icon">📋</div>
        <h3 class="calc-card-title">个人所得税计算器</h3>
        <p class="calc-card-desc">2024最新税率表，月薪 → 实际到手工资，支持五险一金专项附加扣除。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag tax">税务工具</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <!-- Row 2 -->
      <a href="https://yasi.jisuan.help" class="calc-card sr sr-delay-1" data-cat="liuxue" aria-label="雅思分数计算器">
        <div class="calc-icon">📝</div>
        <h3 class="calc-card-title">雅思综合分计算器</h3>
        <p class="calc-card-desc">四项单科分 → 综合分 band 自动四舍五入，快速校验目标院校最低要求。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag liuxue">留学必备</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <a href="https://qianzheng.jisuan.help" class="calc-card sr sr-delay-2" data-cat="visa" aria-label="签证费用计算器">
        <div class="calc-icon">🛂</div>
        <h3 class="calc-card-title">签证费用计算器</h3>
        <p class="calc-card-desc">澳洲学签/工签/旅游签证申请费，汇率自动换算，含附申请人附加费。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag visa">签证工具</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <a href="https://oshc.jisuan.help" class="calc-card sr sr-delay-3" data-cat="liuxue" aria-label="海外学生医保估价">
        <div class="calc-icon">🏥</div>
        <h3 class="calc-card-title">OSHC 医保费用估算</h3>
        <p class="calc-card-desc">澳洲 OSHC 年费按学习年限 + 人数估算，Allianz / Medibank / BUPA 对比参考。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag liuxue">留学必备</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <a href="https://auyimin.jisuan.help" class="calc-card sr sr-delay-4" data-cat="visa" aria-label="澳洲移民打分计算器">
        <div class="calc-icon">🇦🇺</div>
        <h3 class="calc-card-title">澳洲移民打分 (EOI)</h3>
        <p class="calc-card-desc">独立技术移民 189 / 190 / 491，按年龄+英语+学历+工作经验自动测分。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag visa">签证工具</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <a href="https://fudai.jisuan.help" class="calc-card sr sr-delay-5" data-cat="finance" aria-label="复利投资计算器">
        <div class="calc-icon">📈</div>
        <h3 class="calc-card-title">复利投资计算器</h3>
        <p class="calc-card-desc">本金 × 年化利率 × 投资年限，复利滚算，直观展示财富增长曲线。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag finance">财务工具</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

      <a href="https://auyimin.jisuan.help" class="calc-card sr sr-delay-6" data-cat="life" aria-label="房租与买房成本对比">
        <div class="calc-icon">🔑</div>
        <h3 class="calc-card-title">租房 vs 买房成本对比</h3>
        <p class="calc-card-desc">综合贷款利息、印花税、物业费，算清 5 / 10 / 20 年租买哪个更划算。</p>
        <div class="calc-card-meta">
          <span class="calc-card-tag life">生活工具</span>
          <span class="calc-card-arrow">→</span>
        </div>
      </a>

    </div>
  </div>
</section>

