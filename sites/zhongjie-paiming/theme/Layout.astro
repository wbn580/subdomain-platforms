  <div class="widget-panel" id="widgetPanel" role="dialog" aria-label="留学中介咨询助手" aria-modal="false">
    <div class="widget-header">
      <div class="widget-header-left">
        <div class="widget-avatar" aria-hidden="true">
          🏆
          <div class="widget-avatar-dot"></div>
