<script>
// ---- SCROLL EFFECTS ----
  const nav = document.getElementById('mainNav');
  const backTop = document.getElementById('backTop');
  const heroBg = document.getElementById('heroBg');

  window.addEventListener('scroll', () => {
    const y = window.scrollY;
    nav.classList.toggle('scrolled', y > 60);
    backTop.classList.toggle('show', y > 400);
  }, { passive: true });

  // Hero BG parallax subtle
  window.addEventListener('scroll', () => {
    if (heroBg) {
      heroBg.style.transform = `scale(1.04) translateY(${window.scrollY * 0.12}px)`;
    }
  }, { passive: true });

  // Hero BG load effect
  window.addEventListener('load', () => {
    if (heroBg) heroBg.classList.add('loaded');
  });

  // ---- SCROLL REVEAL ----
  const revealEls = document.querySelectorAll('.reveal');
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        revealObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  revealEls.forEach(el => revealObserver.observe(el));

  // ---- HAMBURGER ----
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger.addEventListener('click', () => {
    const open = mobileMenu.classList.toggle('open');
    hamburger.classList.toggle('open', open);
    hamburger.setAttribute('aria-expanded', open);
  });
  // Close on nav link click
  mobileMenu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      mobileMenu.classList.remove('open');
      hamburger.classList.remove('open');
      hamburger.setAttribute('aria-expanded', false);
    });
  });

  // ---- CALCULATOR ----
  const PROVIDERS = [
    {
      name: 'Wise',
      feeBase: 9,       // flat CNY
      feePct: 0.0046,   // % of CNY amount
      rateFactor: 1.000,// uses true mid-rate
      badge: '最省手续费',
      color: '#0057A8'
    },
    {
      name: 'Remitly',
      feeBase: 25,
      feePct: 0.0020,
      rateFactor: 0.994,
      badge: '',
      color: '#E03A20'
    },
    {
      name: 'Flywire',
      feeBase: 0,
      feePct: 0.0000,
      rateFactor: 0.996,
      badge: '学费直缴',
      color: '#7C3AED'
    },
    {
      name: '银行电汇',
      feeBase: 200,
      feePct: 0.0010,
      rateFactor: 0.980,
      badge: '',
      color: '#475569'
    }
  ];

  function runCalc() {
    const btn = document.getElementById('calcBtn');
    const btnText = document.getElementById('calcBtnText');
    const btnIcon = document.getElementById('calcBtnIcon');
    const amountInput = document.getElementById('calcAmount');
    const targetSel = document.getElementById('calcTarget');
    const resultsDiv = document.getElementById('calcResults');

    const amount = parseFloat(amountInput.value) || 50000;
    const selectedOpt = targetSel.selectedOptions[0];
    const baseRate = parseFloat(selectedOpt.dataset.rate);
    const currency = targetSel.value;

    // Loading state
    btn.classList.add('loading');
    btnText.textContent = '计算中…';
    btnIcon.textContent = '⏳';

    setTimeout(() => {
      btn.classList.remove('loading');
      btnText.textContent = '重新计算';
      btnIcon.textContent = '↺';

      // Compute results
      const results = PROVIDERS.map(p => {
        const fee = p.feeBase + amount * p.feePct;
        const netCNY = amount - fee;
        const received = netCNY * baseRate * p.rateFactor;
        return { ...p, fee, received };
      }).sort((a, b) => b.received - a.received);

      const best = results[0];

      let html = '';
      results.forEach((r, i) => {
        const isBest = i === 0;
        const savingVsWorst = r.received - results[results.length - 1].received;
        html += `
          <div class="calc-result-row ${isBest ? 'best' : ''}">
            <div>
              <div class="result-provider">
                <span style="width:8px;height:8px;border-radius:50%;background:${r.color};display:inline-block;flex-shrink:0;" aria-hidden="true"></span>
                ${r.name}
                ${r.badge ? `<span class="result-badge">${r.badge}</span>` : ''}
              </div>
              <div class="result-fee">手续费约 ¥${Math.round(r.fee).toLocaleString()}</div>
            </div>
            <div>
              <div class="result-amount">${currency} ${r.received.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',')}</div>
              ${isBest ? `<div class="result-fee" style="color:var(--c-green)">最多到账</div>` : `<div class="result-fee">少 ${currency} ${(best.received - r.received).toFixed(0)}</div>`}
            </div>
          </div>
        `;
      });

      html += `<p class="calc-disclaimer">汇率数据为参考估算，实际以各平台为准。推广链接已合规标注（§3.43）。</p>`;
      resultsDiv.innerHTML = html;
      resultsDiv.classList.add('show');
    }, 800);
  }

  // ---- FAQ ACCORDION ----
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item');
      const wasOpen = item.classList.contains('open');
      // Close all
      document.querySelectorAll('.faq-item').forEach(i => {
        i.classList.remove('open');
        i.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
      });
      if (!wasOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ---- WIDGET ----
  let widgetOpen = false;
  function toggleWidget() {
    widgetOpen = !widgetOpen;
    document.getElementById('widgetPanel').classList.toggle('open', widgetOpen);
    document.getElementById('widgetBubble').setAttribute('aria-expanded', widgetOpen);
    if (widgetOpen) {
      setTimeout(() => document.getElementById('widgetInput').focus(), 300);
    }
  }

  const BOT_REPLIES = {
    '澳洲学费怎么缴最省？': '缴澳洲学费建议优先用 Flywire——直达学校账户、到账稳定、部分学校合作免汇率差。大金额（>5万CNY）也可以考虑 Wise，真实中间汇率比银行牌价省约 0.5%。银行电汇虽然稳妥，但手续费 ¥150–300 加上汇率差，5万以上能差出好几百元。需要我帮你算一下具体差多少吗？',
    'Wise 安全吗？': 'Wise 非常安全！它是英国 FCA 持牌机构，在澳大利亚受 AUSTRAC 监管，客户资金存放在独立账户，与公司运营资金完全分开。全球每月处理超过 100 亿美元，是国际汇款领域最合规透明的平台之一。',
    '每月生活费用哪个渠道？': '月度生活费（5000–15000 CNY）用 Wise 最合适：✅ 真实中间汇率无隐藏加价，✅ App 操作简单可设定金额，✅ 1–2 工作日到账，✅ 手续费低（约 ¥9 起）。Remitly 首笔有新客优惠也可以试试。银行电汇手续费按笔收，频次高亏多。'
  };

  function widgetSend(preset) {
    const input = document.getElementById('widgetInput');
    const msgs = document.getElementById('widgetMsgs');
    const text = preset || input.value.trim();
    if (!text) return;

    // Remove quick btns
    const qBtns = msgs.querySelector('.widget-quick-btns');
    if (qBtns) qBtns.remove();

    // User bubble
    const userMsg = document.createElement('div');
    userMsg.className = 'msg user';
    userMsg.textContent = text;
    msgs.appendChild(userMsg);
    input.value = '';
    msgs.scrollTop = msgs.scrollHeight;

    // Typing indicator
    const typing = document.createElement('div');
    typing.className = 'msg-typing';
    typing.innerHTML = '<div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div>';
    msgs.appendChild(typing);
    msgs.scrollTop = msgs.scrollHeight;

    // Bot reply
    setTimeout(() => {
      msgs.removeChild(typing);
      const reply = BOT_REPLIES[text] || '好的！请告诉我你想汇款的目标国家和大约金额，我来帮你比较哪条渠道最省钱。';
      const botMsg = document.createElement('div');
      botMsg.className = 'msg bot';
      botMsg.textContent = reply;
      msgs.appendChild(botMsg);
      msgs.scrollTop = msgs.scrollHeight;
    }, 1200);
  }

  // ---- SMOOTH SCROLL for nav links ----
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', e => {
      const target = document.querySelector(a.getAttribute('href'));
      if (target) {
        e.preventDefault();
        const offset = 80;
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });

  // ---- ARRIVAL BAR ANIMATE ----
  const arrivalObserver = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.querySelectorAll('.arrival-bar-fill').forEach(bar => {
          const w = bar.style.width;
          bar.style.width = '0';
          requestAnimationFrame(() => {
            requestAnimationFrame(() => { bar.style.width = w; });
          });
        });
        arrivalObserver.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('.arrival-cards').forEach(el => arrivalObserver.observe(el));
</script>