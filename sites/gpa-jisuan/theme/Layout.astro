}
.req-list li:last-child { border-bottom: none; }
.req-list .rl-name { color: var(--text-secondary); }
.req-list .rl-val {
  font-weight: 700;
  color: var(--text-primary);
}
.rl-val.high { color: var(--accent-dark); }
.rl-val.medium { color: #D97706; }

/* =============================================
   Advice — tips cards
   ============================================= */
.advice-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 20px;
}
.advice-card {
  background: var(--bg-card);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  position: relative;
  overflow: hidden;
  transition: box-shadow var(--transition), transform var(--transition);
}
.advice-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.advice-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
}
.advice-card.tip1::before { background: linear-gradient(90deg, var(--primary), var(--primary-light)); }
.advice-card.tip2::before { background: linear-gradient(90deg, var(--accent), #7EEFC0); }
.advice-card.tip3::before { background: linear-gradient(90deg, #F59E0B, #FCD34D); }
.advice-card .ac-num {
  font-size: 2rem;
  font-weight: 900;
  opacity: 0.07;
  position: absolute;
  top: 16px; right: 18px;
  color: var(--primary);
  line-height: 1;
}
.advice-card h3 {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 10px;
}
.advice-card p {
  font-size: 0.83rem;
  color: var(--text-secondary);
  line-height: 1.65;
}

/* =============================================
   FAQ
   ============================================= */
.faq-list { max-width: 760px; }
.faq-item {
  border: 1.5px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin-bottom: 10px;
  transition: box-shadow var(--transition);
}
.faq-item.open { box-shadow: var(--shadow-sm); }
.faq-q {
  padding: 18px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  user-select: none;
  background: var(--bg-card);
  transition: background var(--transition);
}
.faq-q:hover { background: var(--bg-section-alt); }
.faq-q span {
  font-size: 0.9rem;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
  padding-right: 16px;
}
.faq-chevron {
  width: 20px; height: 20px;
  flex-shrink: 0;
  color: var(--text-muted);
  transition: transform var(--transition);
}
.faq-item.open .faq-chevron { transform: rotate(180deg); color: var(--primary); }
.faq-a {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1), padding var(--transition);
  background: var(--bg-card);
}
.faq-item.open .faq-a { max-height: 300px; }
.faq-a-inner {
  padding: 0 20px 18px;
  font-size: 0.85rem;
  color: var(--text-secondary);
  line-height: 1.7;
  border-top: 1px solid var(--border);
}

/* =============================================
   Editorial picks
   ============================================= */
.picks-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
  gap: 20px;
}
.pick-card {
  background: var(--bg-card);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  transition: box-shadow var(--transition), transform var(--transition);
  cursor: pointer;
}
.pick-card:hover {
  box-shadow: var(--shadow-card-hover);
  transform: translateY(-3px);
}
.pick-img {
  width: 100%;
  aspect-ratio: 16/8;
  background: var(--bg-section-alt);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
  position: relative;
  overflow: hidden;
}
.pick-img-gradient {
  position: absolute;
  inset: 0;
}
.pick-img-gradient.g1 { background: linear-gradient(135deg, #27348B22, #22A06B22); }
.pick-img-gradient.g2 { background: linear-gradient(135deg, #22A06B22, #27348B22); }
.pick-img-gradient.g3 { background: linear-gradient(135deg, #F59E0B22, #22A06B22); }
.pick-img-emoji { position: relative; z-index: 1; }
.pick-body { padding: 18px 20px; }
.pick-tag {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: 100px;
  font-size: 0.68rem;
  font-weight: 700;
  background: var(--bg-section-alt);
  color: var(--primary);
  margin-bottom: 10px;
}
.pick-body h3 {
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 8px;
}
.pick-body p {
  font-size: 0.78rem;
  color: var(--text-secondary);
  line-height: 1.6;
}
.pick-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 20px;
  border-top: 1px solid var(--border);
}
.pick-date {
  font-size: 0.7rem;
  color: var(--text-muted);
}
.pick-read {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--primary);
  display: flex;
  align-items: center;
  gap: 4px;
  transition: gap var(--transition);
}
.pick-card:hover .pick-read { gap: 8px; }

/* =============================================
   CTA Banner
   ============================================= */
.cta-banner {
  background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 60%, var(--accent-dark) 100%);
  border-radius: var(--radius-xl);
  padding: 52px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 32px;
  position: relative;
  overflow: hidden;
}
.cta-banner::before {
  content: '';
  position: absolute;
  width: 300px; height: 300px;
  background: rgba(255,255,255,0.04);
  border-radius: 50%;
  top: -100px; right: -80px;
}
.cta-banner::after {
  content: '';
  position: absolute;
  width: 200px; height: 200px;
  background: rgba(34,160,107,0.12);
  border-radius: 50%;
  bottom: -80px; left: 40px;
}
.cta-text { color: #fff; position: relative; z-index: 1; }
.cta-text h2 {
  font-size: clamp(1.3rem, 2.5vw, 1.8rem);
  font-weight: 800;
  margin-bottom: 10px;
  letter-spacing: -0.01em;
}
.cta-text p {
  font-size: 0.9rem;
  opacity: 0.8;
  line-height: 1.6;
}
.cta-actions {
  display: flex;
  gap: 12px;
  flex-shrink: 0;
  position: relative;
  z-index: 1;
}
.btn-white {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #fff;
  color: var(--primary);
  font-weight: 700;
  font-size: 0.9rem;
  padding: 13px 24px;
  border-radius: var(--radius-md);
  transition: transform var(--transition), box-shadow var(--transition);
  min-height: 46px;
}
.btn-white:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(0,0,0,0.15);
}
.btn-outline-white {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1.5px solid rgba(255,255,255,0.45);
  color: rgba(255,255,255,0.9);
  font-weight: 600;
  font-size: 0.88rem;
  padding: 12px 20px;
  border-radius: var(--radius-md);
  transition: background var(--transition), border-color var(--transition);
  min-height: 46px;
}
.btn-outline-white:hover {
  background: rgba(255,255,255,0.1);
  border-color: rgba(255,255,255,0.7);
}

/* =============================================
   Footer
   ============================================= */
.footer {
  background: var(--text-primary);
  color: rgba(255,255,255,0.7);
  padding: 56px clamp(20px, 5vw, 60px) 28px;
}
.footer-inner {
  max-width: 1200px;
  margin: 0 auto;
}
.footer-top {
  display: grid;
  grid-template-columns: 1.4fr repeat(3, 1fr);
  gap: 40px;
