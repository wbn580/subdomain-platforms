---
// 雅思培训排名 · Bespoke Layout
import { siteConfig } from '../../../src/lib/site';

const { title, description, ogImage } = Astro.props;
const brand = siteConfig.brand || '雅思培训排名';
const pageTitle = title || brand;
const pageDesc = description || '雅思培训机构横向排名/比价';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
{ogImage && <meta property="og:image" content={ogImage} />}
<style is:global>
/* ===== CSS VARIABLES (design tokens) ===== */
    :root {
      --primary: #1E3A8A;
      --primary-dark: #152A6A;
      --primary-light: #3B5CB8;
      --accent: #F59E0B;
      --accent-dark: #D97706;
      --accent-light: #FCD34D;
      --neutral-50: #F8FAFF;
      --neutral-100: #EEF2FF;
      --neutral-200: #E2E8F0;
      --neutral-300: #CBD5E1;
      --neutral-400: #94A3B8;
      --neutral-500: #64748B;
      --neutral-600: #475569;
      --neutral-700: #334155;
      --neutral-800: #1E293B;
      --neutral-900: #0F172A;
      --success: #10B981;
      --font-stack: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "Noto Sans SC", "Source Han Sans SC", "Helvetica Neue", Arial, sans-serif;
      --radius-sm: 6px;
      --radius-md: 12px;
      --radius-lg: 20px;
      --radius-xl: 28px;
      --shadow-sm: 0 1px 4px rgba(30,58,138,0.08);
      --shadow-md: 0 4px 16px rgba(30,58,138,0.12);
      --shadow-lg: 0 12px 40px rgba(30,58,138,0.16);
      --shadow-xl: 0 24px 60px rgba(30,58,138,0.20);
      --transition: 180ms cubic-bezier(0.4,0,0.2,1);
    }

    /* ===== RESET & BASE ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; font-size: 16px; }
    body {
      font-family: var(--font-stack);
      color: var(--neutral-800);
      background: #fff;
      line-height: 1.6;
      overflow-x: hidden;
    }
    img { max-width: 100%; display: block; }
    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }

    /* ===== SCROLL REVEAL ===== */
    .reveal {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.55s ease, transform 0.55s ease;
    }
    .reveal.visible { opacity: 1; transform: none; }
    @media (prefers-reduced-motion: reduce) {
      .reveal { opacity: 1; transform: none; transition: none; }
    }

    /* ===== NAVBAR ===== */
    .navbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      padding: 0 5%;
      height: 68px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: transparent;
      transition: background var(--transition), box-shadow var(--transition), backdrop-filter var(--transition);
    }
    .navbar.scrolled {
      background: rgba(30,58,138,0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: 0 2px 16px rgba(30,58,138,0.22);
    }
    .nav-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      color: #fff;
      font-size: 1.15rem;
      font-weight: 700;
      letter-spacing: -0.01em;
    }
    .nav-brand .brand-icon {
      width: 36px; height: 36px;
      background: linear-gradient(135deg, var(--accent), var(--accent-dark));
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem;
    }
    .nav-links {
      display: flex;
      align-items: center;
      gap: 32px;
    }
    .nav-links a {
      color: rgba(255,255,255,0.88);
      font-size: 0.92rem;
      font-weight: 500;
      transition: color var(--transition);
      position: relative;
    }
    .nav-links a::after {
      content: '';
      position: absolute;
      bottom: -3px; left: 0; right: 0;
      height: 2px;
      background: var(--accent);
      transform: scaleX(0);
      transition: transform var(--transition);
    }
    .nav-links a:hover { color: #fff; }
    .nav-links a:hover::after { transform: scaleX(1); }
    .nav-cta {
      background: var(--accent);
      color: var(--primary-dark) !important;
      padding: 8px 20px;
      border-radius: var(--radius-sm);
      font-weight: 700 !important;
      font-size: 0.88rem !important;
      transition: background var(--transition), transform var(--transition) !important;
    }
    .nav-cta::after { display: none !important; }
    .nav-cta:hover { background: var(--accent-dark) !important; transform: translateY(-1px); }
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      cursor: pointer;
      padding: 6px;
    }
    .hamburger span {
      display: block;
      width: 24px; height: 2px;
      background: #fff;
      border-radius: 2px;
      transition: all 0.25s ease;
    }
    .hamburger.active span:nth-child(1) { transform: rotate(45deg) translate(5px,5px); }
    .hamburger.active span:nth-child(2) { opacity: 0; }
    .hamburger.active span:nth-child(3) { transform: rotate(-45deg) translate(5px,-5px); }

    /* ===== MOBILE NAV ===== */
    .mobile-nav {
      display: none;
      position: fixed;
      top: 68px; left: 0; right: 0;
      background: rgba(30,58,138,0.98);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      z-index: 99;
      padding: 20px 5% 28px;
      flex-direction: column;
      gap: 0;
      transform: translateY(-100%);
      opacity: 0;
      transition: transform 0.28s ease, opacity 0.28s ease;
    }
    .mobile-nav.open { transform: translateY(0); opacity: 1; }
    .mobile-nav a {
      color: rgba(255,255,255,0.9);
      font-size: 1rem;
      font-weight: 500;
      padding: 14px 0;
      border-bottom: 1px solid rgba(255,255,255,0.08);
      transition: color var(--transition);
    }
    .mobile-nav a:last-child { border-bottom: none; }
    .mobile-nav a:hover { color: var(--accent); }
    .mobile-nav .mob-cta {
      margin-top: 16px;
      background: var(--accent);
      color: var(--primary-dark);
      text-align: center;
      padding: 14px;
      border-radius: var(--radius-sm);
      font-weight: 700;
      font-size: 1rem;
    }

    /* ===== HERO ===== */
    .hero {
      position: relative;
      height: 100vh;
      min-height: 620px;
      max-height: 960px;
      display: flex;
      align-items: center;
      overflow: hidden;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('https://images.pexels.com/photos/5649522/pexels-photo-5649522.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=1080&w=1920');
      background-size: cover;
      background-position: center 30%;
      transform: scale(1.04);
      transition: transform 6s ease;
    }
    .hero-bg.loaded { transform: scale(1); }
    .hero-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        135deg,
        rgba(14,22,66,0.88) 0%,
        rgba(30,58,138,0.72) 50%,
        rgba(14,22,66,0.55) 100%
      );
    }
    .hero-content {
      position: relative;
      z-index: 2;
      max-width: 1160px;
      margin: 0 auto;
      padding: 0 5%;
      color: #fff;
    }
    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(245,158,11,0.18);
      border: 1px solid rgba(245,158,11,0.4);
      color: var(--accent-light);
      font-size: 0.82rem;
      font-weight: 600;
      padding: 6px 14px;
      border-radius: 100px;
      margin-bottom: 24px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .hero-badge::before {
      content: '';
      width: 6px; height: 6px;
      background: var(--accent);
      border-radius: 50%;
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%,100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.4); }
    }
    .hero h1 {
      font-size: clamp(2.2rem, 5vw, 4rem);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.03em;
      margin-bottom: 20px;
    }
    .hero h1 em {
      font-style: normal;
      color: var(--accent);
    }
    .hero-sub {
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: rgba(255,255,255,0.82);
      max-width: 580px;
      line-height: 1.7;
      margin-bottom: 36px;
    }
    .hero-ctas {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 56px;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--accent);
      color: var(--primary-dark);
      font-weight: 700;
      font-size: 0.98rem;
      padding: 14px 28px;
      border-radius: var(--radius-sm);
      border: none;
      cursor: pointer;
      transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
    }
    .btn-primary:hover {
      background: var(--accent-dark);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(245,158,11,0.35);
    }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: transparent;
      color: rgba(255,255,255,0.9);
      font-weight: 600;
      font-size: 0.95rem;
      padding: 14px 28px;
      border-radius: var(--radius-sm);
      border: 1.5px solid rgba(255,255,255,0.35);
      cursor: pointer;
      transition: border-color var(--transition), color var(--transition), background var(--transition);
    }
    .btn-secondary:hover {
      border-color: rgba(255,255,255,0.7);
      background: rgba(255,255,255,0.08);
      color: #fff;
    }
    .hero-stats {
      display: flex;
      gap: 40px;
      flex-wrap: wrap;
    }
    .hero-stat { text-align: left; }
    .hero-stat .num {
      display: block;
      font-size: 2rem;
      font-weight: 800;
      color: var(--accent);
      line-height: 1;
      letter-spacing: -0.02em;
    }
    .hero-stat .label {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.65);
      margin-top: 4px;
    }
    .hero-scroll {
      position: absolute;
      bottom: 36px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      color: rgba(255,255,255,0.5);
      font-size: 0.75rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      animation: bounce 2.5s ease-in-out infinite;
    }
    @keyframes bounce {
      0%,100% { transform: translateX(-50%) translateY(0); }
      50% { transform: translateX(-50%) translateY(8px); }
    }

    /* ===== SECTION COMMON ===== */
    section { padding: 88px 5%; }
    .section-inner { max-width: 1160px; margin: 0 auto; }
    .section-header { text-align: center; margin-bottom: 56px; }
    .section-eyebrow {
      display: inline-block;
      color: var(--primary);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .section-eyebrow.accent { color: var(--accent-dark); }
    .section-title {
      font-size: clamp(1.6rem, 3vw, 2.4rem);
      font-weight: 800;
      color: var(--neutral-900);
      letter-spacing: -0.025em;
      line-height: 1.25;
      margin-bottom: 16px;
    }
    .section-desc {
      font-size: 1rem;
      color: var(--neutral-500);
      max-width: 560px;
      margin: 0 auto;
      line-height: 1.75;
    }

    /* ===== RANKING SECTION ===== */
    #ranking { background: var(--neutral-50); }
    .ranking-filter {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: center;
      margin-bottom: 40px;
    }
    .filter-btn {
      padding: 8px 20px;
      border-radius: 100px;
      border: 1.5px solid var(--neutral-200);
      background: #fff;
      color: var(--neutral-600);
      font-size: 0.87rem;
      font-weight: 600;
      cursor: pointer;
      transition: all var(--transition);
    }
    .filter-btn:hover, .filter-btn.active {
      background: var(--primary);
      border-color: var(--primary);
      color: #fff;
    }
    .ranking-list { display: flex; flex-direction: column; gap: 16px; }
    .ranking-card {
      background: #fff;
      border-radius: var(--radius-lg);
      padding: 28px 32px;
      display: grid;
      grid-template-columns: 56px 1fr auto;
      gap: 0 24px;
      align-items: center;
      box-shadow: var(--shadow-sm);
      border: 1.5px solid var(--neutral-100);
      transition: transform var(--transition), box-shadow var(--transition);
      position: relative;
      overflow: hidden;
    }
    .ranking-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 4px;
      background: var(--neutral-200);
      transition: background var(--transition);
    }
    .ranking-card:hover {
      transform: translateY(-3px);
      box-shadow: var(--shadow-lg);
    }
    .ranking-card:hover::before { background: var(--primary); }
    .ranking-card.top-1::before { background: var(--accent); }
    .ranking-card.top-2::before { background: var(--neutral-400); }
    .ranking-card.top-3::before { background: #CD7F32; }
    .rank-num {
      font-size: 2rem;
      font-weight: 800;
      color: var(--neutral-300);
      text-align: center;
      line-height: 1;
    }
    .ranking-card.top-1 .rank-num { color: var(--accent); }
    .ranking-card.top-2 .rank-num { color: var(--neutral-500); }
    .ranking-card.top-3 .rank-num { color: #CD7F32; }
    .rank-info h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--neutral-900);
      margin-bottom: 6px;
    }
    .rank-info .rank-tags {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }
    .rank-tag {
      font-size: 0.75rem;
      font-weight: 600;
      padding: 3px 10px;
      border-radius: 100px;
      background: var(--neutral-100);
      color: var(--neutral-600);
    }
    .rank-tag.highlight {
      background: rgba(245,158,11,0.12);
      color: var(--accent-dark);
    }
    .rank-info .rank-desc {
      font-size: 0.87rem;
      color: var(--neutral-500);
      line-height: 1.6;
    }
    .rank-meta {
      text-align: right;
      flex-shrink: 0;
    }
    .rank-score {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      background: var(--primary);
      color: #fff;
      padding: 10px 18px;
      border-radius: var(--radius-md);
    }
    .rank-score .score-val {
      font-size: 1.5rem;
      font-weight: 800;
      line-height: 1;
    }
    .rank-score .score-label {
      font-size: 0.68rem;
      opacity: 0.75;
      margin-top: 3px;
    }
    .ranking-card.top-1 .rank-score { background: linear-gradient(135deg, var(--accent), var(--accent-dark)); color: var(--primary-dark); }
    .stars {
      color: var(--accent);
      font-size: 0.85rem;
      margin-top: 8px;
    }
    .ranking-note {
      text-align: center;
      color: var(--neutral-400);
      font-size: 0.8rem;
      margin-top: 28px;
    }
    .ranking-note a { color: var(--primary); font-weight: 600; }

    /* ===== SKILLS SECTION (听说读写) ===== */
    #skills { background: #fff; }
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }
    .skill-card {
      background: linear-gradient(160deg, var(--neutral-50) 0%, #fff 100%);
      border: 1.5px solid var(--neutral-100);
      border-radius: var(--radius-lg);
      padding: 36px 28px;
      text-align: center;
      transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
      position: relative;
      overflow: hidden;
    }
    .skill-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: var(--primary);
      transform: scaleX(0);
      transition: transform var(--transition);
    }
    .skill-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-xl);
      border-color: var(--primary-light);
    }
    .skill-card:hover::after { transform: scaleX(1); }
    .skill-icon {
      width: 64px; height: 64px;
      margin: 0 auto 20px;
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      border-radius: 18px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem;
    }
    .skill-card:nth-child(2) .skill-icon { background: linear-gradient(135deg, var(--accent), var(--accent-dark)); }
    .skill-card:nth-child(3) .skill-icon { background: linear-gradient(135deg, #6366F1, #4F46E5); }
    .skill-card:nth-child(4) .skill-icon { background: linear-gradient(135deg, var(--success), #059669); }
    .skill-card h3 {
      font-size: 1.15rem;
      font-weight: 700;
      color: var(--neutral-900);
      margin-bottom: 10px;
    }
    .skill-card p {
      font-size: 0.87rem;
      color: var(--neutral-500);
      line-height: 1.7;
      margin-bottom: 20px;
    }
    .skill-score-bar {
      background: var(--neutral-100);
      border-radius: 100px;
      height: 6px;
      overflow: hidden;
      margin-bottom: 8px;
    }
    .skill-score-fill {
      height: 100%;
      border-radius: 100px;
      background: linear-gradient(90deg, var(--primary), var(--primary-light));
      transition: width 1.2s cubic-bezier(0.4,0,0.2,1);
    }
    .skill-card:nth-child(2) .skill-score-fill { background: linear-gradient(90deg, var(--accent), var(--accent-dark)); }
    .skill-card:nth-child(3) .skill-score-fill { background: linear-gradient(90deg, #6366F1, #818CF8); }
    .skill-card:nth-child(4) .skill-score-fill { background: linear-gradient(90deg, var(--success), #34D399); }
    .skill-score-label {
      display: flex;
      justify-content: space-between;
      font-size: 0.75rem;
      color: var(--neutral-400);
    }
    .skill-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      color: var(--primary);
      font-size: 0.87rem;
      font-weight: 600;
      margin-top: 18px;
      transition: gap var(--transition);
    }
    .skill-link:hover { gap: 10px; }

    /* ===== SCORE CURVE SECTION ===== */
    #score-method {
      background: linear-gradient(160deg, var(--primary) 0%, var(--primary-dark) 100%);
      color: #fff;
    }
    #score-method .section-title { color: #fff; }
    #score-method .section-desc { color: rgba(255,255,255,0.65); }
    #score-method .section-eyebrow { color: var(--accent-light); }
    .methods-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }
    .method-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: var(--radius-lg);
      padding: 32px;
      transition: background var(--transition), border-color var(--transition), transform var(--transition);
    }
    .method-card:hover {
      background: rgba(255,255,255,0.12);
      border-color: rgba(255,255,255,0.25);
      transform: translateY(-3px);
    }
    .method-num {
      width: 44px; height: 44px;
      border-radius: 12px;
      background: var(--accent);
      color: var(--primary-dark);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
      font-weight: 800;
      margin-bottom: 16px;
    }
    .method-card h3 {
      font-size: 1.1rem;
      font-weight: 700;
      margin-bottom: 10px;
    }
    .method-card p {
      font-size: 0.87rem;
      color: rgba(255,255,255,0.7);
      line-height: 1.7;
    }
    .score-curve-visual {
      margin: 56px auto 0;
      max-width: 800px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: var(--radius-xl);
      padding: 40px;
    }
    .curve-title {
      font-size: 0.85rem;
      color: rgba(255,255,255,0.5);
      text-align: center;
      margin-bottom: 24px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .curve-canvas {
      width: 100%;
      height: 140px;
      position: relative;
    }
    .curve-svg { width: 100%; height: 100%; }
    .curve-labels {
      display: flex;
      justify-content: space-between;
      margin-top: 12px;
      padding: 0 4px;
    }
    .curve-label {
      text-align: center;
      font-size: 0.78rem;
      color: rgba(255,255,255,0.5);
    }
    .curve-label strong {
      display: block;
      color: rgba(255,255,255,0.9);
      font-size: 0.92rem;
      font-weight: 700;
    }

    /* ===== SELF VS CLASS SECTION ===== */
    #compare { background: var(--neutral-50); }
    .compare-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      max-width: 900px;
      margin: 0 auto;
    }
    .compare-card {
      background: #fff;
      border-radius: var(--radius-lg);
      padding: 36px;
      box-shadow: var(--shadow-sm);
      border: 2px solid var(--neutral-100);
      transition: border-color var(--transition), box-shadow var(--transition);
    }
    .compare-card:hover { border-color: var(--primary-light); box-shadow: var(--shadow-lg); }
