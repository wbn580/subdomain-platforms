  font-size: 24px;
  flex-shrink: 0;
}
.method-card-icon.primary { background: rgba(156,74,46,.1); }
.method-card-icon.accent  { background: rgba(52,73,94,.1); }
.method-card-title { font-size: 18px; font-weight: 800; color: var(--text-primary); margin-bottom: 4px; }
