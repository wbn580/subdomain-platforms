<script>
// ---- NAV SCROLL ----
  const nav = document.getElementById('mainNav');
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 40);
    document.getElementById('backTop').classList.toggle('visible', window.scrollY > 400);
  }, { passive: true });

  // ---- HERO IMAGE LOAD ----
  const heroImg = document.getElementById('heroImg');
  const img = new Image();
  img.onload = () => heroImg.classList.add('loaded');
  img.src = 'https://images.pexels.com/photos/1117410/pexels-photo-1117410.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1080&fit=crop';

  // ---- HAMBURGER / MOBILE MENU ----
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');

  hamburger.addEventListener('click', () => {
    const open = hamburger.classList.toggle('active');
    hamburger.setAttribute('aria-expanded', open);
    mobileMenu.classList.toggle('open', open);
    mobileMenu.setAttribute('aria-hidden', !open);
  });

  function closeMobileMenu() {
    hamburger.classList.remove('active');
    hamburger.setAttribute('aria-expanded', 'false');
    mobileMenu.classList.remove('open');
    mobileMenu.setAttribute('aria-hidden', 'true');
  }

  // ---- SCROLL REVEAL ----
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((e, i) => {
      if (e.isIntersecting) {
        // Stagger reveal for grouped items
        const siblings = e.target.parentElement.querySelectorAll('.reveal:not(.in-view)');
        siblings.forEach((el, idx) => {
          setTimeout(() => el.classList.add('in-view'), idx * 90);
        });
        e.target.classList.add('in-view');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // ---- FAQ ACCORDION ----
  function toggleFaq(btn) {
    const item = btn.closest('.faq-item');
    const wasOpen = item.classList.contains('open');
    // Close all
    document.querySelectorAll('.faq-item.open').forEach(i => {
      i.classList.remove('open');
      i.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
    });
    // Toggle clicked
    if (!wasOpen) {
      item.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    }
  }

  // ---- CHAT WIDGET ----
  let chatOpen = false;

  function toggleChat() {
    chatOpen = !chatOpen;
    document.getElementById('chatPanel').classList.toggle('open', chatOpen);
    document.getElementById('chatBubble').setAttribute('aria-expanded', chatOpen);
  }

  function closeChat() {
    chatOpen = false;
    document.getElementById('chatPanel').classList.remove('open');
    document.getElementById('chatBubble').setAttribute('aria-expanded', 'false');
  }

  function sendChatMsg() {
    const inp = document.querySelector('.chat-input');
    const val = inp.value.trim();
    if (!val) return;
    const msgs = document.querySelector('.chat-messages');
    const userBubble = document.createElement('div');
    userBubble.className = 'chat-bubble-msg';
    userBubble.style.cssText = 'align-self:flex-end;border-radius:16px 16px 4px 16px;background:var(--primary);color:white;';
    userBubble.textContent = val;
    msgs.appendChild(userBubble);
    msgs.scrollTop = msgs.scrollHeight;
    inp.value = '';
  }

  // ---- BACK TO TOP ----
  function scrollToTop() {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ---- SMOOTH ANCHOR SCROLL ----
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function(e) {
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        closeMobileMenu();
      }
    });
  });
</script>

