<div id="chat-widget" role="complementary" aria-label="在线助手">
  <div id="chat-bubble" onclick="toggleChat()" aria-label="打开在线助手" aria-expanded="false" tabindex="0" role="button" onkeydown="if(event.key==='Enter')toggleChat()">
    <span class="chat-online-dot" aria-hidden="true"></span>
    <span id="chat-bubble-icon">🧮</span>
  </div>

  <div id="chat-panel" role="dialog" aria-modal="false" aria-label="jisuan 在线助手">
    <div class="chat-panel-header">
      <div class="chat-panel-avatar" aria-hidden="true">🤖</div>
      <div class="chat-panel-info">
        <div class="chat-panel-name">计算助手</div>
        <div class="chat-panel-status">在线，即时回复</div>
      </div>
      <button class="chat-close" onclick="toggleChat()" aria-label="关闭助手">✕</button>
    </div>
    <div class="chat-messages" id="chat-messages" aria-live="polite">
      <div class="chat-msg-bot" id="initial-msg">
        想算啲咩？留学费用、GPA 换算、落户积分、月供……话我知，帮你找对工具！😊
