      <button class="chat-qb" role="listitem" onclick="chatQuick('我想算留学费用')">🎓 留学费用</button>
      <button class="chat-qb" role="listitem" onclick="chatQuick('GPA怎么换算')">📊 GPA换算</button>
      <button class="chat-qb" role="listitem" onclick="chatQuick('算贷款月供')">🏠 月供计算</button>
