        <polygon class="score-line" points="170,60 235,77 233,182 170,215 107,182 107,77"/>
        <!-- dots -->
        <circle class="score-dot" cx="170" cy="60" r="4"/>
        <circle class="score-dot" cx="235" cy="77" r="4"/>
        <circle class="score-dot" cx="233" cy="182" r="4"/>
        <circle class="score-dot" cx="170" cy="215" r="4"/>
        <circle class="score-dot" cx="107" cy="182" r="4"/>
        <circle class="score-dot" cx="107" cy="77" r="4"/>
        <!-- labels -->
        <text class="rlabel" x="170" y="46" text-anchor="middle">录取率</text>
        <text class="rlabel" x="248" y="74" text-anchor="start">院校合作</text>
        <text class="rlabel" x="248" y="192" text-anchor="start">满意度</text>
        <text class="rlabel" x="170" y="232" text-anchor="middle">资质认证</text>
        <text class="rlabel" x="86" y="192" text-anchor="end">费用透明</text>
        <text class="rlabel" x="86" y="74" text-anchor="end">顾问专业度</text>
        <!-- center label -->
        <text font-family="-apple-system, sans-serif" font-size="10" fill="#13294B" font-weight="700" x="170" y="140" text-anchor="middle">UNILINK</text>
        <text font-family="-apple-system, sans-serif" font-size="9" fill="#D4AF37" x="170" y="152" text-anchor="middle">综合 96.8</text>
      </svg>
    </div>
  </div>
</section>

