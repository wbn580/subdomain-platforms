---
// 月供计算器 · Bespoke Layout
import { siteConfig } from '../../../src/lib/site';

const { title, description, ogImage } = Astro.props;
const brand = siteConfig.brand || '月供计算器';
const pageTitle = title || brand;
const pageDesc = description || '房贷/车贷等额本息&本金试算';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
{ogImage && <meta property="og:image" content={ogImage} />}
<style is:global>
/* ===== CSS CUSTOM PROPERTIES / DESIGN TOKENS — yuegong-jisuan ===== */
:root {
  --primary:       #9C4A2E;
  --primary-dark:  #7A3520;
  --primary-light: #C46140;
  --accent:        #34495E;
  --accent-light:  #4A6278;
  --accent-dark:   #243545;

  --bg:            #FAFAF8;
  --bg-warm:       #F5F1EE;
  --bg-card:       #FFFFFF;
  --surface:       #F0EBE7;

  --text-primary:  #1E1C1A;
  --text-secondary:#4A4540;
  --text-muted:    #7A7470;
  --text-light:    #A09890;

  --border:        #E0D9D4;
  --border-strong: #C8BEB8;
  --divider:       #EDE7E2;

  --shadow-xs:  0 1px 3px rgba(30,20,15,.06);
  --shadow-sm:  0 2px 8px rgba(30,20,15,.08);
  --shadow-md:  0 4px 20px rgba(30,20,15,.10);
  --shadow-lg:  0 8px 40px rgba(30,20,15,.13);
  --shadow-xl:  0 20px 60px rgba(30,20,15,.16);

  --radius-sm:  6px;
  --radius-md:  12px;
  --radius-lg:  20px;
  --radius-xl:  28px;

  --font-sans: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei",
               "Noto Sans SC", "Source Han Sans SC", "Helvetica Neue", Arial, sans-serif;

  --transition: 150ms ease;
  --transition-md: 250ms ease;
}

/* ===== RESET & BASE ===== */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  font-family: var(--font-sans);
  color: var(--text-primary);
  background: var(--bg);
  line-height: 1.6;
  overflow-x: hidden;
}
img { max-width: 100%; display: block; }
a { color: inherit; text-decoration: none; }
button { cursor: pointer; font-family: inherit; border: none; background: none; }
input, select { font-family: inherit; }

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { transition-duration: .01ms !important; animation-duration: .01ms !important; }
  html { scroll-behavior: auto; }
}

/* ===== SCROLL REVEAL ===== */
.reveal {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity .6s ease, transform .6s ease;
}
.reveal.visible { opacity: 1; transform: none; }
.reveal-delay-1 { transition-delay: .08s; }
.reveal-delay-2 { transition-delay: .16s; }
.reveal-delay-3 { transition-delay: .24s; }
.reveal-delay-4 { transition-delay: .32s; }

/* ===== CONTAINER ===== */
.container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }

/* ===== SECTION SCAFFOLDING ===== */
.section { padding: 80px 0; }
.section-label {
  font-size: 12px; font-weight: 700;
  color: var(--primary);
  letter-spacing: .1em; text-transform: uppercase;
  margin-bottom: 10px;
}
.section-title {
  font-size: clamp(26px, 3.5vw, 40px);
  font-weight: 800; color: var(--text-primary);
  letter-spacing: -.02em;
  line-height: 1.2;
  margin-bottom: 14px;
}
.section-subtitle {
  font-size: 16px; color: var(--text-secondary);
  max-width: 540px;
  line-height: 1.65;
}

/* ===== NAVIGATION ===== */
#navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  padding: 0 32px;
  height: 68px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background var(--transition-md), box-shadow var(--transition-md), backdrop-filter var(--transition-md);
}
#navbar.transparent {
  background: rgba(0,0,0,.12);
  backdrop-filter: blur(2px);
}
#navbar.scrolled {
  background: rgba(255,255,255,.97);
  backdrop-filter: blur(20px);
  box-shadow: var(--shadow-sm);
}
.nav-logo {
  display: flex; align-items: center; gap: 10px;
  font-weight: 700; font-size: 18px;
  color: #FFF;
  transition: color var(--transition);
}
#navbar.scrolled .nav-logo { color: var(--text-primary); }
.nav-logo-icon {
  width: 38px; height: 38px;
  background: var(--primary);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}
.nav-links {
  display: flex; align-items: center; gap: 28px;
  list-style: none;
}
.nav-links a {
  font-size: 14px; font-weight: 500;
  color: rgba(255,255,255,.85);
  transition: color var(--transition);
}
.nav-links a:hover { color: #FFF; }
#navbar.scrolled .nav-links a { color: var(--text-secondary); }
#navbar.scrolled .nav-links a:hover { color: var(--primary); }
.nav-cta {
  padding: 8px 20px;
  background: var(--primary);
  color: #FFF !important;
  border-radius: var(--radius-sm);
  font-weight: 600;
  font-size: 14px;
  transition: background var(--transition), transform var(--transition);
}
.nav-cta:hover { background: var(--primary-dark) !important; transform: translateY(-1px); }

/* Hamburger */
.hamburger {
  display: none;
  flex-direction: column; gap: 5px;
  padding: 8px;
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: background var(--transition);
}
.hamburger:hover { background: rgba(255,255,255,.1); }
#navbar.scrolled .hamburger:hover { background: var(--surface); }
.hamburger span {
  display: block; width: 24px; height: 2px;
  background: #FFF;
  border-radius: 2px;
  transition: transform var(--transition-md), opacity var(--transition-md), background var(--transition-md);
}
#navbar.scrolled .hamburger span { background: var(--text-primary); }
.hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hamburger.open span:nth-child(2) { opacity: 0; }
.hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile menu */
.mobile-menu {
  display: none;
  position: fixed; top: 68px; left: 0; right: 0; z-index: 999;
  background: rgba(255,255,255,.98);
  backdrop-filter: blur(20px);
  padding: 20px 24px 28px;
  box-shadow: var(--shadow-lg);
  border-top: 1px solid var(--border);
  flex-direction: column; gap: 4px;
  transform: translateY(-10px); opacity: 0;
  transition: transform var(--transition-md), opacity var(--transition-md);
}
.mobile-menu.open {
  display: flex; transform: none; opacity: 1;
}
.mobile-menu a {
  padding: 12px 16px;
  font-size: 15px; font-weight: 500;
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  transition: background var(--transition), color var(--transition);
}
.mobile-menu a:hover { background: var(--surface); color: var(--primary); }
.mobile-menu .m-cta {
  margin-top: 8px;
  padding: 13px 16px;
  background: var(--primary);
  color: #FFF !important;
  text-align: center;
  border-radius: var(--radius-sm);
  font-weight: 600;
}
.mobile-menu .m-cta:hover { background: var(--primary-dark) !important; }

@media (max-width: 768px) {
  .nav-links, .nav-cta { display: none; }
  .hamburger { display: flex; }
  #navbar { padding: 0 20px; }
}

/* ===== HERO ===== */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 100px 24px 60px;
}
.hero-bg {
  position: absolute; inset: 0; z-index: 0;
  background: url('https://images.pexels.com/photos/7031604/pexels-photo-7031604.jpeg?auto=compress&cs=tinysrgb&w=1920') center/cover no-repeat;
}
.hero-overlay {
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(
    135deg,
    rgba(28,18,12,.80) 0%,
    rgba(52,73,94,.72) 50%,
    rgba(20,12,8,.75) 100%
  );
}
.hero-content {
  position: relative; z-index: 2;
  max-width: 860px;
  width: 100%;
  text-align: center;
  margin-bottom: 40px;
}
.hero-badge {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 6px 14px;
  background: rgba(156,74,46,.35);
  border: 1px solid rgba(156,74,46,.5);
  border-radius: 100px;
  font-size: 12px; font-weight: 600;
  color: rgba(255,255,255,.9);
  letter-spacing: .04em;
  text-transform: uppercase;
  margin-bottom: 20px;
}
.hero-badge-dot {
  width: 6px; height: 6px;
  background: #C4614A;
  border-radius: 50%;
  animation: pulse-dot 2s infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: .5; transform: scale(.7); }
}
.hero h1 {
  font-size: clamp(36px, 6vw, 68px);
  font-weight: 800;
  color: #FFF;
  line-height: 1.15;
  letter-spacing: -.02em;
  margin-bottom: 16px;
}
.hero h1 em { font-style: normal; color: #E8836A; }
.hero-sub {
  font-size: clamp(16px, 2vw, 19px);
  color: rgba(255,255,255,.75);
  max-width: 560px;
  margin: 0 auto 32px;
  font-weight: 400;
  line-height: 1.65;
}
.hero-meta {
  display: flex; align-items: center; justify-content: center; gap: 24px;
  flex-wrap: wrap;
}
.hero-meta-item {
  display: flex; align-items: center; gap: 6px;
  font-size: 13px; color: rgba(255,255,255,.65);
  font-weight: 500;
}
.hero-meta-icon { font-size: 14px; }

/* ===== CALCULATOR CARD ===== */
.calc-wrapper {
  position: relative; z-index: 2;
  width: 100%;
  max-width: 900px;
}
.calc-card {
  background: rgba(255,255,255,.98);
  backdrop-filter: blur(20px);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-xl);
  overflow: hidden;
}
.calc-header {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  padding: 22px 32px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  flex-wrap: wrap;
}
.calc-header-left { display: flex; align-items: center; gap: 12px; }
.calc-header-icon {
  width: 42px; height: 42px;
  background: rgba(255,255,255,.18);
  border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
}
.calc-header h2 {
  font-size: 18px; font-weight: 700; color: #FFF;
  letter-spacing: -.01em;
}
.calc-header p { font-size: 13px; color: rgba(255,255,255,.75); margin-top: 2px; }

/* Loan type tabs */
.loan-type-tabs {
  display: flex;
  background: rgba(255,255,255,.15);
  border-radius: var(--radius-sm);
  padding: 3px;
  gap: 3px;
}
.loan-tab {
  padding: 7px 18px;
  border-radius: 6px;
  font-size: 13px; font-weight: 600;
  color: rgba(255,255,255,.75);
  transition: background var(--transition), color var(--transition);
  cursor: pointer;
  white-space: nowrap;
}
.loan-tab.active {
  background: #FFF;
  color: var(--primary);
}
.loan-tab:hover:not(.active) { color: #FFF; background: rgba(255,255,255,.1); }

/* Calc body */
.calc-body {
  padding: 32px;
  display: grid;
  grid-template-columns: 1fr 1.15fr;
  gap: 32px;
}
@media (max-width: 768px) {
  .calc-body { grid-template-columns: 1fr; padding: 24px; gap: 24px; }
}

/* Inputs side */
.calc-inputs { display: flex; flex-direction: column; gap: 22px; }
.field-group { display: flex; flex-direction: column; gap: 7px; }
.field-label {
  font-size: 13px; font-weight: 600;
  color: var(--text-secondary);
  letter-spacing: .01em;
  display: flex; justify-content: space-between; align-items: center;
}
.field-unit {
  font-weight: 400; color: var(--text-muted);
  font-size: 12px;
}
.field-input-wrap {
  position: relative;
  display: flex; align-items: center;
}
.field-prefix {
  position: absolute; left: 14px;
  font-size: 15px; font-weight: 600;
  color: var(--text-muted);
  pointer-events: none;
  user-select: none;
}
.field-input {
  width: 100%;
  padding: 12px 14px 12px 30px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 16px; font-weight: 600;
  color: var(--text-primary);
  background: var(--bg);
  transition: border-color var(--transition), box-shadow var(--transition), background var(--transition);
  font-variant-numeric: tabular-nums;
  -moz-appearance: textfield;
}
.field-input::-webkit-outer-spin-button,
.field-input::-webkit-inner-spin-button { -webkit-appearance: none; }
.field-input:focus {
  outline: none;
  border-color: var(--primary);
  background: #FFF;
  box-shadow: 0 0 0 3px rgba(156,74,46,.12);
}
.field-input.error { border-color: #DC3545; box-shadow: 0 0 0 3px rgba(220,53,69,.12); }

/* Loan method radio */
.method-group {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
}
.method-option {
  position: relative;
}
.method-option input[type="radio"] {
  position: absolute; opacity: 0; width: 0; height: 0;
}
.method-label {
  display: flex; flex-direction: column; align-items: center; gap: 4px;
  padding: 14px 12px;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: border-color var(--transition), background var(--transition), box-shadow var(--transition);
  text-align: center;
}
.method-label:hover { border-color: var(--primary-light); background: rgba(156,74,46,.04); }
.method-option input:checked + .method-label {
  border-color: var(--primary);
  background: rgba(156,74,46,.06);
  box-shadow: 0 0 0 3px rgba(156,74,46,.10);
}
.method-emoji { font-size: 20px; }
.method-name { font-size: 13px; font-weight: 700; color: var(--text-primary); }
.method-desc { font-size: 11px; color: var(--text-muted); line-height: 1.4; }

/* Calc button */
.calc-btn {
  padding: 15px 28px;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #FFF;
  border-radius: var(--radius-sm);
  font-size: 16px; font-weight: 700;
  width: 100%;
  transition: transform var(--transition), box-shadow var(--transition), filter var(--transition);
  letter-spacing: -.01em;
}
.calc-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(156,74,46,.35);
  filter: brightness(1.05);
}
.calc-btn:active { transform: translateY(0); box-shadow: none; }
.calc-disclaimer {
  font-size: 11px; color: var(--text-light);
  line-height: 1.5; margin-top: 10px;
}

/* Results side */
.calc-results {
  display: flex; flex-direction: column; gap: 16px;
}

/* Monthly payment hero */
.result-hero {
  background: linear-gradient(135deg, #F9F3EF 0%, #F0EAE4 100%);
  border: 1px solid rgba(156,74,46,.15);
  border-radius: var(--radius-lg);
  padding: 24px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.result-hero::before {
  content: '';
  position: absolute; top: -30px; right: -30px;
  width: 100px; height: 100px;
  background: rgba(156,74,46,.06);
  border-radius: 50%;
}
.result-label {
  font-size: 12px; font-weight: 700;
  color: var(--primary);
  letter-spacing: .08em;
  text-transform: uppercase;
  margin-bottom: 8px;
}
.result-amount {
  font-size: clamp(30px, 4vw, 42px);
  font-weight: 800;
  color: var(--text-primary);
  letter-spacing: -.03em;
  font-variant-numeric: tabular-nums;
  line-height: 1;
}
.result-amount .currency { font-size: 55%; font-weight: 600; color: var(--text-muted); vertical-align: super; margin-right: 2px; }
.result-amount .unit { font-size: 40%; font-weight: 500; color: var(--text-muted); margin-left: 4px; }
.result-note { font-size: 12px; color: var(--text-muted); margin-top: 6px; }

/* Summary stats */
.result-stats {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
}
.stat-card {
  background: #FFF;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 14px 16px;
  transition: box-shadow var(--transition), transform var(--transition);
}
.stat-card:hover { box-shadow: var(--shadow-sm); transform: translateY(-1px); }
.stat-name { font-size: 11px; font-weight: 600; color: var(--text-muted); letter-spacing: .04em; text-transform: uppercase; margin-bottom: 6px; }
.stat-val { font-size: 17px; font-weight: 700; color: var(--text-primary); font-variant-numeric: tabular-nums; }
.stat-val.interest { color: #C04020; }
.stat-val.principal { color: #2D6A4F; }

/* Composition bar */
.composition-bar-wrap { display: flex; flex-direction: column; gap: 10px; }
.comp-bar-title { font-size: 12px; font-weight: 700; color: var(--text-secondary); letter-spacing: .04em; text-transform: uppercase; }
.comp-bar {
  height: 12px;
  border-radius: 100px;
  background: var(--border);
  overflow: hidden;
  position: relative;
}
.comp-bar-principal {
  height: 100%;
  border-radius: 100px;
  background: linear-gradient(90deg, #2D6A4F, #52B788);
  transition: width .7s cubic-bezier(.25,.46,.45,.94);
  position: absolute; left: 0; top: 0;
}
.comp-bar-interest {
  height: 100%;
  border-radius: 100px;
  background: linear-gradient(90deg, #C04020, #E86A50);
  position: absolute; top: 0;
  transition: left .7s cubic-bezier(.25,.46,.45,.94), width .7s cubic-bezier(.25,.46,.45,.94);
}
.comp-legend {
  display: flex; gap: 16px;
  font-size: 11px; color: var(--text-muted);
}
.comp-legend-item { display: flex; align-items: center; gap: 5px; }
.comp-dot { width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0; }
.comp-dot.p { background: #52B788; }
.comp-dot.i { background: #E86A50; }

/* Amortization toggle */
.amort-toggle {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12px 16px;
  background: var(--bg-warm);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: background var(--transition), border-color var(--transition);
  user-select: none;
}
.amort-toggle:hover { background: var(--surface); border-color: var(--primary-light); }
.amort-toggle-text { font-size: 13px; font-weight: 600; color: var(--text-secondary); }
.amort-chevron {
  font-size: 14px; color: var(--text-muted);
  transition: transform var(--transition-md);
}
.amort-chevron.open { transform: rotate(180deg); }

/* Amortization container */
.amort-container {
  display: none;
  max-height: 340px;
  overflow-y: auto;
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  scrollbar-width: thin;
  scrollbar-color: var(--border-strong) transparent;
}
.amort-container::-webkit-scrollbar { width: 5px; }
.amort-container::-webkit-scrollbar-track { background: transparent; }
.amort-container::-webkit-scrollbar-thumb { background: var(--border-strong); border-radius: 3px; }
.amort-container.visible { display: block; }

.amort-header-row {
  display: grid; grid-template-columns: 48px 1fr 1fr 1fr 1fr;
  padding: 10px 16px;
  background: var(--accent);
  font-size: 11px; font-weight: 700;
  color: rgba(255,255,255,.85);
  letter-spacing: .04em; text-transform: uppercase;
  position: sticky; top: 0; z-index: 2;
}
.amort-row {
  display: grid; grid-template-columns: 48px 1fr 1fr 1fr 1fr;
  padding: 9px 16px;
  font-size: 12px;
  border-bottom: 1px solid var(--divider);
  transition: background var(--transition);
  font-variant-numeric: tabular-nums;
}
.amort-row:last-child { border-bottom: none; }
.amort-row:hover { background: rgba(156,74,46,.04); }
.amort-row .month { color: var(--text-muted); font-weight: 600; }
.amort-row .pay { font-weight: 700; color: var(--text-primary); }
.amort-row .int { color: #C04020; }
.amort-row .prin { color: #2D6A4F; }
.amort-row .bal { color: var(--text-secondary); }

/* Result placeholder */
.result-placeholder {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  gap: 12px; padding: 40px 20px;
  text-align: center;
}
.result-placeholder-icon { font-size: 48px; opacity: .35; }
.result-placeholder-text { font-size: 14px; color: var(--text-muted); font-weight: 500; }

/* ===== STATS RIBBON ===== */
.stats-ribbon {
  background: var(--accent-dark);
  padding: 28px 0;
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: rgba(255,255,255,.08);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.stats-item {
  background: var(--accent-dark);
  padding: 24px 20px;
  text-align: center;
  transition: background var(--transition);
}
.stats-item:hover { background: var(--accent); }
.stats-num {
  font-size: 28px; font-weight: 800;
  color: #FFF;
  letter-spacing: -.03em;
  font-variant-numeric: tabular-nums;
  line-height: 1;
  margin-bottom: 6px;
}
.stats-num span { font-size: 55%; font-weight: 500; color: rgba(255,255,255,.7); }
.stats-label {
  font-size: 12px; font-weight: 500;
