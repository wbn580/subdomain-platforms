    <button class="widget-send" onclick="sendMsg()" aria-label="发送消息">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 8l12-6-4 6 4 6-12-6z" fill="currentColor"/></svg>
    </button>
  </div>
