  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.footer-brand h3 {
  font-size: 1.1rem;
  font-weight: 800;
  color: #fff;
  margin-bottom: 10px;
}
.footer-brand p {
  font-size: 0.8rem;
  line-height: 1.7;
  max-width: 240px;
}
.footer-col h4 {
  font-size: 0.8rem;
  font-weight: 700;
  color: rgba(255,255,255,0.9);
