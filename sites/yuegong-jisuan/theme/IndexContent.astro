'use strict';

// ── Utility ──────────────────────────────────────────────────────────────────
const fmt = (n) => Math.round(n).toLocaleString('zh-CN');
const fmtDec = (n, d=2) => n.toLocaleString('zh-CN', {minimumFractionDigits:d, maximumFractionDigits:d});

// ── Loan type state ───────────────────────────────────────────────────────────
let currentMethod = 'equal-payment';

function switchTab(method) {
  currentMethod = method;
  document.querySelectorAll('.loan-tab').forEach(t => {
    t.classList.toggle('active', t.id === 'tab-' + method);
    t.setAttribute('aria-selected', t.id === 'tab-' + method);
  });
  document.querySelectorAll('input[name="method"]').forEach(r => {
    r.checked = r.value === method;
  });
  calculate();
}

// ── Core Calculation ──────────────────────────────────────────────────────────
function calculate() {
  const P  = parseFloat(document.getElementById('loan-amount').value) || 0;
  const yr = parseFloat(document.getElementById('annual-rate').value) || 0;
  const yrs= parseFloat(document.getElementById('loan-years').value)  || 0;

  // Validate
  const amtEl  = document.getElementById('loan-amount');
  const ratEl  = document.getElementById('annual-rate');
  const yrsEl  = document.getElementById('loan-years');
  amtEl.classList.remove('error'); ratEl.classList.remove('error'); yrsEl.classList.remove('error');

  if (!P || P <= 0) { amtEl.classList.add('error'); showPlaceholder('请输入有效的贷款金额'); return; }
  if (!yr || yr <= 0 || yr > 30) { ratEl.classList.add('error'); showPlaceholder('请输入 0.01%–30% 范围内的年利率'); return; }
  if (!yrs || yrs < 1 || yrs > 50) { yrsEl.classList.add('error'); showPlaceholder('请输入 1–50 年范围内的年限'); return; }

  const r = yr / 100 / 12;     // monthly rate
  const n = Math.round(yrs * 12); // total months

  let schedule = [];

  if (currentMethod === 'equal-payment') {
    // 等额本息: M = P * r * (1+r)^n / [(1+r)^n - 1]
    const factor = Math.pow(1 + r, n);
    const M = P * r * factor / (factor - 1);
    let balance = P;
    for (let i = 1; i <= n; i++) {
      const interest  = balance * r;
      const principal = M - interest;
      balance -= principal;
      schedule.push({
        month:     i,
        payment:   M,
        interest:  interest,
        principal: principal,
        balance:   Math.max(0, balance)
      });
    }
    const totalPay   = M * n;
    const totalInt   = totalPay - P;
    renderResults(M, M, P, totalInt, totalPay, schedule, '等额本息');
  } else {
    // 等额本金: 每月本金 = P/n; 当月利息 = 余额 × r
    const monthlyPrincipal = P / n;
    let balance = P;
    let firstPay = 0;
    let totalInt = 0;
    for (let i = 1; i <= n; i++) {
      const interest = balance * r;
      const payment  = monthlyPrincipal + interest;
      balance       -= monthlyPrincipal;
      totalInt      += interest;
      if (i === 1) firstPay = payment;
      schedule.push({
        month:     i,
        payment:   payment,
        interest:  interest,
        principal: monthlyPrincipal,
        balance:   Math.max(0, balance)
      });
    }
    const totalPay = P + totalInt;
    renderResults(firstPay, schedule[Math.floor(n/2)].payment, P, totalInt, totalPay, schedule, '等额本金');
  }
}

function showPlaceholder(msg) {
  document.getElementById('result-placeholder').style.display = 'flex';
  document.getElementById('result-placeholder').querySelector('.result-placeholder-text').textContent = msg;
  document.getElementById('amort-section').style.display = 'none';
}

function renderResults(firstPay, midPay, principal, totalInt, totalPay, schedule, methodLabel) {
  const rContainer = document.getElementById('calc-results');
  const pPct = (principal / totalPay * 100).toFixed(1);
  const iPct = (totalInt  / totalPay * 100).toFixed(1);
  const isEqualPayment = currentMethod === 'equal-payment';

  rContainer.innerHTML = `
    <div class="result-hero">
      <div class="result-label">${methodLabel} · 首月月供</div>
      <div class="result-amount">
        <span class="currency">¥</span>${fmt(firstPay)}<span class="unit">/月</span>
      </div>
      ${isEqualPayment
        ? `<div class="result-note">每月固定 ¥${fmt(firstPay)}，全程不变</div>`
        : `<div class="result-note">月供逐月递减，期中约 ¥${fmt(midPay)}/月</div>`
      }
    </div>

    <div class="result-stats">
      <div class="stat-card">
        <div class="stat-name">本金总额</div>
        <div class="stat-val principal">¥${fmt(principal)}</div>
      </div>
      <div class="stat-card">
        <div class="stat-name">总利息</div>
        <div class="stat-val interest">¥${fmt(totalInt)}</div>
      </div>
      <div class="stat-card">
        <div class="stat-name">还款总额</div>
        <div class="stat-val">¥${fmt(totalPay)}</div>
      </div>
      <div class="stat-card">
        <div class="stat-name">利息/本金比</div>
        <div class="stat-val">${fmtDec(totalInt/principal*100, 1)}%</div>
      </div>
    </div>

    <div class="composition-bar-wrap">
      <div class="comp-bar-title">还款构成</div>
      <div class="comp-bar" role="img" aria-label="本金 ${pPct}%，利息 ${iPct}%">
        <div class="comp-bar-principal" id="bar-principal" style="width:0%"></div>
        <div class="comp-bar-interest"  id="bar-interest"  style="left:0%;width:0%"></div>
      </div>
      <div class="comp-legend">
        <span class="comp-legend-item">
          <span class="comp-dot p" aria-hidden="true"></span>
          本金 ${pPct}%（¥${fmt(principal)}）
        </span>
        <span class="comp-legend-item">
          <span class="comp-dot i" aria-hidden="true"></span>
          利息 ${iPct}%（¥${fmt(totalInt)}）
        </span>
      </div>
    </div>
  `;

  // Animate bars after paint
  requestAnimationFrame(() => {
    requestAnimationFrame(() => {
      const barP = document.getElementById('bar-principal');
      const barI = document.getElementById('bar-interest');
      if (barP) barP.style.width = pPct + '%';
      if (barI) { barI.style.left = pPct + '%'; barI.style.width = iPct + '%'; }
    });
  });

  // Build amortization schedule
  buildAmortTable(schedule);
  document.getElementById('amort-section').style.display = 'block';
}

function buildAmortTable(schedule) {
  const container = document.getElementById('amort-container');
  container.innerHTML = `
    <div class="amort-header-row" role="row">
      <span role="columnheader">期数</span>
      <span role="columnheader">月供</span>
      <span role="columnheader">本金</span>
      <span role="columnheader">利息</span>
      <span role="columnheader" class="bal-h">剩余本金</span>
    </div>
  `;
  // Limit DOM to 360 rows max for performance
  const limit = Math.min(schedule.length, 360);
  const fragment = document.createDocumentFragment();
  for (let i = 0; i < limit; i++) {
    const row = schedule[i];
    const div = document.createElement('div');
    div.className = 'amort-row'; div.setAttribute('role','row');
    div.innerHTML = `
      <span class="month" role="cell">${row.month}</span>
      <span class="pay"   role="cell">¥${fmt(row.payment)}</span>
      <span class="prin"  role="cell">¥${fmt(row.principal)}</span>
      <span class="int"   role="cell">¥${fmt(row.interest)}</span>
      <span class="bal"   role="cell">¥${fmt(row.balance)}</span>
    `;
    fragment.appendChild(div);
  }
  container.appendChild(fragment);
  if (schedule.length > 360) {
    const note = document.createElement('div');
    note.style.cssText = 'padding:12px;text-align:center;font-size:12px;color:var(--text-muted)';
    note.textContent = `（仅显示前 360 期，共 ${schedule.length} 期）`;
    container.appendChild(note);
  }
}

// ── Amort toggle ──────────────────────────────────────────────────────────────
let amortOpen = false;
function toggleAmort() {
  amortOpen = !amortOpen;
  const c = document.getElementById('amort-container');
  const ch = document.getElementById('amort-chevron');
  const tg = document.getElementById('amort-toggle');
  const tt = document.getElementById('amort-toggle-text');
  c.classList.toggle('visible', amortOpen);
  ch.classList.toggle('open', amortOpen);
  tg.setAttribute('aria-expanded', amortOpen);
  tt.textContent = amortOpen ? '📋 收起还款计划表' : '📋 展开完整还款计划表';
}

// ── FAQ ───────────────────────────────────────────────────────────────────────
function toggleFaq(btn) {
  const item   = btn.closest('.faq-item');
  const answer = item.querySelector('.faq-answer');
  const isOpen = item.classList.contains('open');

  // Close all
  document.querySelectorAll('.faq-item.open').forEach(openItem => {
    openItem.classList.remove('open');
    openItem.querySelector('.faq-answer').style.maxHeight = '0';
    openItem.querySelector('.faq-question').setAttribute('aria-expanded','false');
  });

  if (!isOpen) {
    item.classList.add('open');
    answer.style.maxHeight = answer.scrollHeight + 'px';
    btn.setAttribute('aria-expanded','true');
  }
}

// ── Init: auto-calculate on load ──────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  calculate();
});
</script>
