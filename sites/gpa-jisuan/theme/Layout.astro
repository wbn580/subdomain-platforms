---
import { siteConfig } from '../../../src/lib/site';

const { title, description } = Astro.props;
const brand = siteConfig.brand || 'GPA 换算器';
const pageTitle = title || brand;
const pageDesc = description || '免费 GPA 换算工具：中国百分制、4分制、英式等第、德式制一键换算。支持多门课加权计算，留学申请必备。';
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{pageTitle}</title>
<meta name="description" content={pageDesc} />
<meta property="og:title" content="GPA 换算器 · 中外成绩一键换算" />
<meta property="og:description" content="支持中国百分制 ↔ 美式 4.0 ↔ 英式等第，加权 GPA 计算，留学申请必备工具。" />
<style is:global>
/* =============================================
   CSS Variables — Design Token System
   ============================================= */
:root {
  --primary: #27348B;
  --primary-dark: #1B2468;
  --primary-light: #3D4FA8;
  --accent: #22A06B;
  --accent-dark: #178A56;
  --accent-light: #2EBD7E;

  --bg-page: #F7F8FC;
  --bg-card: #FFFFFF;
  --bg-section-alt: #EEF0F9;

  --text-primary: #1A1D2E;
  --text-secondary: #4A4F6B;
  --text-muted: #8B91B0;
  --text-on-primary: #FFFFFF;

  --border: #DDE1F0;
  --border-focus: #27348B;
  --shadow-sm: 0 1px 4px rgba(39,52,139,0.08);
  --shadow-md: 0 4px 16px rgba(39,52,139,0.12);
  --shadow-lg: 0 8px 32px rgba(39,52,139,0.16);
  --shadow-card-hover: 0 8px 28px rgba(39,52,139,0.18);

  --radius-sm: 6px;
  --radius-md: 12px;
  --radius-lg: 20px;
  --radius-xl: 28px;

  --font-stack: -apple-system, BlinkMacSystemFont, "PingFang SC",
                "Microsoft YaHei", "Noto Sans SC", "Source Han Sans SC",
                "Helvetica Neue", Arial, sans-serif;

  --nav-h: 68px;
  --transition: 180ms cubic-bezier(0.4,0,0.2,1);
}

/* =============================================
   Reset & Base
   ============================================= */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  font-family: var(--font-stack);
  background: var(--bg-page);
  color: var(--text-primary);
  line-height: 1.75;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}
a { color: inherit; text-decoration: none; }
img { max-width: 100%; display: block; }
button { font-family: inherit; cursor: pointer; border: none; background: none; }

/* =============================================
   Navigation
   ============================================= */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  height: var(--nav-h);
  display: flex;
  align-items: center;
  padding: 0 clamp(20px, 5vw, 60px);
  transition: background var(--transition), box-shadow var(--transition),
              backdrop-filter var(--transition);
}
.nav.transparent {
  background: rgba(255,255,255,0.06);
  backdrop-filter: blur(2px);
}
.nav.solid {
  background: rgba(255,255,255,0.97);
  backdrop-filter: blur(16px);
  box-shadow: var(--shadow-sm);
}
.nav-inner {
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 32px;
}
.nav-logo {
  display: flex;
  align-items: center;
  gap: 10px;
  font-weight: 700;
  font-size: 1.1rem;
  letter-spacing: -0.01em;
}
.nav-logo .logo-icon {
  width: 36px; height: 36px;
  background: var(--primary);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 0.9rem;
  font-weight: 800;
  flex-shrink: 0;
  transition: transform var(--transition);
}
.nav.transparent .nav-logo .logo-text { color: #fff; }
.nav.solid .nav-logo .logo-text { color: var(--primary); }
.nav.transparent .logo-icon { background: rgba(255,255,255,0.2); }
.nav.solid .logo-icon { background: var(--primary); }
.nav-links {
  display: flex;
  gap: 4px;
  list-style: none;
  margin-left: auto;
}
.nav-links a {
  padding: 6px 14px;
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
  font-weight: 500;
  transition: background var(--transition), color var(--transition);
}
.nav.transparent .nav-links a { color: rgba(255,255,255,0.88); }
.nav.transparent .nav-links a:hover {
  background: rgba(255,255,255,0.14);
  color: #fff;
}
.nav.solid .nav-links a { color: var(--text-secondary); }
.nav.solid .nav-links a:hover {
  background: var(--bg-section-alt);
  color: var(--primary);
}
.nav-cta {
  padding: 8px 20px !important;
  background: var(--accent) !important;
  color: #fff !important;
  border-radius: var(--radius-md) !important;
  font-weight: 600 !important;
  font-size: 0.875rem !important;
  transition: background var(--transition), transform var(--transition), box-shadow var(--transition) !important;
}
.nav-cta:hover {
  background: var(--accent-dark) !important;
  transform: translateY(-1px);
  box-shadow: 0 4px 12px rgba(34,160,107,0.35) !important;
}
.hamburger {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 8px;
  margin-left: auto;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: background var(--transition);
}
.hamburger span {
  width: 22px; height: 2px;
  border-radius: 2px;
  transition: background var(--transition), transform var(--transition), opacity var(--transition);
}
.nav.transparent .hamburger span { background: #fff; }
.nav.solid .hamburger span { background: var(--text-primary); }
.hamburger:hover { background: rgba(255,255,255,0.1); }
.mobile-menu {
  display: none;
  position: fixed;
  top: var(--nav-h);
  left: 0; right: 0;
  background: rgba(255,255,255,0.97);
  backdrop-filter: blur(16px);
  box-shadow: var(--shadow-md);
  padding: 16px 24px 24px;
  z-index: 999;
  border-top: 1px solid var(--border);
  flex-direction: column;
  gap: 4px;
}
.mobile-menu.open { display: flex; }
.mobile-menu a {
  padding: 12px 16px;
  border-radius: var(--radius-sm);
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--text-secondary);
  transition: background var(--transition), color var(--transition);
}
.mobile-menu a:hover {
  background: var(--bg-section-alt);
  color: var(--primary);
}
.mobile-menu .nav-cta {
  margin-top: 8px;
  text-align: center;
  background: var(--accent) !important;
  color: #fff !important;
}

/* =============================================
   Hero
   ============================================= */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  inset: 0;
  background-image: url('https://images.pexels.com/photos/8197508/pexels-photo-8197508.jpeg?auto=compress&cs=tinysrgb&w=1920&h=1280&fit=crop');
  background-size: cover;
  background-position: center 30%;
  will-change: transform;
}
.hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    135deg,
    rgba(27,36,104,0.88) 0%,
    rgba(39,52,139,0.72) 45%,
    rgba(15,50,60,0.65) 100%
  );
}
.hero-content {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 1200px;
  margin: 0 auto;
  padding: calc(var(--nav-h) + 48px) clamp(20px, 5vw, 60px) 80px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
}
.hero-text { color: #fff; }
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(34,160,107,0.2);
  border: 1px solid rgba(34,160,107,0.4);
  color: #7EEFC0;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 5px 14px;
  border-radius: 100px;
  margin-bottom: 20px;
}
.hero-badge::before {
  content: '';
  width: 6px; height: 6px;
  background: #22A06B;
  border-radius: 50%;
  animation: pulse-dot 2s infinite;
}
@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.7); }
}
.hero-title {
  font-size: clamp(2rem, 4.5vw, 3.4rem);
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin-bottom: 18px;
}
.hero-title .accent-line {
  display: block;
  background: linear-gradient(90deg, #22A06B, #7EEFC0);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-sub {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.8);
  line-height: 1.7;
  max-width: 480px;
  margin-bottom: 32px;
}
.hero-actions {
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
}
.btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--accent);
  color: #fff;
  font-weight: 700;
  font-size: 0.95rem;
  padding: 14px 28px;
  border-radius: var(--radius-md);
  transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
  min-height: 48px;
}
.btn-primary:hover {
  background: var(--accent-dark);
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(34,160,107,0.4);
}
.btn-primary:active { transform: translateY(0); }
.btn-ghost {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1.5px solid rgba(255,255,255,0.4);
  color: rgba(255,255,255,0.9);
  font-weight: 600;
  font-size: 0.9rem;
  padding: 13px 24px;
  border-radius: var(--radius-md);
  transition: border-color var(--transition), background var(--transition), color var(--transition);
  min-height: 48px;
}
.btn-ghost:hover {
  border-color: rgba(255,255,255,0.8);
  background: rgba(255,255,255,0.1);
  color: #fff;
}
.hero-stats {
  display: flex;
  gap: 28px;
  margin-top: 40px;
  flex-wrap: wrap;
}
.hero-stat { color: rgba(255,255,255,0.85); }
.hero-stat strong {
  display: block;
  font-size: 1.5rem;
  font-weight: 800;
  color: #fff;
  letter-spacing: -0.02em;
  line-height: 1.2;
}
.hero-stat span { font-size: 0.78rem; opacity: 0.7; }

/* =============================================
   Hero Calculator Card
   ============================================= */
.hero-calc-card {
  background: rgba(255,255,255,0.97);
  border-radius: var(--radius-xl);
  padding: 28px;
  box-shadow: 0 20px 60px rgba(10,20,80,0.3);
  position: relative;
  z-index: 2;
}
.calc-card-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 20px;
}
.calc-icon {
  width: 40px; height: 40px;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 1.1rem;
  flex-shrink: 0;
}
.calc-title-group { flex: 1; }
.calc-title-group h3 {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
}
.calc-title-group p {
  font-size: 0.75rem;
  color: var(--text-muted);
  margin-top: 2px;
}

/* Course table (div-based grid, no <table>) */
.course-grid {
  width: 100%;
  margin-bottom: 14px;
}
.course-row-header {
  display: grid;
  grid-template-columns: 1fr 72px 56px 36px;
  gap: 4px;
  padding: 0 4px 8px;
  border-bottom: 1.5px solid var(--border);
  margin-bottom: 2px;
}
.course-th {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  text-align: left;
}
.course-th:last-child { text-align: center; }
.course-row {
  display: grid;
  grid-template-columns: 1fr 72px 56px 36px;
  gap: 4px;
  padding: 4px 0;
  align-items: center;
}
.course-input {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 7px 10px;
  font-family: var(--font-stack);
  font-size: 0.82rem;
  color: var(--text-primary);
  background: var(--bg-page);
  transition: border-color var(--transition), box-shadow var(--transition);
  min-height: 36px;
}
.course-input:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(39,52,139,0.1);
  background: #fff;
}
.course-input::placeholder { color: var(--text-muted); }
.del-btn {
  width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  border-radius: 6px;
  color: var(--text-muted);
  margin: 0 auto;
  transition: background var(--transition), color var(--transition);
}
.del-btn:hover { background: #FEE2E2; color: #EF4444; }
.add-course-btn {
  width: 100%;
  padding: 9px;
  border: 1.5px dashed var(--border);
  border-radius: var(--radius-sm);
  color: var(--text-muted);
  font-size: 0.82rem;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  transition: border-color var(--transition), color var(--transition), background var(--transition);
  margin-bottom: 16px;
  min-height: 36px;
}
.add-course-btn:hover {
  border-color: var(--primary);
  color: var(--primary);
  background: var(--bg-section-alt);
}
.calc-scale-select {
  width: 100%;
  border: 1.5px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 8px 12px;
  font-family: var(--font-stack);
  font-size: 0.82rem;
  color: var(--text-primary);
  background: var(--bg-page);
  margin-bottom: 14px;
  cursor: pointer;
  transition: border-color var(--transition);
  min-height: 38px;
}
.calc-scale-select:focus {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 3px rgba(39,52,139,0.1);
}
.calc-btn {
  width: 100%;
  padding: 12px;
  background: linear-gradient(135deg, var(--primary), var(--primary-light));
  color: #fff;
  font-weight: 700;
  font-size: 0.9rem;
  border-radius: var(--radius-md);
  transition: opacity var(--transition), transform var(--transition), box-shadow var(--transition);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  min-height: 44px;
}
.calc-btn:hover {
  opacity: 0.92;
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(39,52,139,0.35);
}
.calc-btn:active { transform: translateY(0); }

/* Result panel */
.calc-result {
  margin-top: 16px;
  display: none;
}
.calc-result.visible { display: block; }
.result-divider {
  height: 1px;
  background: var(--border);
  margin-bottom: 16px;
}
.result-grades {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 14px;
}
.grade-badge {
  border-radius: var(--radius-md);
  padding: 12px 10px;
  text-align: center;
}
.grade-badge.pct { background: #EEF0F9; }
.grade-badge.gpa4 { background: linear-gradient(135deg, #EEF0F9, #E4E8F6); }
.grade-badge.uk { background: linear-gradient(135deg, #E6F9F3, #D2F3E7); }
.grade-badge .gb-label {
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 6px;
}
.grade-badge.pct .gb-label { color: var(--primary); }
.grade-badge.gpa4 .gb-label { color: var(--primary-dark); }
.grade-badge.uk .gb-label { color: var(--accent-dark); }
.grade-badge .gb-value {
  font-size: 1.5rem;
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -0.02em;
}
.grade-badge.pct .gb-value { color: var(--primary); }
.grade-badge.gpa4 .gb-value { color: var(--primary-dark); }
.grade-badge.uk .gb-value { color: var(--accent); }
.grade-badge .gb-sub {
  font-size: 0.7rem;
  color: var(--text-muted);
  margin-top: 3px;
}
/* Scale bar */
.scale-bar-wrap {
  background: var(--bg-page);
  border-radius: var(--radius-sm);
  padding: 12px 14px;
  margin-bottom: 10px;
}
.scale-bar-label {
  display: flex;
  justify-content: space-between;
  font-size: 0.7rem;
  color: var(--text-muted);
  margin-bottom: 6px;
}
.scale-bar-track {
  height: 8px;
  border-radius: 4px;
  background: var(--border);
  overflow: visible;
  position: relative;
}
.scale-bar-fill {
  height: 100%;
  border-radius: 4px;
  background: linear-gradient(90deg, var(--primary), var(--accent));
  transition: width 0.5s cubic-bezier(0.4,0,0.2,1);
  position: relative;
}
.scale-bar-thumb {
  position: absolute;
  right: -6px; top: -4px;
  width: 16px; height: 16px;
  background: #fff;
  border: 2.5px solid var(--primary);
  border-radius: 50%;
  box-shadow: 0 2px 6px rgba(39,52,139,0.25);
  transition: transform var(--transition);
}
.scale-markers {
  display: flex;
  justify-content: space-between;
  font-size: 0.65rem;
  color: var(--text-muted);
  margin-top: 5px;
}
.disclaimer-note {
  font-size: 0.68rem;
  color: var(--text-muted);
  text-align: center;
  margin-top: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
}
.disclaimer-note a { color: var(--primary); text-decoration: underline; text-decoration-style: dotted; }

/* =============================================
   Section scaffold
   ============================================= */
.section {
  padding: 72px clamp(20px, 5vw, 60px);
}
.section-inner {
  max-width: 1200px;
  margin: 0 auto;
}
.section-label {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 10px;
}
.section-title {
  font-size: clamp(1.5rem, 3vw, 2.2rem);
  font-weight: 800;
  color: var(--text-primary);
  line-height: 1.25;
  letter-spacing: -0.02em;
  margin-bottom: 14px;
}
.section-desc {
  font-size: 1rem;
  color: var(--text-secondary);
  max-width: 580px;
  line-height: 1.7;
  margin-bottom: 40px;
}

/* =============================================
   Quick Look — conversion table (card grid, no table element)
   ============================================= */
.section.alt { background: var(--bg-section-alt); }
.conversion-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 14px;
}
.conv-card {
  background: var(--bg-card);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-md);
  padding: 18px 16px;
  transition: box-shadow var(--transition), transform var(--transition), border-color var(--transition);
}
.conv-card:hover {
  box-shadow: var(--shadow-card-hover);
  transform: translateY(-3px);
  border-color: var(--primary);
}
.conv-card .cc-pct {
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--primary);
  letter-spacing: -0.02em;
  line-height: 1;
}
.conv-card .cc-gpa {
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--text-secondary);
  margin-top: 6px;
}
.conv-card .cc-uk {
  display: inline-flex;
  align-items: center;
  margin-top: 8px;
  padding: 3px 10px;
  border-radius: 100px;
  font-size: 0.72rem;
  font-weight: 700;
}
.cc-uk.first { background: #D1FAE5; color: #065F46; }
.cc-uk.upper-second { background: #DBEAFE; color: #1E40AF; }
.cc-uk.lower-second { background: #FEF3C7; color: #92400E; }
.cc-uk.third { background: #F3F4F6; color: #374151; }
.conv-card .cc-note {
  font-size: 0.68rem;
  color: var(--text-muted);
  margin-top: 8px;
  line-height: 1.4;
}

/* =============================================
   Standard explanations — icon cards
   ============================================= */
.standards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 20px;
}
.standard-card {
  background: var(--bg-card);
  border: 1.5px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  transition: box-shadow var(--transition), transform var(--transition);
}
.standard-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}
.standard-card .sc-icon {
  width: 44px; height: 44px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  margin-bottom: 14px;
}
.sc-icon.blue { background: #EEF0F9; }
.sc-icon.green { background: #E6F9F3; }
.sc-icon.orange { background: #FEF3C7; }
.sc-icon.purple { background: #F3E8FF; }
.standard-card h3 {
