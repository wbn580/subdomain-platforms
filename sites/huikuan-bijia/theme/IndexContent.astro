          <div class="provider-logo" style="background:linear-gradient(135deg,#FF5C3A,#E03A20);" aria-hidden="true">R</div>
          <div>
            <div class="provider-name">Remitly</div>
            <div class="provider-sub">速汇档位灵活 · 首笔优惠</div>
          </div>
        </div>
        <div class="provider-stat">
          <div class="provider-stat-value">0.35%</div>
          <div class="provider-stat-label">综合汇率优势</div>
        </div>
        <div class="provider-stat">
          <div class="provider-stat-value">≈¥25/笔</div>
          <div class="provider-stat-label">手续费（参考）</div>
        </div>
        <div class="provider-stat">
          <div class="provider-stat-value">1–3天</div>
          <div class="provider-stat-label">预计到账</div>
        </div>
        <div class="provider-cta">
          <a href="#" class="btn-compare" aria-label="了解 Remitly 详情">了解详情</a>
        </div>
      </div>

      <!-- Bank Wire -->
      <div class="provider-card reveal reveal-delay-2" role="listitem" aria-label="银行电汇">
        <div class="provider-info">
          <div class="provider-logo" style="background:linear-gradient(135deg,#64748B,#475569);" aria-hidden="true">🏦</div>
          <div>
            <div class="provider-name">银行电汇（工行/建行）</div>
            <div class="provider-sub">传统通道 · 到账稳定</div>
          </div>
        </div>
        <div class="provider-stat">
          <div class="provider-stat-value">基准</div>
          <div class="provider-stat-label">汇率（银行牌价）</div>
        </div>
        <div class="provider-stat">
          <div class="provider-stat-value">¥150–300</div>
          <div class="provider-stat-label">手续费（参考）</div>
        </div>
        <div class="provider-stat">
          <div class="provider-stat-value">2–5天</div>
          <div class="provider-stat-label">预计到账</div>
        </div>
        <div class="provider-cta">
          <a href="#" class="btn-compare" aria-label="了解银行电汇详情">了解详情</a>
