<!-- ====================================================
     SECTION 3: COST & ANNUAL REVIEW
     ==================================================== -->
<section class="cost-section" id="cost" aria-labelledby="cost-heading">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-eyebrow">费用与年审</div>
      <h2 class="section-title" id="cost-heading">透明费用一览<br>无隐藏收费</h2>
      <p class="section-desc">注册到年度运营，每笔费用均列明出处，保障你的财务规划。</p>
    </div>

    <div class="cost-grid">
      <!-- Registration Fees Table -->
      <div class="reveal">
        <div class="cost-table-wrap">
          <div class="cost-table-title">注册费用（一次性）</div>
          <div class="cost-table-row">
            <span class="cost-table-row-label">政府注册费（CR）</span>
            <div class="cost-table-row-val">HK$1,720<span class="note">e-Registry 电子申请</span></div>
          </div>
          <div class="cost-table-row">
            <span class="cost-table-row-label">首年商业登记证</span>
            <div class="cost-table-row-val">HK$1,000<span class="note">税务局发出</span></div>
          </div>
          <div class="cost-table-row">
            <span class="cost-table-row-label">注册地址（秘书地址）</span>
            <div class="cost-table-row-val">HK$1,200 起/年<span class="note">需香港本地地址</span></div>
          </div>
          <div class="cost-table-row">
            <span class="cost-table-row-label">公司秘书服务</span>
            <div class="cost-table-row-val">HK$1,500 起/年<span class="note">持牌 TCSP 服务商</span></div>
          </div>
          <div class="cost-table-row">
            <span class="cost-table-row-label">公司章程草拟</span>
            <div class="cost-table-row-val">HK$800–2,000<span class="note">标准版或定制版</span></div>
          </div>
        </div>
      </div>

      <!-- Annual Review Box -->
      <div class="reveal">
        <div class="cost-table-wrap" style="margin-bottom: var(--sp-md);">
          <div class="cost-table-title">年度合规费用（持续性）</div>
          <div class="cost-table-row">
            <span class="cost-table-row-label">商业登记证续期</span>
            <div class="cost-table-row-val">HK$2,200/年</div>
          </div>
          <div class="cost-table-row">
            <span class="cost-table-row-label">周年申报（Annual Return）</span>
            <div class="cost-table-row-val">HK$105<span class="note">公司成立周年日起 42 天内</span></div>
          </div>
          <div class="cost-table-row">
            <span class="cost-table-row-label">审计报告（如适用）</span>
            <div class="cost-table-row-val">HK$6,000 起<span class="note">休眠公司可豁免</span></div>
          </div>
          <div class="cost-table-row">
            <span class="cost-table-row-label">利得税申报</span>
            <div class="cost-table-row-val">按税务顾问报价</div>
          </div>
        </div>

        <div class="cost-highlight-box">
          <h3>离岸收入可申请豁免税</h3>
          <p>香港采用「地域来源征税」原则——收入来源于香港境外，可向税务局申请离岸豁免（Offshore Claim），不缴利得税。适合主要业务在内地或国际的持股公司。</p>
          <div class="cost-annual-items">
            <div class="cost-annual-item">税务豁免申请费约 HK$5,000–15,000</div>
            <div class="cost-annual-item">批准后历年均可豁免</div>
            <div class="cost-annual-item">须保留交易凭证备查</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


