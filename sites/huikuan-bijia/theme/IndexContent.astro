    <div class="arrival-cards">
      <div class="arrival-card reveal">
        <div class="arrival-time-bar"><div class="arrival-bar-fill" style="background:var(--c-green);width:20%;"></div></div>
        <div class="arrival-icon" aria-hidden="true">⚡</div>
        <div class="arrival-provider">Wise</div>
        <div class="arrival-time fast">1–2天</div>
        <div class="arrival-label">工作日最快次日达</div>
      </div>
      <div class="arrival-card reveal reveal-delay-1">
        <div class="arrival-time-bar"><div class="arrival-bar-fill" style="background:var(--c-blue-light);width:35%;"></div></div>
        <div class="arrival-icon" aria-hidden="true">🔄</div>
        <div class="arrival-provider">Remitly</div>
        <div class="arrival-time fast">1–3天</div>
        <div class="arrival-label">速汇档可选加急</div>
      </div>
      <div class="arrival-card reveal reveal-delay-2">
        <div class="arrival-time-bar"><div class="arrival-bar-fill" style="background:var(--c-gold);width:60%;"></div></div>
        <div class="arrival-icon" aria-hidden="true">🏫</div>
        <div class="arrival-provider">Flywire</div>
        <div class="arrival-time">2–3天</div>
        <div class="arrival-label">直达学校账户</div>
      </div>
      <div class="arrival-card reveal reveal-delay-3">
        <div class="arrival-time-bar"><div class="arrival-bar-fill" style="background:var(--c-red);width:90%;"></div></div>
        <div class="arrival-icon" aria-hidden="true">🏦</div>
        <div class="arrival-provider">银行电汇</div>
        <div class="arrival-time slow">3–5天</div>
        <div class="arrival-label">受节假日影响较大</div>
