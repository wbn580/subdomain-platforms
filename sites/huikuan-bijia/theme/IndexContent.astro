    </p>

    <!-- Table header labels -->
    <div class="compare-header" aria-hidden="true">
      <div class="compare-header-item" style="text-align:left;">渠道</div>
      <div class="compare-header-item">综合汇率</div>
      <div class="compare-header-item">手续费</div>
      <div class="compare-header-item">到账时间</div>
