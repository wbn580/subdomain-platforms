// ── UTILS ──
function fmt(n){ return '¥'+Math.round(n/1000)+'万' }
function fmtFull(n){ return '¥'+n.toLocaleString('zh-CN') }

// ── TABS ──
function switchTab(el,panel){
  document.querySelectorAll('.calc-tab').forEach(t=>{ t.classList.remove('active'); t.setAttribute('aria-selected','false'); });
  el.classList.add('active'); el.setAttribute('aria-selected','true');
  document.getElementById('panelFull').style.display = panel==='full'?'':'none';
  document.getElementById('panelCompare').style.display = panel==='compare'?'':'none';
  document.getElementById('panelBudget').style.display = panel==='budget'?'':'none';
  if(panel==='compare') compare();
  if(panel==='budget') budgetCalc();
}

// ── COUNTRY CHANGE ──
function onCountryChange(){
  const cc = document.getElementById('country').value;
  const sel = document.getElementById('city');
  sel.innerHTML = '<option value="">请选择城市</option>';
  if(cc && COUNTRIES[cc]){
    COUNTRIES[cc].cities.forEach(c=>{ const o=document.createElement('option'); o.value=c; o.textContent=c; sel.appendChild(o); });
    sel.value = COUNTRIES[cc].cities[0];
  }
}

// ── CALCULATE ──
function calculate(){
  const cc = document.getElementById('country').value;
  const deg = document.getElementById('degree').value;
  const city = document.getElementById('city').value || (cc ? COUNTRIES[cc].cities[0] : '');
  const years = parseFloat(document.getElementById('years').value) || 2;
  if(!cc){ alert('请先选择目的国'); return; }
  const d = COUNTRIES[cc];
  const [tMin,tMax] = d.tuition[deg];
  const tuition = Math.round((tMin+tMax)/2) * years;
  const livingPerYear = d.living[city] || Object.values(d.living)[0];
  const living = Math.round(livingPerYear * years);
  const insPerYear = d.insurance[deg];
  const insurance = Math.round(insPerYear * years);
  const flight = d.flight; // one way first year only
  const total = tuition + living + insurance + flight;
  const amounts = [tuition, living, insurance, flight];
  showResult(total, amounts, cc, deg, city, years);
}

function showResult(total, amounts, cc, deg, city, years){
  document.getElementById('totalAmount').textContent = fmtFull(total);
  const degName = {bachelor:'本科',master:'硕士',phd:'博士',language:'语言学校'}[deg];
  document.getElementById('totalPeriod').textContent = `${COUNTRIES[cc].name} · ${city} · ${degName} · ${years} 年总费用`;
  // donut
  drawDonut(amounts, total);
  // breakdown
  const bl = document.getElementById('breakdownList');
  bl.innerHTML='';
  amounts.forEach((amt,i)=>{
    const pct = (amt/total*100).toFixed(1);
    bl.innerHTML+=`
      <div class="breakdown-item">
        <div class="breakdown-row">
          <div class="breakdown-dot-label">
            <div class="breakdown-dot" style="background:${COLORS[i]}"></div>
            <span class="breakdown-name">${ITEMS[i]}</span>
          </div>
          <div>
            <span class="breakdown-amount">${fmtFull(amt)}</span>
            <span class="breakdown-pct" style="margin-left:6px">${pct}%</span>
          </div>
        </div>
        <div class="bar-track"><div class="bar-fill" style="width:0%;background:${COLORS[i]}" data-width="${pct}"></div></div>
      </div>`;
  });
  document.getElementById('donutTopPct').textContent = (amounts[0]/total*100).toFixed(0)+'%';
  document.getElementById('calcNote').textContent = '数据仅供规划参考，实际以院校官方收费及生活为准。汇率区间用当前均值估算。';
  const panel = document.getElementById('resultPanel');
  panel.classList.add('visible');
  // animate bars
  requestAnimationFrame(()=>{ requestAnimationFrame(()=>{
    document.querySelectorAll('.bar-fill').forEach(b=>{ b.style.width = b.dataset.width+'%'; });
  });});
}

function drawDonut(amounts, total){
  const svg = document.getElementById('donutArcs');
  svg.innerHTML = '';
  const cx=100,cy=100,r=75,sw=28;
  const circ = 2*Math.PI*r;
  let offset = -circ/4; // start top
  amounts.forEach((amt,i)=>{
    const frac = amt/total;
    const dash = frac*circ - 2;
    const circle = document.createElementNS('http://www.w3.org/2000/svg','circle');
    circle.setAttribute('cx',cx); circle.setAttribute('cy',cy); circle.setAttribute('r',r);
    circle.setAttribute('fill','none'); circle.setAttribute('stroke',COLORS[i]);
    circle.setAttribute('stroke-width',sw);
    circle.setAttribute('stroke-dasharray', `${dash} ${circ-dash}`);
    circle.setAttribute('stroke-dashoffset', -offset);
    circle.setAttribute('stroke-linecap','round');
    circle.style.transition = 'stroke-dasharray 0.8s cubic-bezier(0.4,0,0.2,1)';
    svg.appendChild(circle);
    offset += frac*circ;
  });
}

// ── COMPARE ──
function compare(){
  const deg = document.getElementById('cmpDegree').value;
  const years = deg==='master' ? 1.5 : 3;
  const container = document.getElementById('compareTable');
  const sorted = Object.entries(COUNTRIES).map(([cc,d])=>{
    const [tMin,tMax]=d.tuition[deg];
    const tAvg = (tMin+tMax)/2*years;
    const lAvg = Object.values(d.living).reduce((a,b)=>a+b,0)/Object.values(d.living).length*years;
    const ins = d.insurance[deg]*years;
    const total = tAvg+lAvg+ins+d.flight;
    return {cc,name:d.name,total};
  }).sort((a,b)=>a.total-b.total);
  const maxTotal = sorted[sorted.length-1].total;
  container.innerHTML = sorted.map(({cc,name,total})=>{
    const flags={AU:'🇦🇺',UK:'🇬🇧',US:'🇺🇸',CA:'🇨🇦',NZ:'🇳🇿',SG:'🇸🇬',HK:'🇭🇰'};
    const pct = (total/maxTotal*100).toFixed(1);
    return `<div style="display:flex;align-items:center;gap:12px;">
      <span style="font-size:1.4rem;width:28px">${flags[cc]}</span>
      <div style="flex:1">
        <div style="display:flex;justify-content:space-between;margin-bottom:5px;font-size:.9rem;font-weight:600">
          <span>${name}</span><span style="color:var(--primary)">${fmt(total)}</span>
        </div>
        <div class="bar-track" style="height:8px"><div class="bar-fill" style="background:var(--primary);opacity:${0.4+0.6*total/maxTotal};width:${pct}%"></div></div>
      </div>
    </div>`;
  }).join('');
}

// ── BUDGET ──
function budgetCalc(){
  const budget = parseFloat(document.getElementById('budgetCNY').value);
  const deg = document.getElementById('budgetDegree').value;
  const res = document.getElementById('budgetResult');
  if(!budget||budget<5){res.innerHTML='';return;}
  const budgetCNY = budget*10000;
  const matches = [];
  Object.entries(COUNTRIES).forEach(([cc,d])=>{
    const years = deg==='master'?1.5:deg==='bachelor'?3:0.75;
    const [tMin,tMax]=d.tuition[deg];
    const tAvg=(tMin+tMax)/2*years;
    const lAvg=Object.values(d.living).reduce((a,b)=>a+b,0)/Object.values(d.living).length*years;
    const ins=d.insurance[deg]*years;
    const total=tAvg+lAvg+ins+d.flight;
    matches.push({cc,name:d.name,total,feasible:budgetCNY>=total*0.85});
  });
  matches.sort((a,b)=>a.total-b.total);
  const flags={AU:'🇦🇺',UK:'🇬🇧',US:'🇺🇸',CA:'🇨🇦',NZ:'🇳🇿',SG:'🇸🇬',HK:'🇭🇰'};
  res.innerHTML='<div style="font-size:.85rem;font-weight:700;color:var(--text-2);margin-bottom:10px">根据预算推荐目的地：</div>'+
  matches.map(m=>`<div style="display:flex;align-items:center;gap:10px;padding:9px 0;border-bottom:1px solid var(--border)">
    <span style="font-size:1.2rem">${flags[m.cc]}</span>
    <span style="flex:1;font-size:.9rem;font-weight:600;color:var(--text)">${m.name}</span>
    <span style="font-size:.85rem;color:var(--text-2)">${fmt(m.total)}</span>
    <span style="font-size:.75rem;font-weight:700;padding:3px 8px;border-radius:4px;background:${m.feasible?'rgba(34,160,107,.12)':'rgba(224,163,60,.12)'};color:${m.feasible?'var(--success)':'var(--accent-dark)'}">${m.feasible?'✓ 可行':'⚡ 偏紧'}</span>
  </div>`).join('')+
  '<p style="font-size:.75rem;color:var(--text-3);margin-top:10px">以均价估算，实际以院校报价为准</p>';
}

// ── PREFILL ──
function prefill(cc){
  document.getElementById('country').value = cc;
  onCountryChange();
  document.getElementById('calculator').scrollIntoView({behavior:'smooth'});
  // switch to full tab
  const tabs = document.querySelectorAll('.calc-tab');
  switchTab(tabs[0],'full');
}

// ── FAQ ──
function toggleFaq(el){
  const item = el.parentElement;
  const isOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item.open').forEach(i=>{ i.classList.remove('open'); i.querySelector('.faq-q').setAttribute('aria-expanded','false'); });
  if(!isOpen){ item.classList.add('open'); el.setAttribute('aria-expanded','true'); }
}
document.querySelectorAll('.faq-q').forEach(q=>{
  q.addEventListener('keydown',e=>{ if(e.key==='Enter'||e.key===' '){ e.preventDefault(); toggleFaq(q); }});
});
