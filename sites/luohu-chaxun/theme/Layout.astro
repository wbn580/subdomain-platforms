      },
      gz: {
        name: '广州', threshold: 60, thresholdLabel: '当前基准线：约 60 分（以官方公告为准）',
        eduScore:    { phd:40, master_oversea:30, master_domestic:26, bachelor_oversea:22, bachelor_domestic:18, bachelor_other:14, college:8 },
        ageScore:    { u25:20, '25_30':18, '30_35':15, '35_40':10, o40:4 },
        socialScore: { '0':0, '1':3, '2':8, '5':14, '7':20, '10':27, '15':35 },
        overseasScore:{ '0':0, '1':3, '2':6, '4':10, '5':14 },
        uniScore:    { qs50:20, qs100:14, qs200:10, qs500:5, other:2, na:0 },
      },
      sz: {
        name: '深圳', threshold: 100, thresholdLabel: '秒批条件：本科+社保≥1个月，积分参考线 100 分（以官方公告为准）',
        eduScore:    { phd:45, master_oversea:36, master_domestic:30, bachelor_oversea:26, bachelor_domestic:20, bachelor_other:15, college:8 },
        ageScore:    { u25:25, '25_30':22, '30_35':18, '35_40':12, o40:5 },
        socialScore: { '0':0, '1':5, '2':13, '5':22, '7':30, '10':38, '15':48 },
        overseasScore:{ '0':0, '1':4, '2':9, '4':14, '5':20 },
        uniScore:    { qs50:28, qs100:20, qs200:14, qs500:7, other:3, na:0 },
      },
    };

    let currentCity = 'sh';

    function switchCity(btn, city) {
      currentCity = city;
      document.querySelectorAll('.city-tab').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      // Reset result
      document.getElementById('calcResult').classList.remove('visible');
      calcScore();
    }

    function calcScore() {
      // Light auto-preview (don't show result until button clicked,
      // but keep data ready)
    }

    function runCalc() {
      const cfg = cityConfig[currentCity];
      const eduVal    = document.getElementById('eduLevel').value;
      const uniVal    = document.getElementById('uniTier').value;
      const ageVal    = document.getElementById('ageGroup').value;
      const socVal    = document.getElementById('socialSec').value;
      const ovsVal    = document.getElementById('overseasYrs').value;
      const specVal   = parseInt(document.getElementById('specialTalent').value) || 0;

      // Show skeleton briefly for UX feel
      const skel = document.getElementById('calcSkeleton');
      const result = document.getElementById('calcResult');
      result.classList.remove('visible');
      skel.classList.add('visible');

      setTimeout(() => {
        skel.classList.remove('visible');

        const brkEdu     = cfg.eduScore[eduVal]     || 0;
        const brkUni     = cfg.uniScore[uniVal]     || 0;
        const brkAge     = cfg.ageScore[ageVal]     || 0;
        const brkSocial  = cfg.socialScore[socVal]  || 0;
        const brkOverseas= cfg.overseasScore[ovsVal]|| 0;
        const brkSpecial = specVal;

        const total = brkEdu + brkUni + brkAge + brkSocial + brkOverseas + brkSpecial;

        // Ring animation
        const circumference = 2 * Math.PI * 28; // ~175.9
        const fill = Math.min(total / (cfg.threshold * 1.4), 1);
        const offset = circumference * (1 - fill);
        document.getElementById('ringFg').style.strokeDasharray = circumference;
        document.getElementById('ringFg').style.strokeDashoffset = offset;

        // Fill values
        document.getElementById('totalScore').textContent = total;
        document.getElementById('resultCityLabel').textContent = cfg.name + ' 落户积分估算';
        document.getElementById('resultThreshold').textContent = cfg.thresholdLabel;
        document.getElementById('brkEdu').innerHTML     = brkEdu     + ' <span>分</span>';
        document.getElementById('brkAge').innerHTML     = brkAge     + ' <span>分</span>';
        document.getElementById('brkSocial').innerHTML  = brkSocial  + ' <span>分</span>';
        document.getElementById('brkOverseas').innerHTML= brkOverseas+ ' <span>分</span>';
        document.getElementById('brkUni').innerHTML     = brkUni     + ' <span>分</span>';
        document.getElementById('brkSpecial').innerHTML = brkSpecial + ' <span>分</span>';

        const verdict = document.getElementById('resultVerdict');
        if (total >= cfg.threshold) {
          verdict.textContent = '✅ 初步达到参考门槛，建议专业顾问核查';
          verdict.className = 'result-verdict verdict-close';
        } else if (total >= cfg.threshold * 0.75) {
          verdict.textContent = '📈 接近门槛，差 ' + (cfg.threshold - total) + ' 分，可提升策略';
          verdict.className = 'result-verdict verdict-close';
        } else {
          verdict.textContent = '💡 仍需补充积累 ' + (cfg.threshold - total) + ' 分，建议咨询顾问';
          verdict.className = 'result-verdict verdict-need';
        }

        result.classList.add('visible');
      }, 900);
    }

    // ---- FAQ ACCORDION ----
    function toggleFaq(btn) {
      const item = btn.closest('.faq-item');
      const wasOpen = item.classList.contains('open');
      // Close all
      document.querySelectorAll('.faq-item.open').forEach(i => {
        i.classList.remove('open');
        i.querySelector('button').setAttribute('aria-expanded', 'false');
      });
      if (!wasOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    }

    // ---- WIDGET ----
    function openWidget() {
      // CTA placeholder — leads to UNILINK consultation
      alert('海归落户专业咨询即将接入，感谢您的耐心等待。');
    }

    // ---- KEYBOARD NAV FOR CARDS ----
    document.querySelectorAll('.city-card[tabindex], .article-card[tabindex]').forEach(card => {
      card.addEventListener('keypress', e => {
        if (e.key === 'Enter' || e.key === ' ') card.click();
      });
    });

    // ---- SMOOTH ANCHOR SCROLL ----
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const target = document.querySelector(a.getAttribute('href'));
        if (target) {
          e.preventDefault();
          const offset = 72;
          const top = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      });
    });

    // ---- FLOW STEP HOVER ----
    document.querySelectorAll('.flow-step').forEach((step, i) => {
      step.addEventListener('mouseenter', () => {
        document.querySelectorAll('.flow-step').forEach(s => s.classList.remove('active'));
        step.classList.add('active');
      });
    });
</script>

