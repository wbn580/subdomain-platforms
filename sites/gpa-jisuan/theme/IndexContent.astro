<!-- ============ CALCULATOR & PAGE JAVASCRIPT ============ -->
<script is:inline>
  'use strict';

  /* ---- Observe any new .reveal elements added dynamically ---- */
  const revealObsLocal = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); revealObsLocal.unobserve(e.target); } });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  // Also observe pre-existing .reveal from Layout (they may be seen by Layout's observer too, but double-observing is harmless)
  document.querySelectorAll('.reveal').forEach(el => revealObsLocal.observe(el));

  /* ---- Row counter ---- */
  let rowId = 3;

  function addRow() {
    const container = document.getElementById('courseRows');
    const row = document.createElement('div');
    row.className = 'course-row';
    row.setAttribute('data-row', rowId);
    row.setAttribute('role', 'row');
    row.innerHTML = '<div role="cell"><input class="course-input" type="text" placeholder="课程名称" aria-label="课程名称"></div>' +
      '<div role="cell"><input class="course-input score-input" type="number" min="0" max="100" placeholder="成绩" aria-label="成绩"></div>' +
      '<div role="cell"><input class="course-input credit-input" type="number" min="0.5" max="20" step="0.5" placeholder="学分" aria-label="学分"></div>' +
      '<div role="cell"><button class="del-btn" onclick="removeRow(' + rowId + ')" aria-label="删除此行">✕</button></div>';
    container.appendChild(row);
    rowId++;
    document.getElementById('calcResult').classList.remove('visible');
  }

  function removeRow(id) {
    const container = document.getElementById('courseRows');
    const rows = container.querySelectorAll('.course-row');
    if (rows.length <= 1) return;
    const row = container.querySelector('.course-row[data-row="' + id + '"]');
    if (row) row.remove();
    document.getElementById('calcResult').classList.remove('visible');
  }

  /* ---- GPA conversion algorithms ---- */
  function toGpa4_standard(pct) {
    if (pct >= 90) return 4.0;
    if (pct >= 85) return 3.7;
    if (pct >= 80) return 3.3;
    if (pct >= 75) return 3.0;
    if (pct >= 70) return 2.7;
    if (pct >= 65) return 2.3;
    if (pct >= 60) return 2.0;
    if (pct >= 50) return 1.0;
    return 0.0;
  }

  function toGpa4_pku(pct) {
    if (pct < 60) return 0.0;
    const g5 = (pct / 10) - 5;
    return Math.min(4.0, parseFloat((g5 * 0.8).toFixed(2)));
  }

  function toGpa4_moe(pct) {
    if (pct < 60) return 0.0;
    if (pct < 75) return 1.5;
    if (pct < 85) return 2.0;
    if (pct < 90) return 3.0;
    return 4.0;
  }

  function toUKDegree(gpa4) {
    if (gpa4 >= 3.7) return 'First';
    if (gpa4 >= 3.3) return '2:1';
    if (gpa4 >= 2.7) return '2:2';
    if (gpa4 >= 2.0) return 'Third';
    return 'Pass';
  }

  function calculate() {
    const scaleMethod = document.getElementById('scaleSelect').value;
    const rows = document.querySelectorAll('#courseRows .course-row');
    let totalPoints = 0, totalCredits = 0, totalPct = 0;
    let valid = false;

    rows.forEach(row => {
      const scoreEl = row.querySelector('.score-input');
      const creditEl = row.querySelector('.credit-input');
      if (!scoreEl || !creditEl) return;
      const score = parseFloat(scoreEl.value);
      const credit = parseFloat(creditEl.value);
      if (!isNaN(score) && !isNaN(credit) && credit > 0 && score >= 0 && score <= 100) {
        let gpa4;
        if (scaleMethod === 'standard') gpa4 = toGpa4_standard(score);
        else if (scaleMethod === 'pku') gpa4 = toGpa4_pku(score);
        else gpa4 = toGpa4_moe(score);
        totalPoints += gpa4 * credit;
        totalPct += score * credit;
        totalCredits += credit;
        valid = true;
      }
    });

    if (!valid || totalCredits === 0) {
      alert('请至少填写一门课程的有效成绩和学分。');
      return;
    }

    const weightedPct = totalPct / totalCredits;
    const weightedGpa4 = totalPoints / totalCredits;
    const ukDegree = toUKDegree(weightedGpa4);

    document.getElementById('resPct').textContent = weightedPct.toFixed(1);
    document.getElementById('resGpa4').textContent = weightedGpa4.toFixed(2);
    document.getElementById('resUK').textContent = ukDegree;

    // Scale bar animation
    const pct = Math.min(100, (weightedGpa4 / 4.0) * 100);
    document.getElementById('scaleBarFill').style.width = pct + '%';
    document.getElementById('barLabel').textContent = 'GPA ' + weightedGpa4.toFixed(2);

    const result = document.getElementById('calcResult');
    result.classList.add('visible');
    result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  /* ---- Conversion reference grid ---- */
  const convData = [
    { pct: '95–100', gpa: '4.0', uk: 'First', cls: 'first', note: '各算法满绩' },
    { pct: '90–94', gpa: '4.0', uk: 'First', cls: 'first', note: '通用四分制满绩' },
    { pct: '85–89', gpa: '3.7', uk: 'First', cls: 'first', note: 'WES A−/A档' },
    { pct: '80–84', gpa: '3.3', uk: 'First', cls: 'first', note: '部分算法 3.3' },
    { pct: '75–79', gpa: '3.0', uk: '2:1', cls: 'upper-second', note: 'B档 · 大多院校达标' },
    { pct: '70–74', gpa: '2.7', uk: '2:1', cls: 'upper-second', note: '2:1 下沿' },
    { pct: '65–69', gpa: '2.3', uk: '2:2', cls: 'lower-second', note: '英 2:2 门槛' },
    { pct: '60–64', gpa: '2.0', uk: '2:2', cls: 'lower-second', note: '及格线' },
  ];
  const convGrid = document.getElementById('convGrid');
  convData.forEach((d, i) => {
    const el = document.createElement('div');
    el.className = 'conv-card reveal reveal-delay-' + ((i % 4) + 1);
    el.setAttribute('role', 'listitem');
    el.innerHTML = '<div class="cc-pct">' + d.pct + '</div>' +
      '<div class="cc-gpa">GPA ' + d.gpa + ' / 4.0</div>' +
      '<div class="cc-uk ' + d.cls + '">' + d.uk + '</div>' +
      '<div class="cc-note">' + d.note + '</div>';
    convGrid.appendChild(el);
    revealObsLocal.observe(el);
  });

  /* ---- FAQ ---- */
  const faqs = [
    { q: '中国百分制直接换算成 4.0 制可靠吗？', a: '不同的换算算法（通用四分制、北大算法、WES 标准）结果有差异。北美院校通常接受 WES 认证结果；英国院校以百分制或国内 GPA 判断，本工具仅供你自评估，申请时请以院校官方要求为准。' },
    { q: '加权 GPA 和普通平均 GPA 有什么区别？', a: '普通平均 GPA 是各科绩点直接求平均，加权 GPA 以学分为权重加权，更能反映真实学业水平。大多数院校和认证机构使用加权 GPA，本工具也采用加权计算。' },
    { q: '我的 GPA 是 3.2，够申请澳洲 G8 大学吗？', a: 'G8 大学多数项目要求 GPA 3.0–3.5 之间，3.2 属于基本达线。但具体还需结合专业、英语成绩、是否需要提交研究计划等因素综合评估。建议咨询专业留学顾问做个人定向评估。' },
    { q: '英式等第 2:1 相当于美式 GPA 多少？', a: '通常 2:1（60-69%区间）对应美式 GPA 约 3.0–3.5，换算在不同院校和算法下略有差异。First（≥70%）约对应 3.7–4.0。' },
    { q: '什么是 WES 认证？申请是否必须提交？', a: 'WES（World Education Services）是北美最通用的国际学历认证机构，为申请学校或雇主评估中国学历。部分学校和签证要求提交，但并非所有申请都强制，请以目标院校要求为准。' },
    { q: '毕业后还能补救 GPA 吗？', a: '部分院校接受修读研究生预科课程（如 Diploma/Pre-Master）来展示近期学业能力。此外，优秀的软性背景（科研/实习/工作经历）可以弥补 GPA 不足，可向留学顾问寻求具体策略。' },
  ];
  const faqList = document.getElementById('faqList');
  faqs.forEach((f, i) => {
    const item = document.createElement('div');
    item.className = 'faq-item';
    item.setAttribute('role', 'listitem');
    item.innerHTML = '<div class="faq-q" onclick="toggleFaq(this)" role="button" tabindex="0" aria-expanded="false" onkeydown="if(event.key===\'Enter\'||event.key===\' \')toggleFaq(this)">' +
      '<span>' + f.q + '</span>' +
      '<svg class="faq-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>' +
      '</div>' +
      '<div class="faq-a" role="region"><div class="faq-a-inner">' + f.a + '</div></div>';
    faqList.appendChild(item);
  });

  function toggleFaq(el) {
    const item = el.closest('.faq-item');
    const isOpen = item.classList.toggle('open');
    el.setAttribute('aria-expanded', String(isOpen));
  }

  /* ---- Editorial Picks ---- */
  const picks = [
    { emoji: '📊', g: 'g1', tag: '申请策略', title: '中国学生 GPA 不足 3.0，还能申请澳八大研究生吗？', desc: '从条件录取、衔接课程到真实案例，系统梳理低 GPA 申请路径与成功率分析。', date: '2026-06-15' },
    { emoji: '🎓', g: 'g2', tag: 'WES 认证', title: 'WES 成绩认证申请全流程：中国学生操作指南（2026 版）', desc: '材料清单、网申步骤、时间预估、费用明细，首次申请 WES 必读。', date: '2026-06-10' },
    { emoji: '🇬🇧', g: 'g3', tag: '英式等第', title: '英国学位等第（First / 2:1 / 2:2）换算成中国成绩是多少？', desc: '英国 30+ 所大学真实换算标准对照，帮助回国就业或继续深造的学生准确换算。', date: '2026-06-05' },
  ];
  const picksGrid = document.getElementById('picksGrid');
  picks.forEach((p, i) => {
    const card = document.createElement('div');
    card.className = 'pick-card reveal reveal-delay-' + (i + 1);
    card.innerHTML = '<div class="pick-img">' +
      '<div class="pick-img-gradient ' + p.g + '" aria-hidden="true"></div>' +
      '<span class="pick-img-emoji" aria-hidden="true">' + p.emoji + '</span>' +
      '</div>' +
      '<div class="pick-body">' +
      '<div class="pick-tag">' + p.tag + '</div>' +
      '<h3>' + p.title + '</h3>' +
      '<p>' + p.desc + '</p>' +
      '</div>' +
      '<div class="pick-footer">' +
      '<span class="pick-date">' + p.date + '</span>' +
      '<span class="pick-read">阅读全文 →</span>' +
      '</div>';
    picksGrid.appendChild(card);
    revealObsLocal.observe(card);
  });
</script>
